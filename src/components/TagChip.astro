---
export interface Props {
  label: string;
  href: string;
}

const { label, href } = Astro.props;
---

<a
  class="inline-flex items-center rounded-full border border-border bg-surface px-2.5 py-1 text-xs font-medium text-muted no-underline transition hover:border-accent hover:text-text"
  href={href}
>
  {label}
</a>
