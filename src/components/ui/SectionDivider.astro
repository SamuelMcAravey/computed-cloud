---
// Usage: <SectionDivider spacing="lg" />
import Divider from "./Divider.astro";

export interface Props {
  spacing?: "sm" | "md" | "lg";
  label?: string;
  class?: string;
}

const { spacing = "md", label, class: className } = Astro.props;

const spacingClasses = {
  sm: "my-8",
  md: "my-12",
  lg: "my-16",
} as const;
---

<Divider label={label} class:list={[spacingClasses[spacing], className]} />
