---
// Usage: <IconBadge tone="success"><span slot="icon">✓</span>Ready</IconBadge>
import Badge from "./Badge.astro";

export interface Props {
  tone?: "neutral" | "primary" | "success" | "warning" | "danger";
  size?: "sm" | "md";
  class?: string;
  iconSize?: "sm" | "md";
}

const {
  tone = "neutral",
  size = "sm",
  class: className,
  iconSize = "sm",
} = Astro.props;

const iconSizeClasses = {
  sm: "text-sm",
  md: "text-base",
} as const;
---

<Badge tone={tone} size={size} class={className}>
  <span
    class:list={[
      "mr-1.5 inline-flex items-center leading-none",
      iconSizeClasses[iconSize],
    ]}
  >
    <slot name="icon" />
  </span>
  <slot />
</Badge>
