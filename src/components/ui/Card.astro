---
// Usage: <Card variant="muted">...</Card>
export interface Props {
  as?: keyof HTMLElementTagNameMap;
  href?: string;
  variant?: "white" | "muted" | "outline";
  padding?: "sm" | "md" | "lg";
  rounded?: "xl" | "2xl";
  shadow?: "none" | "sm";
  class?: string;
  ariaLabel?: string;
}

const {
  as: Tag = "div",
  href,
  variant = "white",
  padding = "md",
  rounded = "2xl",
  shadow = "sm",
  class: className,
  ariaLabel,
} = Astro.props;

const variantClasses = {
  white: "bg-white border border-slate-200",
  muted: "bg-slate-50 border border-slate-200",
  outline: "border border-slate-200 bg-transparent",
} as const;

const paddingClasses = {
  sm: "p-4",
  md: "p-6",
  lg: "p-8",
} as const;

const roundedClasses = {
  xl: "rounded-xl",
  "2xl": "rounded-2xl",
} as const;

const shadowClasses = {
  none: "",
  sm: "shadow-sm",
} as const;
---

{href ? (
  <a
    href={href}
    aria-label={ariaLabel}
    class:list={[
      "block transition-shadow focus:outline-none focus:ring-2 focus:ring-blue-600 focus:ring-offset-2 hover:border-slate-300 hover:shadow-md",
      variantClasses[variant],
      paddingClasses[padding],
      roundedClasses[rounded],
      shadowClasses[shadow],
      className,
    ]}
  >
    <slot />
  </a>
) : (
  <Tag
    class:list={[
      variantClasses[variant],
      paddingClasses[padding],
      roundedClasses[rounded],
      shadowClasses[shadow],
      className,
    ]}
  >
    <slot />
  </Tag>
)}
