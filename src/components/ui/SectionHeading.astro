---
// Usage: <SectionHeading headline="Title" body="Supporting copy." />
export interface Props {
  eyebrow?: string;
  headline: string;
  body?: string | string[];
  align?: "left" | "center";
  size?: "sm" | "md" | "lg";
  headingTag?: "h2" | "h3";
  maxWidth?: "none" | "narrow";
  class?: string;
}

const {
  eyebrow,
  headline,
  body,
  align = "left",
  size = "md",
  headingTag: HeadingTag = "h2",
  maxWidth = "narrow",
  class: className,
} = Astro.props;

const alignmentClasses = {
  left: "text-left items-start",
  center: "text-center items-center mx-auto",
} as const;

const headlineClasses = {
  sm: "text-2xl sm:text-3xl",
  md: "text-3xl sm:text-4xl",
  lg: "text-4xl sm:text-5xl",
} as const;

const maxWidthClasses = {
  none: "",
  narrow: "max-w-3xl",
} as const;

const paragraphs = Array.isArray(body) ? body : body ? [body] : [];
---

<div
  class:list={[
    "flex flex-col space-y-4",
    alignmentClasses[align],
    maxWidthClasses[maxWidth],
    className,
  ]}
>
  {eyebrow ? (
    <p class="text-sm font-semibold uppercase tracking-wider text-slate-500">
      {eyebrow}
    </p>
  ) : null}
  <HeadingTag class:list={[headlineClasses[size], "text-slate-900"]}>
    {headline}
  </HeadingTag>
  {paragraphs.length ? (
    <div class="space-y-4">
      {paragraphs.map((copy) => (
        <p class="text-slate-600">{copy}</p>
      ))}
    </div>
  ) : null}
</div>
