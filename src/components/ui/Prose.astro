---
// Usage: <Prose size="base">...</Prose>
export interface Props {
  size?: "sm" | "base" | "lg";
  tone?: "default" | "muted";
  maxWidth?: "none" | "narrow";
  class?: string;
}

const {
  size = "sm",
  tone = "muted",
  maxWidth = "narrow",
  class: className,
} = Astro.props;

const sizeClasses = {
  sm: "text-sm",
  base: "text-base",
  lg: "text-lg",
} as const;

const toneClasses = {
  default: "text-slate-700",
  muted: "text-slate-600",
} as const;

const maxWidthClasses = {
  none: "",
  narrow: "max-w-3xl",
} as const;
---

<div
  class:list={[
    "space-y-4 [&_h2]:text-slate-900 [&_h2]:text-2xl [&_h2]:font-bold [&_h3]:text-slate-900 [&_h3]:text-xl [&_h3]:font-semibold [&_a]:text-blue-700 [&_a]:underline [&_a:hover]:text-blue-800 [&_ul]:list-disc [&_ul]:pl-5 [&_ol]:list-decimal [&_ol]:pl-5 [&_strong]:text-slate-900",
    sizeClasses[size],
    toneClasses[tone],
    maxWidthClasses[maxWidth],
    className,
  ]}
>
  <slot />
</div>
