---
// Usage: <ButtonLink href="/contact">Contact</ButtonLink>
export interface Props {
  variant?: "primary" | "secondary" | "ghost";
  size?: "sm" | "md" | "lg";
  fullWidth?: boolean;
  class?: string;
  href: string;
  target?: string;
  rel?: string;
  ariaLabel?: string;
  isExternal?: boolean;
}

const {
  variant = "primary",
  size = "md",
  fullWidth = false,
  class: className,
  href,
  target,
  rel,
  ariaLabel,
  isExternal = false,
} = Astro.props;

const resolvedTarget = target ?? (isExternal ? "_blank" : undefined);
const resolvedRel = rel ?? (isExternal ? "noopener noreferrer" : undefined);

const variantClasses = {
  primary: "bg-blue-600 text-white shadow hover:bg-blue-700",
  secondary:
    "border border-slate-200 text-slate-700 hover:border-slate-300 hover:bg-slate-100 hover:text-slate-900",
  ghost: "text-slate-700 hover:bg-slate-100",
} as const;

const sizeClasses = {
  sm: "px-4 py-2 text-sm rounded-lg",
  md: "px-6 py-3 text-sm rounded-lg",
  lg: "px-7 py-3.5 text-base rounded-xl",
} as const;
---

<a
  href={href}
  target={resolvedTarget}
  rel={resolvedRel}
  aria-label={ariaLabel}
  class:list={[
    "inline-flex items-center gap-2 font-semibold transition-colors focus:outline-none focus:ring-2 focus:ring-blue-600 focus:ring-offset-2",
    variantClasses[variant],
    sizeClasses[size],
    fullWidth && "w-full justify-center",
    className,
  ]}
>
  {Astro.slots.has("startIcon") ? (
    <span class="shrink-0">
      <slot name="startIcon" />
    </span>
  ) : null}
  <slot />
  {Astro.slots.has("endIcon") ? (
    <span class="shrink-0">
      <slot name="endIcon" />
    </span>
  ) : null}
</a>
