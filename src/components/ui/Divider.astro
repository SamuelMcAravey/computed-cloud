---
// Usage: <Divider label="Overview" />
export interface Props {
  orientation?: "horizontal" | "vertical";
  label?: string;
  class?: string;
}

const { orientation = "horizontal", label, class: className } = Astro.props;
---

{orientation === "vertical" ? (
  <div class:list={["w-px self-stretch bg-slate-200", className]} />
) : label ? (
  <div class:list={["flex items-center", className]}>
    <div class="flex-1 border-t border-slate-200" />
    <span class="px-3 text-xs font-semibold uppercase tracking-wider text-slate-500">
      {label}
    </span>
    <div class="flex-1 border-t border-slate-200" />
  </div>
) : (
  <hr class:list={["border-slate-200", className]} />
)}
