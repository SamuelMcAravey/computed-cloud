---
// Usage: <ResponsiveImage src="/image.jpg" alt="Description" />
export interface Props {
  src: string;
  alt?: string;
  decorative?: boolean;
  loading?: "lazy" | "eager";
  decoding?: "async" | "auto" | "sync";
  width?: number | string;
  height?: number | string;
  sizes?: string;
  srcset?: string;
  fit?: "cover" | "contain";
  rounded?: "none" | "xl" | "2xl";
  variant?: "plain" | "framed";
  class?: string;
  frameClass?: string;
}

const {
  src,
  alt,
  decorative = false,
  loading = "lazy",
  decoding = "async",
  width,
  height,
  sizes,
  srcset,
  fit = "cover",
  rounded = "xl",
  variant = "plain",
  class: className,
  frameClass,
} = Astro.props;

if (!decorative && !alt) {
  if (import.meta.env.DEV) {
    throw new Error("ResponsiveImage requires alt text unless decorative is true.");
  } else {
    console.warn("ResponsiveImage missing alt text. Provide alt or set decorative.");
  }
}

const fitClasses = {
  cover: "object-cover",
  contain: "object-contain",
} as const;

const roundedClasses = {
  none: "",
  xl: "rounded-xl",
  "2xl": "rounded-2xl",
} as const;

const imgBaseClasses =
  variant === "framed"
    ? "w-full h-full rounded-xl"
    : "w-full h-full";
---

{variant === "framed" ? (
  <div
    class:list={[
      "rounded-2xl border border-slate-200 bg-slate-50 p-4",
      frameClass,
    ]}
  >
    <img
      src={src}
      alt={decorative ? "" : alt}
      aria-hidden={decorative ? "true" : undefined}
      loading={loading}
      decoding={decoding}
      width={width}
      height={height}
      sizes={sizes}
      srcset={srcset}
      class:list={[
        imgBaseClasses,
        fitClasses[fit],
        rounded === "none" ? "" : roundedClasses[rounded],
        className,
      ]}
    />
  </div>
) : (
  <img
    src={src}
    alt={decorative ? "" : alt}
    aria-hidden={decorative ? "true" : undefined}
    loading={loading}
    decoding={decoding}
    width={width}
    height={height}
    sizes={sizes}
    srcset={srcset}
    class:list={[
      imgBaseClasses,
      fitClasses[fit],
      rounded === "none" ? "" : roundedClasses[rounded],
      className,
    ]}
  />
)}
