---
import type { CollectionEntry } from "astro:content";
import TagChip from "@components/TagChip.astro";
import { normalizeTag } from "../utils/blog";

export interface Props {
  post: CollectionEntry<"blog">;
  slug: string;
}

const { post, slug } = Astro.props;
const date = post.data.pubDate.toLocaleDateString("en-US", {
  year: "numeric",
  month: "short",
  day: "numeric",
});
---

<article class="rounded-2xl border border-border bg-surface/90 p-6 shadow-sm transition hover:-translate-y-0.5 hover:shadow-card">
  <div class="text-xs uppercase tracking-wide text-muted">{date}</div>
  <h2 class="mt-3 font-heading text-2xl font-semibold text-text">
    <a class="hover:text-primary" href={`/blog/${slug}`}>{post.data.title}</a>
  </h2>
  <p class="mt-3 text-sm text-muted">{post.data.description}</p>
  {post.data.tags.length > 0 && (
    <div class="mt-4 flex flex-wrap gap-2">
      {post.data.tags.map((tag) => (
        <TagChip label={tag} href={`/tags/${normalizeTag(tag)}`} />
      ))}
    </div>
  )}
</article>
