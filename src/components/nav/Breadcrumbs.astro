---
import { site } from "../../data/site";

export interface Props {
  items?: Array<{ label: string; href?: string }>;
  currentLabel?: string;
  currentPathname?: string;
  includeHome?: boolean;
}

const {
  items,
  currentLabel,
  currentPathname,
  includeHome = true,
} = Astro.props;

const normalizePath = (path: string): string => {
  if (!path || path === "/") {
    return "/";
  }

  return path.replace(/\/+$/, "");
};

const titleize = (value: string): string =>
  value
    .split(/[\s-]+/)
    .filter(Boolean)
    .map((word) => word[0]?.toUpperCase() + word.slice(1))
    .join(" ");

const resolvedPath = normalizePath(currentPathname ?? Astro.url.pathname);

let resolvedItems: Array<{ label: string; href?: string }> = [];

if (items && items.length > 0) {
  resolvedItems = items;
} else {
  const homeItem = { label: "Home", href: "/" };
  if (includeHome) {
    resolvedItems.push(homeItem);
  }

  let label = currentLabel;

  if (!label) {
    const navMatch = site.nav
      .map((item) => ({ ...item, normalized: normalizePath(item.href) }))
      .filter((item) => resolvedPath.startsWith(item.normalized))
      .sort((a, b) => b.normalized.length - a.normalized.length)[0];

    if (navMatch && navMatch.normalized !== "/") {
      label = navMatch.label;
    } else if (resolvedPath !== "/") {
      const segment = resolvedPath.split("/").filter(Boolean).pop();
      label = segment ? titleize(segment) : undefined;
    }
  }

  if (resolvedPath === "/") {
    if (!includeHome) {
      resolvedItems = [{ label: "Home" }];
    }
  } else if (label) {
    resolvedItems.push({ label });
  }
}
---

<nav aria-label="Breadcrumb">
  <ol class="flex flex-wrap items-center gap-x-2 gap-y-1 text-sm text-slate-500">
    {resolvedItems.map((item, index) => {
      const isLast = index === resolvedItems.length - 1;
      return (
        <>
          <li class="flex items-center">
            {isLast ? (
              <span class="text-slate-700" aria-current="page">
                {item.label}
              </span>
            ) : item.href ? (
              <a
                href={item.href}
                class="text-slate-500 transition-colors hover:text-blue-600 focus:outline-none focus:ring-2 focus:ring-blue-600 focus:ring-offset-2"
              >
                {item.label}
              </a>
            ) : (
              <span class="text-slate-500">{item.label}</span>
            )}
          </li>
          {!isLast && (
            <li aria-hidden="true" class="text-slate-400">
              /
            </li>
          )}
        </>
      );
    })}
  </ol>
</nav>
