---
export interface Props {
  links: Array<{ label: string; href: string }>;
  currentPathname: string;
  layout?: "horizontal" | "vertical";
  match?: "exact" | "prefix";
  className?: string;
}

const {
  links,
  currentPathname,
  layout = "horizontal",
  match = "prefix",
  className,
} = Astro.props;

const normalizePath = (path: string): string => {
  if (!path || path === "/") {
    return "/";
  }

  return path.replace(/\/+$/, "");
};

const normalizedCurrent = normalizePath(currentPathname);
---

<ul
  class:list={[
    layout === "horizontal"
      ? "flex items-center space-x-1"
      : "flex flex-col space-y-2",
    className,
  ]}
>
  {links.map((link) => {
    const normalizedHref = normalizePath(link.href);
    const isRoot = normalizedHref === "/";
    const isActive = isRoot
      ? normalizedCurrent === "/"
      : match === "exact"
        ? normalizedCurrent === normalizedHref
        : normalizedCurrent.startsWith(normalizedHref);

    return (
      <li>
        <a
          href={link.href}
          aria-current={isActive ? "page" : undefined}
          class:list={[
            "px-4 py-2 text-sm font-medium text-slate-700 hover:text-blue-600 hover:bg-blue-50 rounded-lg transition-all relative group",
            isActive && "nav-active",
          ]}
        >
          {link.label}
        </a>
      </li>
    );
  })}
</ul>
