---
export interface Props {
  headline?: string;
  body?: string;
  columns: Array<{ key: string; label: string }>;
  rows: Array<{ label: string; values: Record<string, string | boolean | null> }>;
  booleanStyle?: "check" | "yesno";
}

const {
  headline,
  body,
  columns,
  rows,
  booleanStyle = "check",
} = Astro.props;

if (!columns || columns.length === 0 || !rows || rows.length === 0) {
  return null;
}
---

<section class="container mx-auto px-4 py-12 sm:px-6 lg:px-8">
  {(headline || body) && (
    <div class="max-w-2xl space-y-2">
      {headline && <h2 class="text-2xl font-bold text-slate-900">{headline}</h2>}
      {body && <p class="text-sm text-slate-600">{body}</p>}
    </div>
  )}
  <div class="mt-8 overflow-x-auto">
    <table class="min-w-[720px] w-full border-collapse rounded-2xl border border-slate-200 bg-white">
      <thead class="bg-slate-50">
        <tr>
          <th
            scope="col"
            class="px-4 py-3 text-left text-xs font-semibold uppercase tracking-wider text-slate-500"
          >
            Feature
          </th>
          {columns.map((column) => (
            <th
              scope="col"
              class="px-4 py-3 text-left text-xs font-semibold uppercase tracking-wider text-slate-500"
            >
              {column.label}
            </th>
          ))}
        </tr>
      </thead>
      <tbody class="divide-y divide-slate-200 bg-white">
        {rows.map((row) => (
          <tr>
            <th
              scope="row"
              class="px-4 py-4 text-sm font-semibold text-slate-700"
            >
              {row.label}
            </th>
            {columns.map((column) => {
              const value = row.values[column.key];
              return (
                <td class="px-4 py-4 text-sm text-slate-600">
                  {typeof value === "boolean" ? (
                    booleanStyle === "yesno" ? (
                      value ? "Yes" : "No"
                    ) : value ? (
                      <span class="inline-flex h-6 w-6 items-center justify-center rounded-full bg-emerald-100 text-emerald-700">
                        <svg
                          viewBox="0 0 20 20"
                          fill="currentColor"
                          class="h-3.5 w-3.5"
                          aria-hidden="true"
                        >
                          <path
                            fill-rule="evenodd"
                            d="M16.704 5.29a1 1 0 0 1 .006 1.414l-7.25 7.3a1 1 0 0 1-1.42 0L3.29 10.2a1 1 0 1 1 1.42-1.4l3.02 3.02 6.54-6.55a1 1 0 0 1 1.414.02Z"
                            clip-rule="evenodd"
                          />
                        </svg>
                      </span>
                    ) : (
                      <span class="text-slate-400">—</span>
                    )
                  ) : value ? (
                    value
                  ) : (
                    <span class="text-slate-400">—</span>
                  )}
                </td>
              );
            })}
          </tr>
        ))}
      </tbody>
    </table>
  </div>
</section>
