---
export interface Props {
  eyebrow?: string;
  headline: string;
  body?: string[];
  highlights: string[];
  variant?: "check" | "dot";
  columns?: 1 | 2;
}

const {
  eyebrow,
  headline,
  body,
  highlights,
  variant = "check",
  columns = 2,
} = Astro.props;

const hasIntro = Boolean(eyebrow || headline || (body && body.length));
const hasHighlights = Boolean(highlights && highlights.length);

if (!hasIntro && !hasHighlights) {
  return null;
}

const columnClasses = {
  1: "grid-cols-1",
  2: "grid-cols-1 md:grid-cols-2",
} as const;
---

<section class="container mx-auto px-4 py-12 sm:px-6 lg:px-8">
  {hasIntro && (
    <div class="max-w-2xl space-y-3">
      {eyebrow && (
        <p class="text-xs font-semibold uppercase tracking-wider text-slate-500">
          {eyebrow}
        </p>
      )}
      <h2 class="text-2xl font-bold text-slate-900">{headline}</h2>
      {body && body.length > 0 && (
        <div class="space-y-2 text-sm text-slate-600">
          {body.map((paragraph) => (
            <p>{paragraph}</p>
          ))}
        </div>
      )}
    </div>
  )}

  {hasHighlights ? (
    <ul
      class:list={[
        "mt-8 grid gap-4",
        columnClasses[columns],
      ]}
    >
      {highlights.map((item) => (
        <li class="flex items-start gap-3 rounded-xl border border-slate-200 bg-white p-4">
          {variant === "check" ? (
            <span class="mt-0.5 inline-flex h-5 w-5 items-center justify-center rounded-full bg-emerald-100 text-emerald-700">
              <svg
                viewBox="0 0 20 20"
                fill="currentColor"
                class="h-3.5 w-3.5"
                aria-hidden="true"
              >
                <path
                  fill-rule="evenodd"
                  d="M16.704 5.29a1 1 0 0 1 .006 1.414l-7.25 7.3a1 1 0 0 1-1.42 0L3.29 10.2a1 1 0 1 1 1.42-1.4l3.02 3.02 6.54-6.55a1 1 0 0 1 1.414.02Z"
                  clip-rule="evenodd"
                />
              </svg>
            </span>
          ) : (
            <span class="mt-2 h-2 w-2 rounded-full bg-slate-400" aria-hidden="true" />
          )}
          <p class="text-sm text-slate-700">{item}</p>
        </li>
      ))}
    </ul>
  ) : null}
</section>
