---
interface Props {
  headline?: string;
  items: { title: string; description: string }[];
}

const { headline, items } = Astro.props;
---

<section class="container mx-auto px-4 py-12 sm:px-6 lg:px-8">
  {headline && <h2 class="text-2xl font-bold text-slate-900">{headline}</h2>}
  <div class={`${headline ? "mt-8 " : ""}grid gap-6 md:grid-cols-2 lg:grid-cols-3`}>
    {items.map((item) => (
      <div class="rounded-xl border border-slate-200 bg-white p-6">
        <h3 class="text-lg font-semibold text-slate-900">{item.title}</h3>
        <p class="mt-2 text-sm text-slate-600">{item.description}</p>
      </div>
    ))}
  </div>
</section>
