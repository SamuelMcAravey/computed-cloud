---
export interface Props {
  eyebrow?: string;
  headline: string;
  body?: string;
  plans: Array<{
    name: string;
    price?: string;
    priceNote?: string;
    description?: string;
    features: string[];
    cta: { label: string; href: string };
    featured?: boolean;
  }>;
  variant?: "simple" | "withNotes";
  details?: {
    billingHeading?: string;
    billingSteps?: string[];
    includedHeading?: string;
    includedItems?: string[];
  };
}

const { eyebrow, headline, body, plans, variant = "simple", details } = Astro.props;
const showDetails =
  Boolean(details?.billingSteps?.length) || Boolean(details?.includedItems?.length);
const featuredPlan = plans[0];

if (!plans || plans.length === 0) {
  return null;
}
---

<section class="container mx-auto px-4 py-12 sm:px-6 lg:px-8">
  <div class="max-w-2xl space-y-2">
    {eyebrow && (
      <p class="text-xs font-semibold uppercase tracking-wider text-slate-500">
        {eyebrow}
      </p>
    )}
    <h2 class="text-2xl font-bold text-slate-900">{headline}</h2>
    {body && <p class="text-sm text-slate-600">{body}</p>}
  </div>
  {showDetails && featuredPlan ? (
    <div class="mt-8 grid gap-8 lg:grid-cols-[minmax(0,0.95fr)_minmax(0,1.05fr)]">
      <div
        class:list={[
          "flex h-full flex-col rounded-2xl border p-6",
          featuredPlan.featured
            ? "border-blue-200 bg-blue-50 shadow-md"
            : "border-slate-200 bg-white",
        ]}
      >
        <div class="space-y-2">
          <h3 class="text-lg font-semibold text-slate-900">{featuredPlan.name}</h3>
          {featuredPlan.description && (
            <p class="text-sm text-slate-600">{featuredPlan.description}</p>
          )}
        </div>
        {(featuredPlan.price ||
          (variant === "withNotes" && featuredPlan.priceNote)) && (
          <div class="mt-4 space-y-1">
            {featuredPlan.price && (
              <p class="text-3xl font-semibold text-slate-900">
                {featuredPlan.price}
              </p>
            )}
            {variant === "withNotes" && featuredPlan.priceNote && (
              <p class="text-xs text-slate-500">{featuredPlan.priceNote}</p>
            )}
          </div>
        )}
        <ul class="mt-6 space-y-3 text-sm text-slate-600">
          {featuredPlan.features.map((feature) => (
            <li class="flex items-start gap-2">
              <span class="mt-0.5 inline-flex h-5 w-5 items-center justify-center rounded-full bg-emerald-100 text-emerald-700">
                <svg
                  viewBox="0 0 20 20"
                  fill="currentColor"
                  class="h-3.5 w-3.5"
                  aria-hidden="true"
                >
                  <path
                    fill-rule="evenodd"
                    d="M16.704 5.29a1 1 0 0 1 .006 1.414l-7.25 7.3a1 1 0 0 1-1.4
42 0L3.29 10.2a1 1 0 1 1 1.42-1.4l3.02 3.02 6.54-6.55a1 1 0 0 1 1.414.02Z"
                    clip-rule="evenodd"
                  />
                </svg>
              </span>
              <span>{feature}</span>
            </li>
          ))}
        </ul>
        <div class="mt-6">
          <a
            href={featuredPlan.cta.href}
            class:list={[
              "inline-flex w-full items-center justify-center px-6 py-3 text-sm font-semibold rounded-lg transition-colors",
              featuredPlan.featured
                ? "bg-blue-600 text-white shadow hover:bg-blue-700"
                : "border border-blue-200 text-blue-600 hover:bg-blue-50",
            ]}
          >
            {featuredPlan.cta.label}
          </a>
        </div>
      </div>
      <div class="space-y-6">
        {details?.billingSteps?.length ? (
          <div class="rounded-2xl border border-slate-200 bg-white p-6">
            <p class="text-sm font-semibold text-slate-900">
              {details.billingHeading ?? "How billing works"}
            </p>
            <ol class="mt-4 space-y-3 text-sm text-slate-600">
              {details.billingSteps.map((step, index) => (
                <li class="flex gap-3">
                  <span class="mt-0.5 inline-flex h-6 w-6 items-center justify-center rounded-full bg-slate-100 text-xs font-semibold text-slate-700">
                    {index + 1}
                  </span>
                  <span>{step}</span>
                </li>
              ))}
            </ol>
          </div>
        ) : null}
        {details?.includedItems?.length ? (
          <div class="rounded-2xl border border-slate-200 bg-white p-6">
            <p class="text-sm font-semibold text-slate-900">
              {details.includedHeading ?? "What's included"}
            </p>
            <ul class="mt-4 space-y-2 text-sm text-slate-600">
              {details.includedItems.map((item) => (
                <li class="flex gap-2">
                  <span class="mt-1 h-1.5 w-1.5 rounded-full bg-blue-600"></span>
                  <span>{item}</span>
                </li>
              ))}
            </ul>
          </div>
        ) : null}
      </div>
    </div>
  ) : (
    <div class="mt-10 grid gap-6 md:grid-cols-2 lg:grid-cols-3">
      {plans.map((plan) => (
        <div
          class:list={[
            "flex h-full flex-col rounded-2xl border p-6",
            plan.featured
              ? "border-blue-200 bg-blue-50 shadow-md"
              : "border-slate-200 bg-white",
          ]}
        >
          <div class="space-y-2">
            <h3 class="text-lg font-semibold text-slate-900">{plan.name}</h3>
            {plan.description && (
              <p class="text-sm text-slate-600">{plan.description}</p>
            )}
          </div>
          {(plan.price || (variant === "withNotes" && plan.priceNote)) && (
            <div class="mt-4 space-y-1">
              {plan.price && (
                <p class="text-3xl font-semibold text-slate-900">{plan.price}</p>
              )}
              {variant === "withNotes" && plan.priceNote && (
                <p class="text-xs text-slate-500">{plan.priceNote}</p>
              )}
            </div>
          )}
          <ul class="mt-6 space-y-3 text-sm text-slate-600">
            {plan.features.map((feature) => (
              <li class="flex items-start gap-2">
                <span class="mt-0.5 inline-flex h-5 w-5 items-center justify-center rounded-full bg-emerald-100 text-emerald-700">
                  <svg
                    viewBox="0 0 20 20"
                    fill="currentColor"
                    class="h-3.5 w-3.5"
                    aria-hidden="true"
                  >
                    <path
                      fill-rule="evenodd"
                      d="M16.704 5.29a1 1 0 0 1 .006 1.414l-7.25 7.3a1 1 0 0 1-1.4
42 0L3.29 10.2a1 1 0 1 1 1.42-1.4l3.02 3.02 6.54-6.55a1 1 0 0 1 1.414.02Z"
                      clip-rule="evenodd"
                    />
                  </svg>
                </span>
                <span>{feature}</span>
              </li>
            ))}
          </ul>
          <div class="mt-6">
            <a
              href={plan.cta.href}
              class:list={[
                "inline-flex w-full items-center justify-center px-6 py-3 text-sm font-semibold rounded-lg transition-colors",
                plan.featured
                  ? "bg-blue-600 text-white shadow hover:bg-blue-700"
                  : "border border-blue-200 text-blue-600 hover:bg-blue-50",
              ]}
            >
              {plan.cta.label}
            </a>
          </div>
        </div>
      ))}
    </div>
  )}
</section>
