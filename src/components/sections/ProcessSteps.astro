---
export interface Props {
  eyebrow?: string;
  headline: string;
  body?: string;
  steps: Array<{ title: string; body?: string }>;
  variant?: "horizontal" | "vertical";
}

const { eyebrow, headline, body, steps, variant = "horizontal" } = Astro.props;

if (!steps || steps.length === 0) {
  return null;
}

const formatStep = (index: number): string =>
  String(index + 1).padStart(2, "0");
---

<section class="container mx-auto px-4 py-12 sm:px-6 lg:px-8">
  <div class="max-w-2xl space-y-2">
    {eyebrow && (
      <p class="text-xs font-semibold uppercase tracking-wider text-slate-500">
        {eyebrow}
      </p>
    )}
    <h2 class="text-2xl font-bold text-slate-900">{headline}</h2>
    {body && <p class="text-sm text-slate-600">{body}</p>}
  </div>

  {variant === "vertical" ? (
    <ol class="mt-10 space-y-8">
      {steps.map((step, index) => {
        const isLast = index === steps.length - 1;
        return (
          <li class="relative pl-12">
            <div class="absolute left-3 top-0 h-full w-px bg-slate-200" aria-hidden="true" />
            <div class="absolute left-0 top-0 flex h-8 w-8 items-center justify-center rounded-full border border-slate-200 bg-white text-xs font-semibold text-slate-600">
              {formatStep(index)}
            </div>
            <div class="space-y-2">
              <h3 class="text-lg font-semibold text-slate-900">{step.title}</h3>
              {step.body && <p class="text-sm text-slate-600">{step.body}</p>}
            </div>
            {!isLast ? (
              <span class="pointer-events-none absolute left-3 bottom-0 -translate-x-1/2 translate-y-1/2 text-slate-400">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-4 w-4" aria-hidden="true">
                  <path d="M12 5v14M8 15l4 4 4-4" />
                </svg>
              </span>
            ) : null}
          </li>
        );
      })}
    </ol>
  ) : (
    <ol class="mt-10 grid gap-6 md:grid-cols-2 lg:grid-cols-3">
      {steps.map((step, index) => {
        const isLast = index === steps.length - 1;
        return (
          <li class="relative rounded-2xl border border-slate-200 bg-slate-50 p-6">
            <div class="space-y-3">
              <span class="text-xs font-semibold uppercase tracking-wider text-slate-500">
                {formatStep(index)}
              </span>
              <h3 class="text-lg font-semibold text-slate-900">{step.title}</h3>
              {step.body && <p class="text-sm text-slate-600">{step.body}</p>}
            </div>
            {!isLast ? (
              <>
                <span class="pointer-events-none absolute -right-4 top-1/2 hidden -translate-y-1/2 text-slate-400 lg:block">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-4 w-4" aria-hidden="true">
                    <path d="M5 12h14M13 6l6 6-6 6" />
                  </svg>
                </span>
                <span class="pointer-events-none mt-4 flex justify-center text-slate-400 lg:hidden">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-4 w-4" aria-hidden="true">
                    <path d="M12 5v14M8 15l4 4 4-4" />
                  </svg>
                </span>
              </>
            ) : null}
          </li>
        );
      })}
    </ol>
  )}
</section>
