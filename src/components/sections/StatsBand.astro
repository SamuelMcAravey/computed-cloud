---
export interface Props {
  eyebrow?: string;
  headline?: string;
  body?: string;
  stats: Array<{ label: string; value: string; sublabel?: string }>;
  variant?: "plain" | "cards";
}

const { eyebrow, headline, body, stats, variant = "cards" } = Astro.props;

if (!stats || stats.length === 0) {
  return null;
}
---

<section class="container mx-auto px-4 py-12 sm:px-6 lg:px-8">
  {(eyebrow || headline || body) && (
    <div class="max-w-2xl space-y-2">
      {eyebrow && (
        <p class="text-xs font-semibold uppercase tracking-wider text-slate-500">
          {eyebrow}
        </p>
      )}
      {headline && <h2 class="text-2xl font-bold text-slate-900">{headline}</h2>}
      {body && <p class="text-sm text-slate-600">{body}</p>}
    </div>
  )}
  <div
    class:list={[
      "mt-8 grid gap-6 md:grid-cols-2 lg:grid-cols-3",
      variant === "cards" ? "lg:gap-8" : "",
    ]}
  >
    {stats.map((stat) => (
      <div
        class:list={[
          variant === "cards"
            ? "rounded-2xl border border-slate-200 bg-slate-50 p-6"
            : "rounded-2xl border border-transparent p-2",
        ]}
      >
        <div class="space-y-2">
          <p class="text-3xl font-semibold text-slate-900">{stat.value}</p>
          <div class="space-y-1">
            <p class="text-sm font-semibold text-slate-700">{stat.label}</p>
            {stat.sublabel ? (
              <p class="text-xs text-slate-500">{stat.sublabel}</p>
            ) : null}
          </div>
        </div>
      </div>
    ))}
  </div>
</section>
