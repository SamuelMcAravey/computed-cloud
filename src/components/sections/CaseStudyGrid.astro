---
export interface Props {
  eyebrow?: string;
  headline: string;
  body?: string;
  items: Array<{
    title: string;
    summary: string;
    href?: string;
    image?: { src: string; alt: string };
    tags?: string[];
    metrics?: Array<{ label: string; value: string }>;
  }>;
  variant?: "cards" | "list";
}

const { eyebrow, headline, body, items, variant = "cards" } = Astro.props;

if (!items || items.length === 0) {
  return null;
}
---

<section class="container mx-auto px-4 py-12 sm:px-6 lg:px-8">
  <div class="max-w-2xl space-y-2">
    {eyebrow && (
      <p class="text-xs font-semibold uppercase tracking-wider text-slate-500">
        {eyebrow}
      </p>
    )}
    <h2 class="text-2xl font-bold text-slate-900">{headline}</h2>
    {body && <p class="text-sm text-slate-600">{body}</p>}
  </div>

  {variant === "list" ? (
    <div class="mt-10 space-y-6">
      {items.map((item) => {
        const Wrapper = item.href ? "a" : "div";
        return (
          <Wrapper
            href={item.href}
            class:list={[
              "block rounded-2xl border border-slate-200 bg-white p-6 transition-shadow",
              item.href
                ? "hover:shadow-md focus:outline-none focus:ring-2 focus:ring-blue-600 focus:ring-offset-2"
                : "",
            ]}
          >
            <div class="flex flex-col gap-6 md:flex-row md:items-center">
              {item.image ? (
                <img
                  src={item.image.src}
                  alt={item.image.alt}
                  class="h-36 w-full rounded-xl object-cover md:h-28 md:w-44"
                  loading="lazy"
                />
              ) : null}
              <div class="space-y-3">
                <h3 class="text-lg font-semibold text-slate-900">{item.title}</h3>
                <p class="text-sm text-slate-600">{item.summary}</p>
                {item.tags && item.tags.length > 0 ? (
                  <div class="flex flex-wrap gap-2 text-xs text-slate-500">
                    {item.tags.map((tag) => (
                      <span class="rounded-full border border-slate-200 px-2.5 py-1">
                        {tag}
                      </span>
                    ))}
                  </div>
                ) : null}
                {item.metrics && item.metrics.length > 0 ? (
                  <div class="flex flex-wrap gap-6 text-sm text-slate-600">
                    {item.metrics.slice(0, 3).map((metric) => (
                      <div>
                        <p class="font-semibold text-slate-900">{metric.value}</p>
                        <p class="text-xs text-slate-500">{metric.label}</p>
                      </div>
                    ))}
                  </div>
                ) : null}
              </div>
            </div>
          </Wrapper>
        );
      })}
    </div>
  ) : (
    <div class="mt-10 grid gap-6 md:grid-cols-2 lg:grid-cols-3">
      {items.map((item) => {
        const Wrapper = item.href ? "a" : "div";
        return (
          <Wrapper
            href={item.href}
            class:list={[
              "flex h-full flex-col rounded-2xl border border-slate-200 bg-white p-6 transition-shadow",
              item.href
                ? "hover:shadow-md focus:outline-none focus:ring-2 focus:ring-blue-600 focus:ring-offset-2"
                : "",
            ]}
          >
            {item.image ? (
              <img
                src={item.image.src}
                alt={item.image.alt}
                class="mb-4 h-40 w-full rounded-xl object-cover"
                loading="lazy"
              />
            ) : null}
            <div class="space-y-3">
              <h3 class="text-lg font-semibold text-slate-900">{item.title}</h3>
              <p class="text-sm text-slate-600">{item.summary}</p>
              {item.tags && item.tags.length > 0 ? (
                <div class="flex flex-wrap gap-2 text-xs text-slate-500">
                  {item.tags.map((tag) => (
                    <span class="rounded-full border border-slate-200 px-2.5 py-1">
                      {tag}
                    </span>
                  ))}
                </div>
              ) : null}
            </div>
            {item.metrics && item.metrics.length > 0 ? (
              <div class="mt-4 flex flex-wrap gap-6 text-sm text-slate-600">
                {item.metrics.slice(0, 3).map((metric) => (
                  <div>
                    <p class="font-semibold text-slate-900">{metric.value}</p>
                    <p class="text-xs text-slate-500">{metric.label}</p>
                  </div>
                ))}
              </div>
            ) : null}
          </Wrapper>
        );
      })}
    </div>
  )}
</section>
