---
import { Linkedin, Twitter, Facebook, Instagram, Youtube } from "lucide-react";

export interface Props {
  eyebrow?: string;
  headline: string;
  body?: string;
  members: Array<{
    name: string;
    role?: string;
    bio?: string;
    image?: { src: string; alt: string };
    social?: {
      linkedin?: string;
      x?: string;
      facebook?: string;
      instagram?: string;
      youtube?: string;
    };
  }>;
  variant?: "compact" | "detailed";
}

const { eyebrow, headline, body, members, variant = "compact" } = Astro.props;

if (!members || members.length === 0) {
  return null;
}

const socialIcons = {
  linkedin: { label: "LinkedIn", Icon: Linkedin },
  x: { label: "X", Icon: Twitter },
  facebook: { label: "Facebook", Icon: Facebook },
  instagram: { label: "Instagram", Icon: Instagram },
  youtube: { label: "YouTube", Icon: Youtube },
} as const;
---

<section class="container mx-auto px-4 py-12 sm:px-6 lg:px-8">
  <div class="max-w-2xl space-y-2">
    {eyebrow && (
      <p class="text-xs font-semibold uppercase tracking-wider text-slate-500">
        {eyebrow}
      </p>
    )}
    <h2 class="text-2xl font-bold text-slate-900">{headline}</h2>
    {body && <p class="text-sm text-slate-600">{body}</p>}
  </div>

  <div class="mt-10 grid gap-6 md:grid-cols-2 lg:grid-cols-3">
    {members.map((member) => {
      const socialLinks = Object.entries(socialIcons)
        .map(([key, config]) => ({
          key,
          href: member.social?.[key as keyof typeof socialIcons],
          ...config,
        }))
        .filter((item) => item.href);

      return (
        <div class="flex h-full flex-col rounded-2xl border border-slate-200 bg-white p-6">
          {member.image ? (
            <img
              src={member.image.src}
              alt={member.image.alt}
              class="h-32 w-32 rounded-xl object-cover"
              loading="lazy"
            />
          ) : (
            <div class="h-32 w-32 rounded-xl bg-slate-100" aria-hidden="true" />
          )}
          <div class="mt-4 space-y-2">
            <h3 class="text-lg font-semibold text-slate-900">{member.name}</h3>
            {member.role && (
              <p class="text-sm text-slate-600">{member.role}</p>
            )}
            {variant === "detailed" && member.bio && (
              <p class="text-sm text-slate-600">{member.bio}</p>
            )}
          </div>
          {socialLinks.length > 0 && (
            <div class="mt-4 flex flex-wrap gap-2">
              {socialLinks.map((item) => (
                <a
                  href={item.href}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="inline-flex h-9 w-9 items-center justify-center rounded-lg border border-slate-200 text-slate-500 transition-colors hover:bg-blue-50 hover:text-blue-600 focus:outline-none focus:ring-2 focus:ring-blue-600 focus:ring-offset-2"
                  aria-label={`${member.name} on ${item.label}`}
                >
                  <item.Icon className="h-4 w-4" />
                </a>
              ))}
            </div>
          )}
        </div>
      );
    })}
  </div>
</section>
