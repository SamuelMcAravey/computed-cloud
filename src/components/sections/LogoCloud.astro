---
export interface Props {
  headline?: string;
  body?: string;
  logos: Array<{ src: string; alt: string; href?: string }>;
  variant?: "strip" | "grid";
  columns?: 2 | 3 | 4 | 5 | 6;
  tone?: "plain" | "muted";
}

const {
  headline,
  body,
  logos,
  variant = "grid",
  columns = 4,
  tone = "muted",
} = Astro.props;

if (!logos || logos.length === 0) {
  return null;
}

const toneClasses = {
  plain: "",
  muted: "bg-slate-50",
} as const;

const gridColumns = {
  2: "grid-cols-2 sm:grid-cols-2 lg:grid-cols-2",
  3: "grid-cols-2 sm:grid-cols-3 lg:grid-cols-3",
  4: "grid-cols-2 sm:grid-cols-3 lg:grid-cols-4",
  5: "grid-cols-2 sm:grid-cols-3 lg:grid-cols-5",
  6: "grid-cols-2 sm:grid-cols-3 lg:grid-cols-6",
} as const;
---

<section class:list={["py-12", toneClasses[tone]]}>
  <div class="container mx-auto px-4 sm:px-6 lg:px-8">
    {(headline || body) && (
      <div class="max-w-2xl space-y-2">
        {headline && <h2 class="text-2xl font-bold text-slate-900">{headline}</h2>}
        {body && <p class="text-sm text-slate-600">{body}</p>}
      </div>
    )}
    <div
      class:list={[
        headline || body ? "mt-8" : "",
        "rounded-2xl border border-slate-200 bg-white p-6",
      ]}
    >
      {variant === "strip" ? (
        <div class="flex flex-wrap items-center justify-center gap-x-10 gap-y-6">
          {logos.map((logo) =>
            logo.href ? (
              <a
                href={logo.href}
                target="_blank"
                rel="noopener noreferrer"
                class="flex items-center justify-center rounded-lg border border-slate-200 bg-white px-4 py-3 transition-opacity hover:opacity-80 focus:outline-none focus:ring-2 focus:ring-blue-600 focus:ring-offset-2"
              >
                <img
                  src={logo.src}
                  alt={logo.alt}
                  class="h-10 w-auto object-contain sm:h-12"
                  loading="lazy"
                />
              </a>
            ) : (
              <div class="flex items-center justify-center rounded-lg border border-slate-200 bg-white px-4 py-3">
                <img
                  src={logo.src}
                  alt={logo.alt}
                  class="h-10 w-auto object-contain sm:h-12"
                  loading="lazy"
                />
              </div>
            )
          )}
        </div>
      ) : (
        <div class:list={["grid gap-6", gridColumns[columns]]}>
          {logos.map((logo) =>
            logo.href ? (
              <a
                href={logo.href}
                target="_blank"
                rel="noopener noreferrer"
                class="flex items-center justify-center rounded-xl border border-slate-200 bg-white px-4 py-5 transition-opacity hover:opacity-80 focus:outline-none focus:ring-2 focus:ring-blue-600 focus:ring-offset-2"
              >
                <img
                  src={logo.src}
                  alt={logo.alt}
                  class="h-10 w-auto object-contain sm:h-12"
                  loading="lazy"
                />
              </a>
            ) : (
              <div class="flex items-center justify-center rounded-xl border border-slate-200 bg-white px-4 py-5">
                <img
                  src={logo.src}
                  alt={logo.alt}
                  class="h-10 w-auto object-contain sm:h-12"
                  loading="lazy"
                />
              </div>
            )
          )}
        </div>
      )}
    </div>
  </div>
</section>
