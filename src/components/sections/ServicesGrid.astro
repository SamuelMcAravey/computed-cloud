---
import {
  ArrowDownToLine,
  Eye,
  FileText,
  Layers,
  ScanLine,
  ShieldCheck,
} from "lucide-react";

export interface Props {
  headline?: string;
  body?: string;
  items: Array<{
    title: string;
    description: string;
    href?: string;
    icon?: { src: string; alt: string };
    iconName?: string;
  }>;
  variant?: "cards" | "minimal";
  columns?: 2 | 3 | 4;
}

const {
  headline,
  body,
  items,
  variant = "cards",
  columns = 3,
} = Astro.props;

if (!items || items.length === 0) {
  return null;
}

const gridColumns = {
  2: "md:grid-cols-2",
  3: "md:grid-cols-2 lg:grid-cols-3",
  4: "md:grid-cols-2 lg:grid-cols-4",
} as const;

const iconMap: Record<string, any> = {
  fileText: FileText,
  scanLine: ScanLine,
  layers: Layers,
  eye: Eye,
  shieldCheck: ShieldCheck,
  arrowDownToLine: ArrowDownToLine,
};
---

<section class="container mx-auto px-4 py-12 sm:px-6 lg:px-8">
  {(headline || body) && (
    <div class="max-w-2xl space-y-2">
      {headline && <h2 class="text-2xl font-bold text-slate-900">{headline}</h2>}
      {body && <p class="text-sm text-slate-600">{body}</p>}
    </div>
  )}
  <div
    class:list={[
      "mt-8 grid gap-6",
      gridColumns[columns],
      variant === "minimal" ? "gap-y-8" : "",
    ]}
  >
    {items.map((item) => {
      const WrapperTag = item.href ? "a" : "div";
      const IconComponent = item.iconName ? iconMap[item.iconName] : null;
      return (
        <WrapperTag
          href={item.href}
          class:list={[
            variant === "cards"
              ? "group flex h-full flex-col rounded-2xl border border-slate-200 bg-white p-6 transition-shadow hover:shadow-md focus:outline-none focus:ring-2 focus:ring-blue-600 focus:ring-offset-2"
              : "flex h-full flex-col rounded-xl border border-transparent p-2",
            item.href ? "cursor-pointer" : "",
          ]}
        >
          {IconComponent || item.icon ? (
            <div class="mb-4 flex h-10 w-10 items-center justify-center rounded-lg border border-slate-200 bg-slate-50 text-blue-600">
              {IconComponent ? (
                <IconComponent className="h-5 w-5" aria-hidden="true" />
              ) : (
                <img
                  src={item.icon.src}
                  alt={item.icon.alt}
                  class="h-5 w-5 object-contain"
                  loading="lazy"
                />
              )}
            </div>
          ) : null}
          <h3 class="text-lg font-semibold text-slate-900">{item.title}</h3>
          <p class:list={["mt-2 text-sm text-slate-600", variant === "minimal" ? "max-w-sm" : ""]}>
            {item.description}
          </p>
        </WrapperTag>
      );
    })}
  </div>
</section>
