---
interface Props {
  eyebrow?: string;
  headline: string;
  body: string[];
  image: { src: string; alt: string };
  imageSide?: "left" | "right";
  bullets?: string[];
}

const { eyebrow, headline, body, image, imageSide = "right", bullets } = Astro.props;
const isImageLeft = imageSide === "left";
---

<section class="container mx-auto px-4 py-12 sm:px-6 lg:px-8">
  <div class="grid items-center gap-10 lg:grid-cols-2">
    <div class={isImageLeft ? "lg:order-2" : ""}>
      {eyebrow && (
        <p class="text-sm font-semibold uppercase tracking-wider text-slate-500">
          {eyebrow}
        </p>
      )}
      <h2 class="mt-3 text-3xl font-bold text-slate-900 sm:text-4xl">{headline}</h2>
      <div class="mt-4 space-y-4 text-sm text-slate-600">
        {body.map((paragraph) => (
          <p>{paragraph}</p>
        ))}
      </div>
      {bullets && bullets.length > 0 && (
        <ul class="mt-6 space-y-2 text-sm text-slate-600">
          {bullets.map((bullet) => (
            <li class="flex gap-2">
              <span class="mt-1 h-1.5 w-1.5 rounded-full bg-blue-600"></span>
              <span>{bullet}</span>
            </li>
          ))}
        </ul>
      )}
    </div>
    <div class={isImageLeft ? "lg:order-1" : ""}>
      <div class="rounded-2xl border border-slate-200 bg-slate-50 p-4">
        <img
          src={image.src}
          alt={image.alt}
          class="h-full w-full rounded-xl object-cover"
          loading="lazy"
        />
      </div>
    </div>
  </div>
</section>
