---
export interface Props {
  eyebrow?: string;
  headline: string;
  body?: string;
  items: Array<{ date?: string; title: string; body?: string }>;
  variant?: "vertical" | "horizontal";
}

const { eyebrow, headline, body, items, variant = "vertical" } = Astro.props;

if (!items || items.length === 0) {
  return null;
}
---

<section class="container mx-auto px-4 py-12 sm:px-6 lg:px-8">
  <div class="max-w-2xl space-y-2">
    {eyebrow && (
      <p class="text-xs font-semibold uppercase tracking-wider text-slate-500">
        {eyebrow}
      </p>
    )}
    <h2 class="text-2xl font-bold text-slate-900">{headline}</h2>
    {body && <p class="text-sm text-slate-600">{body}</p>}
  </div>

  {variant === "horizontal" ? (
    <div class="mt-10 overflow-x-auto">
      <div class="flex gap-6">
        {items.map((item) => (
          <div class="min-w-[220px] rounded-2xl border border-slate-200 bg-white p-6">
            {item.date && (
              <p class="text-xs font-semibold uppercase tracking-wider text-slate-500">
                {item.date}
              </p>
            )}
            <h3 class="mt-2 text-lg font-semibold text-slate-900">{item.title}</h3>
            {item.body && <p class="mt-2 text-sm text-slate-600">{item.body}</p>}
          </div>
        ))}
      </div>
    </div>
  ) : (
    <div class="mt-10 space-y-8 border-l border-slate-200 pl-6">
      {items.map((item) => (
        <div class="relative">
          <span class="absolute -left-[13px] top-2 h-3 w-3 rounded-full bg-blue-600"></span>
          {item.date && (
            <p class="text-xs font-semibold uppercase tracking-wider text-slate-500">
              {item.date}
            </p>
          )}
          <h3 class="mt-2 text-lg font-semibold text-slate-900">{item.title}</h3>
          {item.body && <p class="mt-2 text-sm text-slate-600">{item.body}</p>}
        </div>
      ))}
    </div>
  )}
</section>
