---
export interface Props {
  headline: string;
  subheadline?: string;
  primaryCta: { label: string; href: string };
  secondaryCta?: { label: string; href: string };
  image?: { src: string; alt: string };
  variant?: "simple" | "centered" | "background";
  background?: { src: string; alt: string; overlay?: "none" | "light" | "dark" };
}

const {
  headline,
  subheadline,
  primaryCta,
  secondaryCta,
  image,
  variant = "simple",
  background,
} = Astro.props;

const hasSecondary = Boolean(secondaryCta);
const overlayTone = background?.overlay ?? "light";

const overlayClasses = {
  none: "",
  light: "bg-white/70",
  dark: "bg-slate-900/65",
} as const;

const textClasses = {
  light: "text-slate-900",
  dark: "text-white",
} as const;

const subheadClasses = {
  light: "text-slate-600",
  dark: "text-slate-200",
} as const;

const backgroundTextTone = overlayTone === "dark" ? "dark" : "light";
const secondaryCtaClasses =
  variant === "background" && backgroundTextTone === "dark"
    ? "text-white border-white/60 hover:border-white hover:bg-white/10"
    : "text-slate-700 border-slate-200 hover:border-slate-300 hover:bg-slate-100 hover:text-slate-900";
---

{variant === "background" ? (
  <section class="container mx-auto px-4 py-12 sm:px-6 lg:px-8">
    <div class="relative overflow-hidden rounded-2xl border border-slate-200">
      {background?.src ? (
        <img
          src={background.src}
          alt={background.alt}
          class="absolute inset-0 h-full w-full object-cover"
          loading="lazy"
        />
      ) : (
        <div class="absolute inset-0 bg-gradient-to-br from-slate-50 to-slate-100" />
      )}
      {overlayTone !== "none" ? (
        <div class:list={["absolute inset-0", overlayClasses[overlayTone]]} />
      ) : null}
      <div class="relative z-10 px-6 py-12 sm:px-10 sm:py-12">
        <div class="max-w-3xl space-y-6">
          <h1
            class:list={[
              "text-4xl font-bold sm:text-5xl",
              textClasses[backgroundTextTone],
            ]}
          >
            {headline}
          </h1>
          {subheadline ? (
            <p class:list={["text-lg", subheadClasses[backgroundTextTone]]}>
              {subheadline}
            </p>
          ) : null}
          <div class="flex flex-wrap gap-4">
            <a
              href={primaryCta.href}
              class="inline-flex items-center px-6 py-3 text-sm font-semibold text-white bg-blue-600 rounded-lg shadow hover:bg-blue-700 transition-colors"
            >
              {primaryCta.label}
            </a>
            {hasSecondary ? (
              <a
                href={secondaryCta.href}
                class:list={[
                  "inline-flex items-center px-6 py-3 text-sm font-semibold border rounded-lg transition-colors",
                  secondaryCtaClasses,
                ]}
              >
                {secondaryCta.label}
              </a>
            ) : null}
          </div>
        </div>
      </div>
    </div>
  </section>
) : variant === "centered" ? (
  <section class="container mx-auto px-4 py-12 sm:px-6 lg:px-8">
    <div class="flex flex-col items-center text-center">
      <div class="max-w-3xl space-y-6">
        <h1 class="text-4xl font-bold text-slate-900 sm:text-5xl">{headline}</h1>
        {subheadline ? (
          <p class="text-lg text-slate-600">{subheadline}</p>
        ) : null}
        <div class="flex flex-wrap justify-center gap-4">
          <a
            href={primaryCta.href}
            class="inline-flex items-center px-6 py-3 text-sm font-semibold text-white bg-blue-600 rounded-lg shadow hover:bg-blue-700 transition-colors"
          >
            {primaryCta.label}
          </a>
          {hasSecondary ? (
            <a
              href={secondaryCta.href}
              class="inline-flex items-center px-6 py-3 text-sm font-semibold text-slate-700 border border-slate-200 rounded-lg hover:border-slate-300 hover:bg-slate-100 hover:text-slate-900 transition-colors"
            >
              {secondaryCta.label}
            </a>
          ) : null}
        </div>
      </div>
      {image ? (
        <div class="mt-10 w-full max-w-4xl rounded-2xl border border-slate-200 bg-slate-50 p-4">
          <img
            src={image.src}
            alt={image.alt}
            class="h-full w-full rounded-xl object-cover"
            loading="lazy"
          />
        </div>
      ) : null}
    </div>
  </section>
) : (
  <section class="container mx-auto px-4 py-12 sm:px-6 lg:px-8">
    <div class="grid items-center gap-10 lg:grid-cols-2">
      <div class="space-y-6">
        <h1 class="text-4xl font-bold text-slate-900 sm:text-5xl">{headline}</h1>
        {subheadline ? <p class="text-lg text-slate-600">{subheadline}</p> : null}
        <div class="flex flex-wrap gap-4">
          <a
            href={primaryCta.href}
            class="inline-flex items-center px-6 py-3 text-sm font-semibold text-white bg-blue-600 rounded-lg shadow hover:bg-blue-700 transition-colors"
          >
            {primaryCta.label}
          </a>
          {hasSecondary ? (
            <a
              href={secondaryCta.href}
              class="inline-flex items-center px-6 py-3 text-sm font-semibold text-slate-700 border border-slate-200 rounded-lg hover:border-slate-300 hover:bg-slate-100 hover:text-slate-900 transition-colors"
            >
              {secondaryCta.label}
            </a>
          ) : null}
        </div>
      </div>
      {image ? (
        <div class="rounded-2xl border border-slate-200 bg-slate-50 p-4">
          <img
            src={image.src}
            alt={image.alt}
            class="h-full w-full rounded-xl object-cover"
            loading="lazy"
          />
        </div>
      ) : null}
    </div>
  </section>
)}
