---
export interface Props {
  eyebrow?: string;
  headline: string;
  body?: string;
  locations: string[];
  variant?: "columns" | "pills";
  columns?: 2 | 3;
  note?: string;
}

const {
  eyebrow,
  headline,
  body,
  locations,
  variant = "columns",
  columns = 3,
  note,
} = Astro.props;

if (!locations || locations.length === 0) {
  return null;
}

const columnClasses = {
  2: "md:columns-2",
  3: "md:columns-3",
} as const;
---

<section class="container mx-auto px-4 py-12 sm:px-6 lg:px-8">
  <div class="max-w-2xl space-y-2">
    {eyebrow && (
      <p class="text-xs font-semibold uppercase tracking-wider text-slate-500">
        {eyebrow}
      </p>
    )}
    <h2 class="text-2xl font-bold text-slate-900">{headline}</h2>
    {body && <p class="text-sm text-slate-600">{body}</p>}
  </div>

  {variant === "pills" ? (
    <div class="mt-8 flex flex-wrap gap-3">
      {locations.map((location) => (
        <span class="rounded-full border border-slate-200 bg-white px-3 py-1.5 text-sm text-slate-600">
          {location}
        </span>
      ))}
    </div>
  ) : (
    <ul class:list={["mt-8 space-y-2 text-sm text-slate-600", columnClasses[columns]]}>
      {locations.map((location) => (
        <li class="break-inside-avoid list-disc pl-4">{location}</li>
      ))}
    </ul>
  )}

  {note && <p class="mt-4 text-xs text-slate-500">{note}</p>}
</section>
