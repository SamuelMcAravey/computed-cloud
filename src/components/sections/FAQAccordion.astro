---
export interface Props {
  eyebrow?: string;
  headline: string;
  body?: string;
  items: Array<{ question: string; answer: string | string[] }>;
  openFirst?: boolean;
}

const { eyebrow, headline, body, items, openFirst = false } = Astro.props;

if (!items || items.length === 0) {
  return null;
}
---

<section class="container mx-auto px-4 py-12 sm:px-6 lg:px-8">
  <div class="max-w-2xl space-y-2">
    {eyebrow && (
      <p class="text-xs font-semibold uppercase tracking-wider text-slate-500">
        {eyebrow}
      </p>
    )}
    <h2 class="text-2xl font-bold text-slate-900">{headline}</h2>
    {body && <p class="text-sm text-slate-600">{body}</p>}
  </div>

  <div class="mt-8 space-y-4">
    {items.map((item, index) => {
      const paragraphs = Array.isArray(item.answer)
        ? item.answer
        : [item.answer];
      return (
        <details
          class="rounded-2xl border border-slate-200 bg-white p-5"
          open={openFirst && index === 0}
        >
          <summary class="flex cursor-pointer items-center justify-between gap-4 text-left text-sm font-semibold text-slate-900 focus:outline-none focus:ring-2 focus:ring-blue-600 focus:ring-offset-2">
            <span>{item.question}</span>
            <span class="text-slate-400">+</span>
          </summary>
          <div class="mt-3 space-y-2 text-sm text-slate-600">
            {paragraphs.map((paragraph) => (
              <p>{paragraph}</p>
            ))}
          </div>
        </details>
      );
    })}
  </div>
</section>
