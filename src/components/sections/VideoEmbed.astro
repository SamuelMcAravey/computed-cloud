---
export interface Props {
  headline?: string;
  body?: string;
  title: string;
  provider: "youtube" | "vimeo";
  videoId: string;
  variant?: "embed" | "thumbnail";
  thumbnail?: { src: string; alt: string };
  aspect?: "16/9" | "4/3" | "1/1";
}

const {
  headline,
  body,
  title,
  provider,
  videoId,
  variant = "embed",
  thumbnail,
  aspect = "16/9",
} = Astro.props;

const embedUrl =
  provider === "youtube"
    ? `https://www.youtube-nocookie.com/embed/${videoId}`
    : `https://player.vimeo.com/video/${videoId}`;

const watchUrl =
  provider === "youtube"
    ? `https://www.youtube.com/watch?v=${videoId}`
    : `https://vimeo.com/${videoId}`;

const aspectClasses = {
  "16/9": "aspect-[16/9]",
  "4/3": "aspect-[4/3]",
  "1/1": "aspect-square",
} as const;

if (variant === "thumbnail" && !thumbnail) {
  throw new Error("VideoEmbed requires a thumbnail when variant is 'thumbnail'.");
}
---

<section class="container mx-auto px-4 py-12 sm:px-6 lg:px-8">
  {(headline || body) && (
    <div class="max-w-2xl space-y-2">
      {headline && <h2 class="text-2xl font-bold text-slate-900">{headline}</h2>}
      {body && <p class="text-sm text-slate-600">{body}</p>}
    </div>
  )}

  <div class="mt-8">
    {variant === "thumbnail" && thumbnail ? (
      <div class="js-video-embed relative overflow-hidden rounded-2xl border border-slate-200 bg-slate-900">
        <button
          type="button"
          class="group relative block w-full focus:outline-none focus:ring-2 focus:ring-blue-600 focus:ring-offset-2"
          data-embed-src={embedUrl}
        >
          <img
            src={thumbnail.src}
            alt={thumbnail.alt}
            class:list={[
              "h-full w-full object-cover",
              aspectClasses[aspect],
            ]}
            loading="lazy"
          />
          <span class="absolute inset-0 flex items-center justify-center">
            <span class="flex h-14 w-14 items-center justify-center rounded-full bg-white/90 text-slate-900 shadow-lg transition-transform group-hover:scale-105">
              ▶
            </span>
          </span>
        </button>
        <noscript>
          <div class="p-4 text-sm text-white">
            <a
              href={watchUrl}
              class="underline decoration-white/60 underline-offset-4"
            >
              Watch the video
            </a>
          </div>
        </noscript>
      </div>
    ) : (
      <div class:list={["overflow-hidden rounded-2xl border border-slate-200 bg-black", aspectClasses[aspect]]}>
        <iframe
          src={embedUrl}
          title={title}
          class="h-full w-full"
          loading="lazy"
          allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
          allowfullscreen
        />
      </div>
    )}
  </div>

  {variant === "thumbnail" ? (
    <script>
      {String.raw`
        (() => {
          const container = document.querySelector('.js-video-embed');
          if (!container) return;
          const button = container.querySelector('button');
          if (!button) return;
          const embedSrc = button.getAttribute('data-embed-src');
          if (!embedSrc) return;

          button.addEventListener('click', () => {
            const iframe = document.createElement('iframe');
            iframe.src = embedSrc;
            iframe.title = ${JSON.stringify(title)};
            iframe.className = 'h-full w-full';
            iframe.loading = 'lazy';
            iframe.allow = 'accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share';
            iframe.setAttribute('allowfullscreen', '');
            button.replaceWith(iframe);
          }, { once: true });
        })();
      `}
    </script>
  ) : null}
</section>
