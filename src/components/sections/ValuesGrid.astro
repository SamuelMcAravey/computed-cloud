---
export interface Props {
  eyebrow?: string;
  headline: string;
  body?: string;
  items: Array<{
    title: string;
    description: string;
    icon?: { src: string; alt: string };
  }>;
  columns?: 2 | 3 | 4;
  variant?: "cards" | "plain";
}

const {
  eyebrow,
  headline,
  body,
  items,
  columns = 3,
  variant = "cards",
} = Astro.props;

if (!items || items.length === 0) {
  return null;
}

const gridColumns = {
  2: "md:grid-cols-2",
  3: "md:grid-cols-2 lg:grid-cols-3",
  4: "md:grid-cols-2 lg:grid-cols-4",
} as const;
---

<section class="container mx-auto px-4 py-12 sm:px-6 lg:px-8">
  <div class="max-w-2xl space-y-2">
    {eyebrow && (
      <p class="text-xs font-semibold uppercase tracking-wider text-slate-500">
        {eyebrow}
      </p>
    )}
    <h2 class="text-2xl font-bold text-slate-900">{headline}</h2>
    {body && <p class="text-sm text-slate-600">{body}</p>}
  </div>

  <div class:list={["mt-10 grid gap-6", gridColumns[columns]]}>
    {items.map((item) => (
      <div
        class:list={[
          "flex h-full flex-col",
          variant === "cards"
            ? "rounded-2xl border border-slate-200 bg-white p-6"
            : "rounded-xl border border-transparent p-2",
        ]}
      >
        {item.icon ? (
          <div class="mb-4 flex h-10 w-10 items-center justify-center rounded-lg border border-slate-200 bg-slate-50">
            <img
              src={item.icon.src}
              alt={item.icon.alt}
              class="h-5 w-5 object-contain"
              loading="lazy"
            />
          </div>
        ) : null}
        <h3 class="text-lg font-semibold text-slate-900">{item.title}</h3>
        <p class="mt-2 text-sm text-slate-600">{item.description}</p>
      </div>
    ))}
  </div>
</section>
