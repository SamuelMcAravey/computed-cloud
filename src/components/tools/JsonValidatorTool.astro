<div class="space-y-3" data-tool="json-validate">
  <div class="space-y-2">
    <label class="text-xs uppercase tracking-wide text-muted" for="json-validate-input">JSON</label>
    <textarea
      id="json-validate-input"
      class="min-h-[140px] w-full rounded-lg border border-border bg-bg px-3 py-2 text-sm text-text"
      placeholder='{"key":"value"}'
    ></textarea>
  </div>
  <p class="text-sm" data-result></p>
  <script is:inline>
    (() => {
      const root = document.querySelector('[data-tool="json-validate"]');
    if (root) {
      const input = root.querySelector("#json-validate-input");
      const result = root.querySelector("[data-result]");
      const update = () => {
        if (!input || !result) return;
        const raw = input.value.trim();
        if (!raw) {
          result.textContent = "";
          result.className = "text-sm";
          return;
        }
        try {
          JSON.parse(input.value);
          result.textContent = "Valid JSON.";
          result.className = "text-sm text-accent";
        } catch (err) {
          result.textContent = "Invalid JSON.";
          result.className = "text-sm text-red-500";
        }
      };
      let raf = 0;
      const scheduleUpdate = () => {
        cancelAnimationFrame(raf);
        raf = requestAnimationFrame(update);
      };
      input?.addEventListener("input", scheduleUpdate);
      scheduleUpdate();
    }
    })();
  </script>
</div>






