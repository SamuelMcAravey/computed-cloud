<div class="space-y-3" data-tool="hmac">
  <div class="grid gap-3 md:grid-cols-2">
    <div class="space-y-2">
      <label class="text-xs uppercase tracking-wide text-muted" for="hmac-key">Key</label>
      <input
        id="hmac-key"
        class="w-full rounded-lg border border-border bg-bg px-3 py-2 text-sm text-text"
        type="text"
        placeholder="Secret key"
      />
    </div>
    <div class="space-y-2">
      <label class="text-xs uppercase tracking-wide text-muted" for="hmac-algo">Algorithm</label>
      <select
        id="hmac-algo"
        class="w-full rounded-lg border border-border bg-bg px-3 py-2 text-sm text-text"
      >
        <option value="SHA-256">SHA-256</option>
        <option value="SHA-1">SHA-1</option>
      </select>
    </div>
  </div>
  <div class="space-y-2">
    <label class="text-xs uppercase tracking-wide text-muted" for="hmac-message">Message</label>
    <textarea
      id="hmac-message"
      class="min-h-[120px] w-full rounded-lg border border-border bg-bg px-3 py-2 text-sm text-text"
      placeholder="Message to sign"
    ></textarea>
  </div>
  <button
    class="rounded-lg border border-border px-3 py-2 text-sm font-medium text-text hover:border-primary"
    type="button"
    data-run
  >
    Generate HMAC
  </button>
  <div class="space-y-2">
    <label class="text-xs uppercase tracking-wide text-muted" for="hmac-output">Output (hex)</label>
    <textarea
      id="hmac-output"
      class="min-h-[100px] w-full rounded-lg border border-border bg-bg px-3 py-2 text-sm text-text"
      readonly
    ></textarea>
  </div>
  <p class="text-xs text-muted" data-error></p>
  <script is:inline>
    (() => {
      const root = document.querySelector('[data-tool="hmac"]');
    if (root) {
      const keyInput = root.querySelector("#hmac-key");
      const algoSelect = root.querySelector("#hmac-algo");
      const msgInput = root.querySelector("#hmac-message");
      const output = root.querySelector("#hmac-output");
      const run = root.querySelector("[data-run]");
      const error = root.querySelector("[data-error]");
      const toHex = (buffer) =>
        Array.from(new Uint8Array(buffer))
          .map((b) => b.toString(16).padStart(2, "0"))
          .join("");
      run?.addEventListener("click", async () => {
        if (!keyInput || !msgInput || !output || !algoSelect || !error) return;
        try {
          const keyData = new TextEncoder().encode(keyInput.value);
          const msgData = new TextEncoder().encode(msgInput.value);
          const key = await crypto.subtle.importKey(
            "raw",
            keyData,
            { name: "HMAC", hash: { name: algoSelect.value } },
            false,
            ["sign"]
          );
          const signature = await crypto.subtle.sign("HMAC", key, msgData);
          output.value = toHex(signature);
          error.textContent = "";
        } catch {
          output.value = "";
          error.textContent = "Unable to generate HMAC.";
        }
      });
    }
    })();
  </script>
</div>






