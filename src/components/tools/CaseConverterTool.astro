<div class="space-y-3" data-tool="case-convert">
  <div class="space-y-2">
    <label class="text-xs uppercase tracking-wide text-muted" for="case-input">Text</label>
    <textarea
      id="case-input"
      class="min-h-[100px] w-full rounded-lg border border-border bg-bg px-3 py-2 text-sm text-text"
      placeholder="Text to convert"
    ></textarea>
  </div>
  <button
    class="rounded-lg border border-border px-3 py-2 text-sm font-medium text-text hover:border-primary"
    type="button"
    data-run
  >
    Convert
  </button>
  <div class="space-y-2">
    <label class="text-xs uppercase tracking-wide text-muted" for="case-camel">camelCase</label>
    <input id="case-camel" class="w-full rounded-lg border border-border bg-bg px-3 py-2 text-sm text-text" type="text" readonly />
  </div>
  <div class="space-y-2">
    <label class="text-xs uppercase tracking-wide text-muted" for="case-pascal">PascalCase</label>
    <input id="case-pascal" class="w-full rounded-lg border border-border bg-bg px-3 py-2 text-sm text-text" type="text" readonly />
  </div>
  <div class="space-y-2">
    <label class="text-xs uppercase tracking-wide text-muted" for="case-snake">snake_case</label>
    <input id="case-snake" class="w-full rounded-lg border border-border bg-bg px-3 py-2 text-sm text-text" type="text" readonly />
  </div>
  <div class="space-y-2">
    <label class="text-xs uppercase tracking-wide text-muted" for="case-kebab">kebab-case</label>
    <input id="case-kebab" class="w-full rounded-lg border border-border bg-bg px-3 py-2 text-sm text-text" type="text" readonly />
  </div>
  <script is:inline>
    (() => {
      const root = document.querySelector('[data-tool="case-convert"]');
    if (root) {
      const input = root.querySelector("#case-input");
      const camel = root.querySelector("#case-camel");
      const pascal = root.querySelector("#case-pascal");
      const snake = root.querySelector("#case-snake");
      const kebab = root.querySelector("#case-kebab");
      const run = root.querySelector("[data-run]");
      const splitWords = (value) =>
        value
          .replace(/([a-z0-9])([A-Z])/g, "$1 $2")
          .replace(/[_\-]+/g, " ")
          .trim()
          .split(/\s+/)
          .filter(Boolean);
      const toCamel = (words) =>
        words
          .map((word, index) =>
            index === 0
              ? word.toLowerCase()
              : word.charAt(0).toUpperCase() + word.slice(1).toLowerCase()
          )
          .join("");
      const toPascal = (words) =>
        words
          .map((word) => word.charAt(0).toUpperCase() + word.slice(1).toLowerCase())
          .join("");
      const toSnake = (words) => words.map((word) => word.toLowerCase()).join("_");
      const toKebab = (words) => words.map((word) => word.toLowerCase()).join("-");
      run?.addEventListener("click", () => {
        if (!input || !camel || !pascal || !snake || !kebab) return;
        const words = splitWords(input.value);
        camel.value = toCamel(words);
        pascal.value = toPascal(words);
        snake.value = toSnake(words);
        kebab.value = toKebab(words);
      });
    }
    })();
  </script>
</div>






