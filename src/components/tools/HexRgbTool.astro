<div class="space-y-3" data-tool="hex-rgb">
  <div class="grid gap-3 md:grid-cols-2">
    <div class="space-y-2">
      <div class="flex items-center justify-between gap-2">
        <label class="text-xs uppercase tracking-wide text-muted" for="hex-input">Hex</label>
        <button
          class="cc-tool-button rounded-lg border border-border px-2 py-1 text-xs text-muted hover:border-primary hover:text-text"
          type="button"
          data-copy-target="#hex-input"
        >
          Copy
        </button>
      </div>
      <input
        id="hex-input"
        class="w-full rounded-lg border border-border bg-bg px-3 py-2 text-sm text-text"
        type="text"
        placeholder="#0ea5e9"
      />
    </div>
    <div class="space-y-2">
      <div class="flex items-center justify-between gap-2">
        <label class="text-xs uppercase tracking-wide text-muted" for="rgb-input">RGB</label>
        <button
          class="cc-tool-button rounded-lg border border-border px-2 py-1 text-xs text-muted hover:border-primary hover:text-text"
          type="button"
          data-copy-target="#rgb-input"
        >
          Copy
        </button>
      </div>
      <input
        id="rgb-input"
        class="w-full rounded-lg border border-border bg-bg px-3 py-2 text-sm text-text"
        type="text"
        placeholder="14, 165, 233"
      />
    </div>
  </div>
  <div class="flex flex-wrap gap-2">
    <button
      class="cc-tool-button rounded-lg border border-border px-3 py-2 text-sm font-medium text-text hover:border-primary"
      type="button"
      data-hex-to-rgb
    >
      Hex to RGB
    </button>
    <button
      class="cc-tool-button rounded-lg border border-border px-3 py-2 text-sm font-medium text-text hover:border-primary"
      type="button"
      data-rgb-to-hex
    >
      RGB to Hex
    </button>
  </div>
  <p class="text-xs text-muted" data-error></p>
  <script is:inline>
    (() => {
      const root = document.querySelector('[data-tool="hex-rgb"]');
    if (root) {
      const hexInput = root.querySelector("#hex-input");
      const rgbInput = root.querySelector("#rgb-input");
      const hexToRgb = root.querySelector("[data-hex-to-rgb]");
      const rgbToHex = root.querySelector("[data-rgb-to-hex]");
      const error = root.querySelector("[data-error]");
      const parseHex = (value) => {
        const hex = value.replace("#", "").trim();
        if (![3, 6].includes(hex.length)) return null;
        const full = hex.length === 3 ? hex.split("").map((c) => c + c).join("") : hex;
        const num = parseInt(full, 16);
        return {
          r: (num >> 16) & 255,
          g: (num >> 8) & 255,
          b: num & 255,
        };
      };
      const toHex = (value) => value.toString(16).padStart(2, "0");
      hexToRgb?.addEventListener("click", () => {
        if (!hexInput || !rgbInput || !error) return;
        const rgb = parseHex(hexInput.value);
        if (!rgb) {
          error.textContent = "Invalid hex value.";
          return;
        }
        rgbInput.value = `${rgb.r}, ${rgb.g}, ${rgb.b}`;
        error.textContent = "";
      });
      rgbToHex?.addEventListener("click", () => {
        if (!hexInput || !rgbInput || !error) return;
        const parts = rgbInput.value.split(",").map((v) => Number(v.trim()));
        if (parts.length !== 3 || parts.some((v) => Number.isNaN(v) || v < 0 || v > 255)) {
          error.textContent = "Invalid RGB value.";
          return;
        }
        hexInput.value = `#${toHex(parts[0])}${toHex(parts[1])}${toHex(parts[2])}`;
        error.textContent = "";
      });
    }
    })();
  </script>
</div>






