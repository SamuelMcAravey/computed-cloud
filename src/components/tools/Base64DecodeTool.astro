<div class="space-y-3" data-tool="base64-decode">
  <div class="space-y-2">
    <label class="text-xs uppercase tracking-wide text-muted" for="b64-decode-input">Base64</label>
    <textarea
      id="b64-decode-input"
      class="min-h-[120px] w-full rounded-lg border border-border bg-bg px-3 py-2 text-sm text-text"
      placeholder="Base64 to decode"
    ></textarea>
  </div>
  <div class="space-y-2">
    <label class="text-xs uppercase tracking-wide text-muted" for="b64-decode-output">Text</label>
    <textarea
      id="b64-decode-output"
      class="min-h-[120px] w-full rounded-lg border border-border bg-bg px-3 py-2 text-sm text-text"
      readonly
    ></textarea>
  </div>
  <p class="text-xs text-muted" data-error></p>
  <script is:inline>
    (() => {
      const root = document.querySelector('[data-tool="base64-decode"]');       
    if (root) {
      const input = root.querySelector("#b64-decode-input");
      const output = root.querySelector("#b64-decode-output");
      const error = root.querySelector("[data-error]");
      const decode = (value) => {
        const binary = atob(value.trim());
        const bytes = Uint8Array.from(binary, (c) => c.charCodeAt(0));
        return new TextDecoder().decode(bytes);
      };
      const update = () => {
        if (!input || !output || !error) return;
        const raw = input.value.trim();
        if (!raw) {
          output.value = "";
          error.textContent = "";
          return;
        }
        try {
          output.value = decode(raw);
          error.textContent = "";
        } catch {
          output.value = "";
          error.textContent = "Invalid base64 input.";
        }
      };
      let raf = 0;
      const scheduleUpdate = () => {
        cancelAnimationFrame(raf);
        raf = requestAnimationFrame(update);
      };
      input?.addEventListener("input", scheduleUpdate);
      scheduleUpdate();
    }
    })();
  </script>
</div>






