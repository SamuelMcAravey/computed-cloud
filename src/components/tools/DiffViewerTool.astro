<div class="space-y-3" data-tool="diff">
  <div class="grid gap-3 md:grid-cols-2">
    <div class="space-y-2">
      <label class="text-xs uppercase tracking-wide text-muted" for="diff-left">Left</label>
      <textarea
        id="diff-left"
        class="min-h-[140px] w-full rounded-lg border border-border bg-bg px-3 py-2 text-sm text-text"
      ></textarea>
    </div>
    <div class="space-y-2">
      <label class="text-xs uppercase tracking-wide text-muted" for="diff-right">Right</label>
      <textarea
        id="diff-right"
        class="min-h-[140px] w-full rounded-lg border border-border bg-bg px-3 py-2 text-sm text-text"
      ></textarea>
    </div>
  </div>
  <button
    class="rounded-lg border border-border px-3 py-2 text-sm font-medium text-text hover:border-primary"
    type="button"
    data-run
  >
    Compare
  </button>
  <div class="space-y-2">
    <label class="text-xs uppercase tracking-wide text-muted" for="diff-output">Diff</label>
    <pre
      id="diff-output"
      class="min-h-[140px] whitespace-pre-wrap rounded-lg border border-border bg-bg px-3 py-2 text-sm text-text"
    ></pre>
  </div>
  <script is:inline>
    (() => {
      const root = document.querySelector('[data-tool="diff"]');
    if (root) {
      const left = root.querySelector("#diff-left");
      const right = root.querySelector("#diff-right");
      const output = root.querySelector("#diff-output");
      const run = root.querySelector("[data-run]");
      const lcs = (a, b) => {
        const dp = Array.from({ length: a.length + 1 }, () => new Array(b.length + 1).fill(0));
        for (let i = 1; i <= a.length; i += 1) {
          for (let j = 1; j <= b.length; j += 1) {
            dp[i][j] = a[i - 1] === b[j - 1] ? dp[i - 1][j - 1] + 1 : Math.max(dp[i - 1][j], dp[i][j - 1]);
          }
        }
        const result = [];
        let i = a.length;
        let j = b.length;
        while (i > 0 && j > 0) {
          if (a[i - 1] === b[j - 1]) {
            result.unshift({ type: "equal", value: a[i - 1] });
            i -= 1;
            j -= 1;
          } else if (dp[i - 1][j] >= dp[i][j - 1]) {
            result.unshift({ type: "remove", value: a[i - 1] });
            i -= 1;
          } else {
            result.unshift({ type: "add", value: b[j - 1] });
            j -= 1;
          }
        }
        while (i > 0) {
          result.unshift({ type: "remove", value: a[i - 1] });
          i -= 1;
        }
        while (j > 0) {
          result.unshift({ type: "add", value: b[j - 1] });
          j -= 1;
        }
        return result;
      };
      run?.addEventListener("click", () => {
        if (!left || !right || !output) return;
        const leftLines = left.value.split("\n");
        const rightLines = right.value.split("\n");
        const diff = lcs(leftLines, rightLines)
          .map((entry) => {
            const prefix = entry.type === "add" ? "+" : entry.type === "remove" ? "-" : " ";
            return `${prefix} ${entry.value}`;
          })
          .join("\n");
        output.textContent = diff;
      });
    }
    })();
  </script>
</div>






