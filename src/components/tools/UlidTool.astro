<div class="space-y-3" data-tool="ulid">
  <div class="flex flex-col gap-2">
    <label class="text-xs uppercase tracking-wide text-muted" for="ulid-output">ULID</label>
    <div class="flex flex-col gap-2 sm:flex-row">
      <input
        id="ulid-output"
        class="w-full rounded-lg border border-border bg-bg px-3 py-2 text-sm text-text"
        type="text"
        readonly
      />
      <button
        class="rounded-lg border border-border px-3 py-2 text-sm font-medium text-text hover:border-primary"
        type="button"
        data-generate
      >
        Generate
      </button>
      <button
        class="rounded-lg border border-border px-3 py-2 text-sm font-medium text-text hover:border-primary"
        type="button"
        data-copy
      >
        Copy
      </button>
    </div>
  </div>
  <p class="text-xs text-muted">Time-based and sortable.</p>
  <script is:inline>
    (() => {
      const root = document.querySelector('[data-tool="ulid"]');
    if (root) {
      const output = root.querySelector("#ulid-output");
      const generate = root.querySelector("[data-generate]");
      const copy = root.querySelector("[data-copy]");
      const encodeTime = (time) => {
        const alphabet = "0123456789ABCDEFGHJKMNPQRSTVWXYZ";
        let value = time;
        let str = "";
        for (let i = 0; i < 10; i += 1) {
          str = alphabet[value % 32] + str;
          value = Math.floor(value / 32);
        }
        return str;
      };
      const encodeRandom = () => {
        const alphabet = "0123456789ABCDEFGHJKMNPQRSTVWXYZ";
        const bytes = new Uint8Array(16);
        crypto.getRandomValues(bytes);
        let str = "";
        for (let i = 0; i < 16; i += 1) {
          str += alphabet[bytes[i] % 32];
        }
        return str;
      };
      const makeUlid = () => encodeTime(Date.now()) + encodeRandom();
      const update = () => {
        if (output) output.value = makeUlid();
      };
      generate?.addEventListener("click", update);
      copy?.addEventListener("click", async () => {
        if (!output?.value) return;
        try {
          await navigator.clipboard.writeText(output.value);
        } catch {
          output.select();
          document.execCommand("copy");
        }
      });
      update();
    }
    })();
  </script>
</div>






