<div class="space-y-3" data-tool="base32">
  <div class="grid gap-3 md:grid-cols-2">
    <div class="space-y-2">
      <label class="text-xs uppercase tracking-wide text-muted" for="base32-mode">Mode</label>
      <select
        id="base32-mode"
        class="w-full rounded-lg border border-border bg-bg px-3 py-2 text-sm text-text"
      >
        <option value="encode">Encode</option>
        <option value="decode">Decode</option>
      </select>
    </div>
  </div>
  <div class="space-y-2">
    <label class="text-xs uppercase tracking-wide text-muted" for="base32-input">Input</label>
    <textarea
      id="base32-input"
      class="min-h-[120px] w-full rounded-lg border border-border bg-bg px-3 py-2 text-sm text-text"
      placeholder="Text to encode or Base32 to decode"
    ></textarea>
  </div>
  <div class="space-y-2">
    <div class="flex items-center justify-between gap-2">
      <label class="text-xs uppercase tracking-wide text-muted" for="base32-output">Output</label>
      <button
        class="cc-tool-button rounded-lg border border-border px-2 py-1 text-xs text-muted hover:border-primary hover:text-text"
        type="button"
        data-copy-target="#base32-output"
      >
        Copy
      </button>
    </div>
    <textarea
      id="base32-output"
      class="min-h-[120px] w-full rounded-lg border border-border bg-bg px-3 py-2 text-sm text-text"
      readonly
    ></textarea>
  </div>
  <p class="text-xs text-muted" data-error></p>
  <script is:inline>
    (() => {
      const root = document.querySelector('[data-tool="base32"]');
      if (!root) return;
      const modeSelect = root.querySelector("#base32-mode");
      const input = root.querySelector("#base32-input");
      const output = root.querySelector("#base32-output");
      const error = root.querySelector("[data-error]");
      const alphabet = "ABCDEFGHIJKLMNOPQRSTUVWXYZ234567";
      const encode = (text) => {
        const bytes = new TextEncoder().encode(text);
        let bits = 0;
        let value = 0;
        let out = "";
        for (const b of bytes) {
          value = (value << 8) | b;
          bits += 8;
          while (bits >= 5) {
            out += alphabet[(value >> (bits - 5)) & 31];
            bits -= 5;
          }
        }
        if (bits > 0) {
          out += alphabet[(value << (5 - bits)) & 31];
        }
        while (out.length % 8 !== 0) out += "=";
        return out;
      };
      const decode = (text) => {
        const clean = text.toUpperCase().replace(/[^A-Z2-7=]/g, "");
        let bits = 0;
        let value = 0;
        const bytes = [];
        for (const ch of clean) {
          if (ch === "=") break;
          const idx = alphabet.indexOf(ch);
          if (idx === -1) throw new Error("Invalid Base32 character.");
          value = (value << 5) | idx;
          bits += 5;
          if (bits >= 8) {
            bytes.push((value >> (bits - 8)) & 255);
            bits -= 8;
          }
        }
        return new TextDecoder().decode(new Uint8Array(bytes));
      };
      const update = () => {
        if (!input || !output || !error || !modeSelect) return;
        const raw = input.value;
        if (!raw.trim()) {
          output.value = "";
          error.textContent = "";
          return;
        }
        try {
          output.value = modeSelect.value === "encode" ? encode(raw) : decode(raw);
          error.textContent = "";
        } catch (err) {
          output.value = "";
          error.textContent = err?.message || "Invalid Base32 input.";
        }
      };
      let raf = 0;
      const schedule = () => {
        cancelAnimationFrame(raf);
        raf = requestAnimationFrame(update);
      };
      input?.addEventListener("input", schedule);
      modeSelect?.addEventListener("change", schedule);
      schedule();
    })();
  </script>
</div>
