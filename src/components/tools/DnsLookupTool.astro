<div class="space-y-3" data-tool="dns-lookup">
  <div class="grid gap-3 md:grid-cols-2">
    <div class="space-y-2">
      <label class="text-xs uppercase tracking-wide text-muted" for="dns-name">Hostname</label>
      <input
        id="dns-name"
        class="w-full rounded-lg border border-border bg-bg px-3 py-2 text-sm text-text"
        type="text"
        placeholder="example.com"
      />
    </div>
    <div class="space-y-2">
      <label class="text-xs uppercase tracking-wide text-muted" for="dns-type">Record type</label>
      <select
        id="dns-type"
        class="w-full rounded-lg border border-border bg-bg px-3 py-2 text-sm text-text"
      >
        <option>A</option>
        <option>AAAA</option>
        <option>CNAME</option>
        <option>MX</option>
        <option>TXT</option>
        <option>NS</option>
        <option>SOA</option>
        <option>CAA</option>
      </select>
    </div>
  </div>
  <button
    class="cc-tool-button rounded-lg border border-border px-3 py-2 text-sm font-medium text-text hover:border-primary"
    type="button"
    data-lookup
  >
    Lookup
  </button>
  <div class="space-y-2">
    <div class="flex items-center justify-between gap-2">
      <label class="text-xs uppercase tracking-wide text-muted" for="dns-output">Results</label>
      <button
        class="cc-tool-button rounded-lg border border-border px-2 py-1 text-xs text-muted hover:border-primary hover:text-text"
        type="button"
        data-copy-target="#dns-output"
      >
        Copy
      </button>
    </div>
    <textarea
      id="dns-output"
      class="min-h-[120px] w-full rounded-lg border border-border bg-bg px-3 py-2 text-sm text-text"
      readonly
    ></textarea>
  </div>
  <p class="text-xs text-muted">Uses DNS over HTTPS (dns.google).</p>
  <p class="text-xs text-muted" data-error></p>
  <script is:inline>
    (() => {
      const root = document.querySelector('[data-tool="dns-lookup"]');
      if (!root) return;
      const nameInput = root.querySelector("#dns-name");
      const typeSelect = root.querySelector("#dns-type");
      const output = root.querySelector("#dns-output");
      const button = root.querySelector("[data-lookup]");
      const error = root.querySelector("[data-error]");
      const lookup = async () => {
        if (!nameInput || !typeSelect || !output || !error) return;
        const name = nameInput.value.trim();
        if (!name) {
          output.value = "";
          error.textContent = "Enter a hostname.";
          return;
        }
        const type = typeSelect.value;
        try {
          const url = `https://dns.google/resolve?name=${encodeURIComponent(name)}&type=${encodeURIComponent(type)}`;
          const res = await fetch(url);
          if (!res.ok) throw new Error("Request failed");
          const data = await res.json();
          if (!data.Answer || data.Answer.length === 0) {
            output.value = "No records found.";
          } else {
            const lines = data.Answer.map((entry) => `${entry.name} ${entry.ttl} ${type} ${entry.data}`);
            output.value = lines.join("\n");
          }
          error.textContent = "";
        } catch {
          output.value = "";
          error.textContent = "Unable to resolve DNS.";
        }
      };
      button?.addEventListener("click", () => {
        void lookup();
      });
    })();
  </script>
</div>
