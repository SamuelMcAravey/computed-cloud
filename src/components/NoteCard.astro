---
import type { SiteNote } from "../utils/notes";
import {
  formatNotePublished,
  formatNotePublishedExact,
  getNoteAnchor,
  getNotePermalink,
} from "../utils/notes";
import { renderNoteBody } from "../utils/render-note-markdown";

export interface Props {
  note: SiteNote;
  compact?: boolean;
}

const { note, compact = false } = Astro.props;
const publishedExact = formatNotePublishedExact(note.published);
const publishedShort = formatNotePublished(note.published);
const notePermalink = getNotePermalink(note);
const visibleLinks = note.links.slice(0, 2);
const noteBodyHtml = !compact ? await renderNoteBody(note.body) : "";
---

<article
  id={getNoteAnchor(note)}
  class="flex h-full flex-col rounded-2xl border border-border bg-surface/90 p-6 shadow-sm scroll-mt-24"
>
  <div class="flex flex-wrap items-start justify-between gap-3">
    <div class="flex flex-wrap gap-2">
      {note.context && (
        <span class="inline-flex items-center rounded-full border border-border bg-bg/70 px-2.5 py-1 text-[11px] font-medium uppercase tracking-wide text-muted">
          {note.context}
        </span>
      )}
    </div>
    <div class="flex flex-wrap justify-end gap-1.5">
      {note.tags.map((tag) => (
        <span class="inline-flex items-center rounded-full border border-border bg-surface px-2 py-0.5 text-[10px] font-medium text-muted">
          {tag}
        </span>
      ))}
    </div>
  </div>

  <h2 class="mt-4 font-heading text-2xl font-semibold text-text">
    <a class="hover:text-primary" href={notePermalink}>{note.title}</a>
  </h2>
  <p class="mt-3 text-sm leading-7 text-muted">{note.summary}</p>

  {!compact && noteBodyHtml && (
    <div class="prose note-prose mt-4 max-w-none text-sm leading-7" set:html={noteBodyHtml} />
  )}

  <div class="mt-auto flex flex-wrap items-end justify-between gap-4 pt-6">
    <div class="flex flex-wrap gap-3">
      <a
        class="inline-flex items-center rounded-full border border-border px-4 py-2 text-sm font-medium text-text hover:border-primary"
        href={notePermalink}
      >
        Open note
      </a>
      {visibleLinks.map((link) => (
        <a
          class="inline-flex items-center rounded-full border border-border px-4 py-2 text-sm font-medium text-text hover:border-primary"
          href={link.href}
        >
          {link.label}
        </a>
      ))}
    </div>
    <div class="ml-auto flex items-center gap-3 text-right">
      <span class="text-xs uppercase tracking-wide text-muted">{publishedShort}</span>
      <button
        type="button"
        class="inline-flex items-center rounded-full border border-border px-3 py-2 text-xs font-medium text-muted hover:border-primary hover:text-text"
        data-copy-link={notePermalink}
        title={`Copy direct link for ${note.title}`}
        aria-label={`Copy direct link for ${note.title}`}
      >
        Copy link
      </button>
      <button
        type="button"
        class="inline-flex h-4 w-4 items-center justify-center text-[10px] font-medium text-muted"
        title={`Added ${publishedExact}`}
        aria-label={`Added ${publishedExact}`}
      >
        i
      </button>
    </div>
  </div>
</article>
