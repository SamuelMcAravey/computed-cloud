---
import type { SiteNote } from "../utils/notes";
import {
  formatNotePublished,
  formatNotePublishedExact,
  getNoteAnchor,
} from "../utils/notes";

export interface Props {
  note: SiteNote;
  compact?: boolean;
}

const { note, compact = false } = Astro.props;
const publishedLabel = formatNotePublished(note.published);
const publishedExact = formatNotePublishedExact(note.published);
---

<article
  id={getNoteAnchor(note)}
  class="rounded-2xl border border-border bg-surface/90 p-6 shadow-sm scroll-mt-24"
>
  <div class="flex flex-wrap items-center justify-between gap-3">
    <div class="flex flex-wrap gap-2">
      {note.context && (
        <span class="inline-flex items-center rounded-full border border-border bg-bg/70 px-2.5 py-1 text-[11px] font-medium uppercase tracking-wide text-muted">
          {note.context}
        </span>
      )}
      {note.tags.map((tag) => (
        <span class="inline-flex items-center rounded-full border border-border bg-surface px-2.5 py-1 text-[11px] font-medium text-muted">
          {tag}
        </span>
      ))}
    </div>
    <span class="text-[11px] uppercase tracking-wide text-muted" title={`Added ${publishedExact}`}>
      Added {publishedLabel}
    </span>
  </div>

  <h2 class="mt-4 font-heading text-2xl font-semibold text-text">{note.title}</h2>
  <p class="mt-3 text-sm leading-7 text-muted">{note.summary}</p>

  {!compact && note.body.length > 0 && (
    <div class="mt-4 space-y-4 text-sm leading-7 text-muted">
      {note.body.map((paragraph) => (
        <p>{paragraph}</p>
      ))}
    </div>
  )}

  {note.links.length > 0 && (
    <div class="mt-5 flex flex-wrap gap-3">
      {note.links.map((link) => (
        <a
          class="inline-flex items-center rounded-full border border-border px-4 py-2 text-sm font-medium text-text hover:border-primary"
          href={link.href}
        >
          {link.label}
        </a>
      ))}
    </div>
  )}
</article>
