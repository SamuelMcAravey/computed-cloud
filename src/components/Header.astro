---
const currentPath = Astro.url.pathname;
---

<header class="sticky top-0 z-20 border-b border-border/80 bg-bg/80 backdrop-blur">
  <div class="mx-auto flex w-full max-w-4xl flex-col gap-4 px-6 py-5 sm:flex-row sm:items-center sm:justify-between">
    <div class="flex items-center justify-between gap-4">
      <a class="flex items-center gap-3" href="/">
        <img src="/assets/logo-mark.svg" alt="Computed Cloud logo" class="h-8 w-8" />
        <span class="font-heading text-lg font-semibold tracking-tight text-text">
          computed cloud
        </span>
      </a>
    </div>
    <nav class="flex flex-wrap items-center gap-3 text-sm font-medium text-muted">
      <a class={currentPath === "/" ? "text-text" : ""} href="/">Home</a>
      <a class={currentPath.startsWith("/blog") ? "text-text" : ""} href="/blog">Blog</a>
      <a class={currentPath.startsWith("/tags") ? "text-text" : ""} href="/tags">Tags</a>
      <a class={currentPath === "/rss.xml" ? "text-text" : ""} href="/rss.xml">RSS</a>
    </nav>
  </div>
</header>
