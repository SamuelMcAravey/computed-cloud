---
export interface Props {
  title: string;
  description?: string;
  id?: string;
}

const { title, description, id } = Astro.props;
---

<section id={id} data-tool-card class="rounded-2xl border border-border bg-surface/90 p-6 shadow-sm">
  <header class="space-y-2">
    <div class="flex items-start justify-between gap-3">
      <h2 class="font-heading text-xl font-semibold text-text">{title}</h2>
      {id && (
        <button
          class="cc-tool-button rounded-lg border border-border px-2 py-1 text-xs text-muted hover:border-primary hover:text-text"
          type="button"
          data-copy-link={`#${id}`}
          aria-label={`Copy link to ${title}`}
          title="Copy link"
        >
          <svg
            aria-hidden="true"
            viewBox="0 0 24 24"
            class="h-4 w-4"
            fill="none"
            stroke="currentColor"
            stroke-width="1.5"
          >
            <path
              d="M10 13a5 5 0 0 0 7.07 0l3.54-3.54a5 5 0 1 0-7.07-7.07L11 4"
              stroke-linecap="round"
              stroke-linejoin="round"
            />
            <path
              d="M14 11a5 5 0 0 0-7.07 0L3.39 14.54a5 5 0 1 0 7.07 7.07L13 20"
              stroke-linecap="round"
              stroke-linejoin="round"
            />
          </svg>
        </button>
      )}
    </div>
    {description && <p class="text-sm text-muted">{description}</p>}
  </header>
  <div class="mt-4">
    <slot />
  </div>
</section>
