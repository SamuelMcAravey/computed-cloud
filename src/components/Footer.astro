---
import { SITE_TITLE } from "../consts";
const year = new Date().getFullYear();
---

<footer class="border-t border-border bg-bg">
  <div class="mx-auto w-full max-w-4xl space-y-6 px-6 py-10 text-sm text-muted">
    <div class="flex flex-col gap-6 sm:flex-row sm:items-center sm:justify-between">
      <div class="flex items-center gap-3">
        <img src="/assets/logo-mark.svg" alt="Computed Cloud logo" class="h-7 w-7" />
        <span class="font-heading text-base font-semibold text-text">computed cloud</span>
      </div>
      <div class="flex flex-wrap items-center gap-4 text-sm">
        <a href="/portfolio">Portfolio</a>
        <a href="/blog">Blog</a>
        <a href="/blog/start-here">Start Here</a>
        <a href="/tags">Tags</a>
        <a href="/rss.xml">RSS</a>
        <a href="/tools">Tools</a>
        <a href="/about">About</a>
      </div>
    </div>
    <div class="flex flex-col gap-2 sm:flex-row sm:items-center sm:justify-between">
      <span>&copy; {year} Samuel McAravey. All rights reserved.</span>
    </div>
  </div>
</footer>
