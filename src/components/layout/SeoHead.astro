---
import { SEO } from "astro-seo";
import { site } from "../../data/site";

export interface Props {
  title: string;
  description: string;
  canonicalPath?: string;
  canonicalUrl?: string;
  ogImage?: string;
  ogImageAlt?: string;
  ogType?: string;
  noIndex?: boolean;
}

const {
  title,
  description,
  canonicalPath,
  canonicalUrl,
  ogImage,
  ogImageAlt,
  ogType = "website",
  noIndex = false,
} = Astro.props;

const canBuildCanonical = Boolean(Astro.site);
const resolvedCanonical = canonicalUrl
  ? canonicalUrl
  : canBuildCanonical
    ? new URL(canonicalPath ?? Astro.url.pathname, Astro.site).toString()
    : undefined;

const ogImageUrl =
  ogImage && (ogImage.startsWith("http://") || ogImage.startsWith("https://"))
    ? ogImage
    : ogImage && canBuildCanonical
      ? new URL(ogImage, Astro.site).toString()
      : undefined;

const twitterCard = ogImageUrl ? "summary_large_image" : "summary";

const openGraph = ogImageUrl
  ? {
      basic: {
        title,
        type: ogType,
        image: ogImageUrl,
        url: resolvedCanonical ?? Astro.url.href,
      },
      image: {
        alt: ogImageAlt,
      },
      optional: {
        description,
        siteName: site.business.businessName,
      },
    }
  : undefined;
---

<SEO
  title={title}
  description={description}
  canonical={resolvedCanonical}
  noindex={noIndex}
  nofollow={noIndex}
  openGraph={openGraph}
  twitter={{
    card: twitterCard,
    title,
    description,
    image: ogImageUrl,
    imageAlt: ogImageAlt,
  }}
/>
