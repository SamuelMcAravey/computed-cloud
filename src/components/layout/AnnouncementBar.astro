---
export interface Props {
  message: string;
  href?: string;
  linkLabel?: string;
  variant?: "info" | "warning" | "success";
}

const {
  message,
  href,
  linkLabel = "Learn more",
  variant = "info",
} = Astro.props;

if (!message) {
  return null;
}

const variantClasses = {
  info: "bg-blue-600 text-white",
  warning: "bg-amber-500 text-slate-900",
  success: "bg-emerald-600 text-white",
} as const;
---

<div class:list={["w-full", variantClasses[variant]]}>
  <div class="container mx-auto flex flex-wrap items-center justify-between gap-3 px-4 py-2 text-sm sm:px-6 lg:px-8">
    <span>{message}</span>
    {href ? (
      <a
        href={href}
        class="font-semibold underline decoration-current/60 underline-offset-4 transition-colors focus:outline-none focus:ring-2 focus:ring-white/80 focus:ring-offset-2 focus:ring-offset-transparent hover:text-white/90"
      >
        {linkLabel}
      </a>
    ) : null}
  </div>
</div>
