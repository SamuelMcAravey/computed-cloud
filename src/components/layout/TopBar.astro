---
import { Clock, Mail, MapPin, Phone } from "lucide-react";

export interface Props {
  phone?: string;
  email?: string;
  hours?: string;
  serviceArea?: string;
}

const { phone, email, hours, serviceArea } = Astro.props;

const hasContent =
  Boolean(phone) || Boolean(email) || Boolean(hours) || Boolean(serviceArea);

if (!hasContent) {
  return null;
}
---

<div class="bg-slate-50 text-slate-600">
  <div class="container mx-auto flex flex-wrap items-center gap-x-6 gap-y-2 px-4 py-2 text-xs sm:px-6 lg:px-8">
    {phone ? (
      <a
        href={`tel:${phone}`}
        class="inline-flex items-center gap-2 font-semibold text-slate-700 transition-colors hover:text-blue-600 focus:outline-none focus:ring-2 focus:ring-blue-600 focus:ring-offset-2 focus:ring-offset-slate-50"
        aria-label={`Call ${phone}`}
      >
        <Phone size={14} aria-hidden="true" />
        <span>{phone}</span>
      </a>
    ) : null}
    {email ? (
      <a
        href={`mailto:${email}`}
        class="inline-flex items-center gap-2 font-semibold text-slate-700 transition-colors hover:text-blue-600 focus:outline-none focus:ring-2 focus:ring-blue-600 focus:ring-offset-2 focus:ring-offset-slate-50"
        aria-label={`Email ${email}`}
      >
        <Mail size={14} aria-hidden="true" />
        <span>{email}</span>
      </a>
    ) : null}
    {serviceArea ? (
      <div class="inline-flex items-center gap-2 text-slate-500">
        <MapPin size={14} aria-hidden="true" />
        <span>{serviceArea}</span>
      </div>
    ) : null}
    {hours ? (
      <div class="inline-flex items-center gap-2 text-slate-500">
        <Clock size={14} aria-hidden="true" />
        <span>{hours}</span>
      </div>
    ) : null}
  </div>
</div>
