---
import Breadcrumbs from "../nav/Breadcrumbs.astro";
import ButtonLink from "../ui/ButtonLink.astro";

export interface Props {
  headline: string;
  subheadline?: string;
  breadcrumbs?: Array<{ label: string; href?: string }>;
  showBreadcrumbs?: boolean;
  primaryCta?: { label: string; href: string };
  secondaryCta?: { label: string; href: string };
  align?: "left" | "center";
}

const {
  headline,
  subheadline,
  breadcrumbs,
  showBreadcrumbs = false,
  primaryCta,
  secondaryCta,
  align = "left",
} = Astro.props;

const alignClasses = {
  left: "text-left items-start",
  center: "text-center items-center",
} as const;
---

<section class="py-10 sm:py-12">
  <div
    class:list={[
      "container mx-auto flex flex-col gap-4 px-4 sm:px-6 lg:px-8",
      alignClasses[align],
    ]}
  >
    {(breadcrumbs && breadcrumbs.length > 0) || showBreadcrumbs ? (
      <Breadcrumbs items={breadcrumbs} />
    ) : null}

    <div class="space-y-3">
      <h1 class="text-3xl font-bold text-slate-900 sm:text-4xl">{headline}</h1>
      {subheadline ? (
        <p class="text-base text-slate-600">{subheadline}</p>
      ) : null}
    </div>

    {(primaryCta || secondaryCta) ? (
      <div
        class:list={[
          "mt-2 flex flex-wrap gap-3",
          align === "center" && "justify-center",
        ]}
      >
        {primaryCta ? (
          <ButtonLink href={primaryCta.href}>{primaryCta.label}</ButtonLink>
        ) : null}
        {secondaryCta ? (
          <ButtonLink href={secondaryCta.href} variant="secondary">
            {secondaryCta.label}
          </ButtonLink>
        ) : null}
      </div>
    ) : null}
  </div>
</section>
