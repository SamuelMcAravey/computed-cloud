---
<div class="relative overflow-hidden rounded-2xl border border-slate-200 bg-white/80 p-4 shadow-sm">
  <div class="grid gap-4 sm:grid-cols-2">
    <div class="rounded-xl border border-slate-200 bg-slate-50 p-3 sm:p-4">
      <div class="flex items-center justify-between text-xs text-slate-500">
        <span class="inline-flex items-center rounded-full bg-slate-900 px-2 py-0.5 font-semibold uppercase tracking-wide text-white">
          PDF
        </span>
        <span>Invoice_0428.pdf</span>
      </div>
      <div class="mt-3 space-y-2">
        <div class="h-3 w-4/5 rounded bg-slate-200"></div>
        <div class="h-3 w-3/4 rounded bg-slate-200"></div>
        <div class="h-3 w-2/3 rounded bg-slate-200"></div>
        <div class="hidden h-3 w-5/6 rounded bg-slate-200 sm:block"></div>
        <div class="hidden h-3 w-1/2 rounded bg-slate-200 sm:block"></div>
      </div>
      <div class="mt-3 rounded-lg border border-slate-200 bg-white p-3 text-xs text-slate-600">
        <p class="font-semibold text-slate-700">Line Items</p>
        <p>3 rows detected</p>
      </div>
    </div>
    <div class="rounded-xl border border-slate-200 bg-white p-3 sm:p-4">
      <div class="flex items-center justify-between text-xs font-semibold uppercase tracking-wide text-slate-500">
        <span>Review</span>
        <span class="rounded-full bg-slate-100 px-2 py-0.5 text-[10px] font-semibold text-slate-500">
          Source match
        </span>
      </div>
      <div class="mt-3 divide-y divide-slate-100 text-sm text-slate-700">
        <div class="flex flex-col gap-1 py-2 sm:flex-row sm:items-center sm:justify-between">
          <span class="text-slate-500">Vendor</span>
          <span class="font-medium text-slate-900">Northwind Industrial</span>
        </div>
        <div class="flex flex-col gap-1 py-2 sm:flex-row sm:items-center sm:justify-between">
          <span class="text-slate-500">Invoice #</span>
          <span class="font-medium text-slate-900">INV-10428</span>
        </div>
        <div class="flex flex-col gap-1 py-2 sm:flex-row sm:items-center sm:justify-between">
          <span class="text-slate-500">Date</span>
          <span class="font-medium text-slate-900">2024-07-18</span>
        </div>
        <div class="flex flex-col gap-1 py-2 sm:flex-row sm:items-center sm:justify-between">
          <span class="text-slate-500">Due date</span>
          <span class="font-medium text-slate-900">2024-08-17</span>
        </div>
        <div class="flex flex-col gap-1 py-2 sm:flex-row sm:items-center sm:justify-between">
          <span class="text-slate-500">Total</span>
          <span class="font-semibold text-slate-900">$1,598.40</span>
        </div>
      </div>
    </div>
  </div>
  <div class="mt-4 flex flex-wrap items-center gap-2 text-xs font-semibold text-slate-600">
    <span class="rounded-full border border-slate-200 bg-white px-3 py-1">Upload</span>
    <span class="text-slate-400">→</span>
    <span class="rounded-full border border-slate-200 bg-white px-3 py-1">Review</span>
    <span class="text-slate-400">→</span>
    <span class="rounded-full border border-slate-200 bg-white px-3 py-1">Export</span>
  </div>
  <div class="mt-3 w-full rounded-lg border border-slate-200 bg-white p-3 text-[11px] text-slate-600 shadow-sm sm:absolute sm:bottom-3 sm:right-3 sm:mt-0 sm:w-44">
    <div class="flex items-center justify-between text-[9px] font-semibold uppercase tracking-wide text-slate-500">
      <span>Export</span>
      <span>CSV / JSON</span>
    </div>
    <div class="mt-2 space-y-1 font-mono text-[10px] text-slate-500">
      <div>{"{\"invoice_number\": \"INV-10428\"}"}</div>
      <div>{"{\"total\": 1598.40}"}</div>
      <div>{"\"line_items\",3"}</div>
    </div>
  </div>
</div>
