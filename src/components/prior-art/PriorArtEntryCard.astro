---
import type { PriorArtEntry } from "../../data/prior-art";
import {
  formatPriorArtDateRange,
  getPriorArtKindLabel,
  getPriorArtRelatedEntries,
  getPriorArtStatusLabel,
  getPriorArtVisibilityLabel,
} from "../../data/prior-art";

export interface Props {
  entry: PriorArtEntry;
  parentTitle?: string | null;
  featured?: boolean;
}

const { entry, parentTitle = null, featured = false } = Astro.props;
const relatedEntries = getPriorArtRelatedEntries(entry).slice(0, 4);
const cardClass = featured
  ? "rounded-[2rem] border border-border bg-surface/95 p-7 shadow-sm"
  : "rounded-3xl border border-border bg-surface/90 p-6 shadow-sm";
---

<article
  id={entry.slug}
  class={cardClass}
  data-prior-art-entry
  data-kind={entry.kind}
  data-status={entry.status}
  data-searchable={[
    entry.title,
    entry.publicSummary,
    entry.notesPublic ?? "",
    entry.portfolio ?? "",
    ...entry.tags,
    ...entry.domains,
  ].join(" ").toLowerCase()}
>
  <div class="flex flex-wrap items-start justify-between gap-3">
    <div class="flex flex-wrap gap-2">
      <span class="inline-flex items-center rounded-full border border-border bg-bg/70 px-2.5 py-1 text-[11px] font-medium uppercase tracking-wide text-muted">
        {getPriorArtKindLabel(entry.kind)}
      </span>
      <span class="inline-flex items-center rounded-full border border-border bg-bg/70 px-2.5 py-1 text-[11px] font-medium uppercase tracking-wide text-muted">
        {getPriorArtStatusLabel(entry.status)}
      </span>
      <span class="inline-flex items-center rounded-full border border-border bg-bg/70 px-2.5 py-1 text-[11px] font-medium uppercase tracking-wide text-muted">
        {getPriorArtVisibilityLabel(entry.visibility)}
      </span>
    </div>
    <span class="text-xs uppercase tracking-[0.18em] text-muted">
      {formatPriorArtDateRange(entry)}
    </span>
  </div>

  <div class="mt-4">
    <h3 class={featured ? "font-heading text-3xl font-semibold text-text" : "font-heading text-2xl font-semibold text-text"}>
      {entry.title}
    </h3>
    {parentTitle && (
      <p class="mt-2 text-xs uppercase tracking-[0.18em] text-muted">
        Part of {parentTitle}
      </p>
    )}
    {entry.portfolio && !parentTitle && (
      <p class="mt-2 text-xs uppercase tracking-[0.18em] text-muted">
        {entry.portfolio}
      </p>
    )}
  </div>

  <p class="mt-4 text-sm leading-7 text-muted">{entry.publicSummary}</p>

  {entry.notesPublic && (
    <p class="mt-4 text-sm leading-7 text-muted">{entry.notesPublic}</p>
  )}

  <div class="mt-5 flex flex-wrap gap-2">
    {entry.tags.map((tag) => (
      <span class="inline-flex items-center rounded-full border border-border bg-surface px-2.5 py-1 text-xs font-medium text-muted">
        {tag}
      </span>
    ))}
  </div>

  {(entry.publicLinks.length > 0 || entry.evidencePublic.length > 0 || relatedEntries.length > 0) && (
    <div class="mt-6 space-y-4 border-t border-border/80 pt-5">
      {entry.publicLinks.length > 0 && (
        <div>
          <p class="text-xs uppercase tracking-[0.18em] text-muted">Public links</p>
          <div class="mt-3 flex flex-wrap gap-3">
            {entry.publicLinks.map((link) => (
              <a
                class="inline-flex items-center rounded-full border border-border px-4 py-2 text-sm font-medium text-text hover:border-primary"
                href={link.url}
                target={link.url.startsWith("http") ? "_blank" : undefined}
                rel={link.url.startsWith("http") ? "noreferrer" : undefined}
              >
                {link.label}
              </a>
            ))}
          </div>
        </div>
      )}

      {entry.evidencePublic.length > 0 && (
        <div>
          <p class="text-xs uppercase tracking-[0.18em] text-muted">Public evidence</p>
          <ul class="mt-3 space-y-2 text-sm leading-6 text-muted">
            {entry.evidencePublic.map((evidence) => (
              <li>
                <a
                  class="font-medium text-text underline decoration-accent/50 underline-offset-4"
                  href={evidence.url}
                  target={evidence.url.startsWith("http") ? "_blank" : undefined}
                  rel={evidence.url.startsWith("http") ? "noreferrer" : undefined}
                >
                  {evidence.label}
                </a>
                {evidence.note && <span>{` - ${evidence.note}`}</span>}
              </li>
            ))}
          </ul>
        </div>
      )}

      {entry.domains.length > 0 && (
        <div>
          <p class="text-xs uppercase tracking-[0.18em] text-muted">Domains</p>
          <div class="mt-3 flex flex-wrap gap-2">
            {entry.domains.map((domain) => (
              <span class="inline-flex items-center rounded-full border border-border bg-bg/70 px-3 py-1.5 text-xs font-medium text-muted">
                {domain}
              </span>
            ))}
          </div>
        </div>
      )}

      {relatedEntries.length > 0 && (
        <div>
          <p class="text-xs uppercase tracking-[0.18em] text-muted">Related items</p>
          <div class="mt-3 flex flex-wrap gap-2">
            {relatedEntries.map((relatedEntry) => (
              <a
                class="inline-flex items-center rounded-full border border-border bg-bg/70 px-3 py-1.5 text-xs font-medium text-text hover:border-primary"
                href={`#${relatedEntry.slug}`}
              >
                {relatedEntry.title}
              </a>
            ))}
          </div>
        </div>
      )}
    </div>
  )}
</article>
