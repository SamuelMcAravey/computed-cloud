---
import BaseLayout from "@layouts/BaseLayout.astro";
import TagChip from "@components/TagChip.astro";
import { normalizeTag } from "../utils/blog";
import { SHOW_POST_DATES } from "../consts";
import type { MarkdownHeading } from "astro";

export interface Props {
  title: string;
  description: string;
  pubDate: Date;
  updatedDate?: Date;
  tags: string[];
  heroImage?: string;
  headings?: MarkdownHeading[];
}

const { title, description, pubDate, updatedDate, tags, heroImage, headings } = Astro.props;
const published = pubDate.toLocaleDateString("en-US", {
  year: "numeric",
  month: "long",
  day: "numeric",
});
const updated =
  updatedDate &&
  updatedDate.toLocaleDateString("en-US", {
    year: "numeric",
    month: "long",
    day: "numeric",
  });
const tocHeadings =
  headings?.filter((heading) => heading.depth >= 2 && heading.depth <= 3) ?? [];
const hasToc = tocHeadings.length > 0;
---

<BaseLayout title={title} description={description} ogType="article" ogImage={heroImage}>
  <article>
    <div class="flex flex-wrap items-center justify-between gap-3">
      <a class="cc-backlink text-xs uppercase tracking-wide text-muted no-underline" href="/blog">
      ← Back to blog
      </a>
      <button
        type="button"
        class="cc-print-button rounded-full border border-border px-3 py-2 text-xs font-medium text-muted hover:border-primary hover:text-text"
        onClick="window.print()"
      >
        Print
      </button>
    </div>
    <h1 class="mt-5 font-heading text-4xl text-text">{title}</h1>
    {SHOW_POST_DATES && (
      <p class="text-sm text-muted">
        {published}
        {updated && ` · Updated ${updated}`}
      </p>
    )}
    {tags.length > 0 && (
      <div class="mt-4 flex flex-wrap gap-2">
        {tags.map((tag) => (
          <TagChip label={tag} href={`/tags/${normalizeTag(tag)}`} />
        ))}
      </div>
    )}
    {heroImage && (
      <img
        class="mt-8 w-full rounded-xl border border-border"
        src={heroImage}
        alt={title}
        loading="lazy"
        decoding="async"
      />
    )}
    {hasToc && (
      <details class="mt-6 rounded-2xl border border-border bg-surface px-4 py-3 text-sm text-text lg:hidden">
        <summary class="cursor-pointer font-semibold text-text">On this page</summary>
        <ol class="mt-3 space-y-1 text-muted">
          {tocHeadings.map((heading) => (
            <li class={heading.depth === 3 ? "pl-4" : ""}>
              <a class="no-underline hover:text-text" href={`#${heading.slug}`}>
                {heading.text}
              </a>
            </li>
          ))}
        </ol>
      </details>
    )}
    <div class="mt-10 lg:grid lg:grid-cols-[minmax(0,1fr)_220px] lg:gap-10">
      <div class="prose max-w-none">
        <slot />
      </div>
      {hasToc && (
        <aside class="hidden lg:block">
          <div class="sticky top-24 rounded-2xl border border-border bg-surface px-4 py-4 text-sm text-muted">
            <p class="font-semibold text-text">On this page</p>
            <ol class="mt-3 space-y-2">
              {tocHeadings.map((heading) => (
                <li class={heading.depth === 3 ? "pl-4" : ""}>
                  <a class="no-underline hover:text-text" href={`#${heading.slug}`}>
                    {heading.text}
                  </a>
                </li>
              ))}
            </ol>
          </div>
        </aside>
      )}
    </div>
  </article>
</BaseLayout>
