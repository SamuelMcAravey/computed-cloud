---
import BaseLayout from "../layouts/BaseLayout.astro";
import type { Theme } from "../templates/types";
import {
  vendorHubTheme,
  rixianTheme,
  pearlBakeryTheme,
  incursaTheme,
  tradesTheme,
  medicalTheme,
  lawFirmTheme,
  studioTheme,
} from "../data/themes";

const presets: Array<{ name: string; theme: Theme }> = [
  { name: "Vendor Hub", theme: vendorHubTheme },
  { name: "Rixian", theme: rixianTheme },
  { name: "Pearl Bakery", theme: pearlBakeryTheme },
  { name: "Incursa", theme: incursaTheme },
  { name: "Trades", theme: tradesTheme },
  { name: "Medical", theme: medicalTheme },
  { name: "Law Firm", theme: lawFirmTheme },
  { name: "Studio", theme: studioTheme },
];

const hexToRgb = (value: string | undefined): string | null => {
  if (!value) return null;
  let hex = value.trim().replace("#", "");
  if (hex.length === 3) {
    hex = hex
      .split("")
      .map((char) => char + char)
      .join("");
  }
  if (hex.length !== 6) return null;
  const int = Number.parseInt(hex, 16);
  if (Number.isNaN(int)) return null;
  const r = (int >> 16) & 255;
  const g = (int >> 8) & 255;
  const b = int & 255;
  return `${r}, ${g}, ${b}`;
};

const percentToAlpha = (value: string | undefined, fallback: number): number => {
  if (!value) return fallback;
  const trimmed = value.trim();
  const numeric = trimmed.endsWith("%")
    ? Number.parseFloat(trimmed) / 100
    : Number.parseFloat(trimmed);
  if (Number.isNaN(numeric)) return fallback;
  return Math.min(1, Math.max(0, numeric));
};

const buildThemeStyle = (theme: Theme): string => {
  const palette = theme.palette ?? {};
  const footer = palette.footer ?? {};
  const brand = palette.brand ?? {};
  const accent = palette.accent ?? {};
  const radius = theme.radius ?? {};
  const typography = theme.typography ?? {};
  const shadows = theme.shadows ?? {};
  const background = theme.background ?? {};
  const pageAccent = background.accent ?? brand["300"] ?? "#676767";
  const pageAccentRgb = hexToRgb(pageAccent) ?? "103, 103, 103";
  const patternAlpha = percentToAlpha(background.patternOpacity, 0.5);

  return [
    `--brand-primary: ${brand["600"] ?? palette.textStrong ?? "#0f172a"};`,
    `--brand-accent: ${accent["600"] ?? accent["500"] ?? "#2563eb"};`,
    `--color-surface: ${palette.surface ?? "#ffffff"};`,
    `--color-surface-muted: ${palette.surfaceMuted ?? "#f8fafc"};`,
    `--color-text: ${palette.text ?? "#0f172a"};`,
    `--color-text-strong: ${palette.textStrong ?? palette.text ?? "#0f172a"};`,
    `--color-text-muted: ${palette.textMuted ?? "#475569"};`,
    `--color-text-subtle: ${palette.textSubtle ?? "#64748b"};`,
    `--color-border: ${palette.border ?? "#e2e8f0"};`,
    `--color-ring: ${palette.ring ?? accent["600"] ?? "#2563eb"};`,
    `--footer-bg: ${footer.background ?? "#0f172a"};`,
    `--footer-text: ${footer.text ?? "#cbd5f5"};`,
    `--footer-text-strong: ${footer.textStrong ?? "#ffffff"};`,
    `--footer-text-muted: ${footer.textMuted ?? "#94a3b8"};`,
    `--footer-link: ${footer.link ?? "#94a3b8"};`,
    `--footer-link-hover: ${footer.linkHover ?? "#38bdf8"};`,
    `--footer-border: ${footer.border ?? "#1e293b"};`,
    `--color-brand-50: ${brand["50"] ?? "#eff6ff"};`,
    `--color-brand-100: ${brand["100"] ?? "#dbeafe"};`,
    `--color-brand-200: ${brand["200"] ?? "#bfdbfe"};`,
    `--color-brand-300: ${brand["300"] ?? "#93c5fd"};`,
    `--color-brand-400: ${brand["400"] ?? "#60a5fa"};`,
    `--color-brand-500: ${brand["500"] ?? "#3b82f6"};`,
    `--color-brand-600: ${brand["600"] ?? "#2563eb"};`,
    `--color-brand-700: ${brand["700"] ?? "#1d4ed8"};`,
    `--color-brand-800: ${brand["800"] ?? "#1e40af"};`,
    `--color-brand-900: ${brand["900"] ?? "#1e3a8a"};`,
    `--color-accent-500: ${accent["500"] ?? brand["600"] ?? "#2563eb"};`,
    `--color-accent-600: ${accent["600"] ?? accent["500"] ?? "#2563eb"};`,
    `--color-accent-700: ${accent["700"] ?? accent["600"] ?? "#1d4ed8"};`,
    `--radius-sm: ${radius.sm ?? "0.5rem"};`,
    `--radius-md: ${radius.md ?? "0.75rem"};`,
    `--radius-lg: ${radius.lg ?? "1rem"};`,
    `--radius-xl: ${radius.xl ?? "1.25rem"};`,
    `--radius-2xl: ${radius["2xl"] ?? "1.5rem"};`,
    `--font-body: ${typography.body ?? 'ui-sans-serif, system-ui, "Segoe UI", sans-serif'};`,
    `--font-display: ${typography.heading ?? 'ui-serif, "Georgia", serif'};`,
    `--shadow-card: ${shadows.card ?? "0 8px 24px rgb(15 23 42 / 0.08)"};`,
    `--shadow-card-hover: ${shadows.hover ?? "0 12px 32px rgb(15 23 42 / 0.12)"};`,
    `--shadow-elevated: ${shadows.elevated ?? "0 18px 54px rgb(15 23 42 / 0.18)"};`,
    `--page-bg-base: ${background.base ?? palette.surface ?? "#ffffff"};`,
    `--page-bg-accent: ${pageAccent};`,
    `--page-bg-accent-rgb: ${pageAccentRgb};`,
    `--page-bg-pattern-alpha: ${patternAlpha};`,
    `--page-bg-pattern-size: ${background.patternSize ?? "32px 32px"};`,
  ].join(" ");
};

const buildBackgroundStyle = (theme: Theme): string => {
  const palette = theme.palette ?? {};
  const brand = palette.brand ?? {};
  const background = theme.background ?? {};
  const base = background.base ?? palette.surface ?? "#ffffff";
  const accent = background.accent ?? brand["100"] ?? "#676767";
  const accentRgb = hexToRgb(accent) ?? "103, 103, 103";
  const alpha = percentToAlpha(background.patternOpacity, 0.5);

  if (background.mode === "gradient") {
    return `background-image: linear-gradient(180deg, ${base} 0%, ${accent} 55%, ${base} 100%);`;
  }
  if (background.mode === "pattern") {
    const size = background.patternSize ?? "32px 32px";
    return `background-image: radial-gradient(rgba(${accentRgb}, ${alpha}) 1px, transparent 1px); background-size: ${size};`;
  }

  return `background-color: ${base};`;
};
---

<BaseLayout pageTitle="Theme Preview" description="Preset theme palette previews.">
  <section class="py-16">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-2xl space-y-3">
        <h1 class="text-3xl font-semibold text-slate-900 sm:text-4xl">Theme preview</h1>
        <p class="text-slate-600">
          Quick visual checks for the preset palettes, radius, and typography tokens.
        </p>
      </div>
      <div class="mt-10 grid gap-8 lg:grid-cols-2">
        {presets.map(({ name, theme }) => (
          <div
            class="space-y-6 rounded-3xl border border-slate-200 bg-white p-6 shadow-sm"
            style={buildThemeStyle(theme)}
          >
            <div class="flex items-start justify-between gap-4">
              <div>
                <h2 class="text-xl font-semibold text-slate-900">{name}</h2>
                <p class="text-sm text-slate-600">Primary palette + surface preview</p>
              </div>
              <span class="inline-flex rounded-full bg-blue-100 px-3 py-1 text-xs font-medium text-blue-700">
                Preset
              </span>
            </div>

            <div
              class="h-28 rounded-2xl border border-slate-200"
              style={buildBackgroundStyle(theme)}
            />

            <div class="space-y-4">
              <div class="rounded-2xl border border-slate-200 bg-slate-50 p-4 shadow-sm">
                <p class="text-sm font-medium text-slate-900">Sample card</p>
                <p class="mt-1 text-sm text-slate-600">
                  Body copy uses the theme text tokens and radius scale.
                </p>
              </div>
              <div class="flex flex-wrap items-center gap-3">
                <button class="rounded-lg bg-blue-600 px-4 py-2 text-sm font-semibold text-white shadow-sm transition-colors hover:bg-blue-700">
                  Primary action
                </button>
                <button class="rounded-lg border border-blue-200 px-4 py-2 text-sm font-semibold text-blue-600 hover:bg-blue-50">
                  Secondary action
                </button>
                <a class="text-sm font-medium text-blue-600 transition-colors hover:text-blue-800" href="#">
                  Text link
                </a>
              </div>
            </div>

            <div
              class="rounded-2xl border border-slate-200 px-4 py-3 text-sm"
              style="background-color: var(--footer-bg); color: var(--footer-text);"
            >
              <div class="flex items-center justify-between text-xs uppercase tracking-wider">
                <span style="color: var(--footer-text-strong);">Footer</span>
                <span style="color: var(--footer-text-muted);">Preview</span>
              </div>
              <div class="mt-2 flex items-center justify-between text-sm">
                <a class="transition-colors hover:text-[var(--footer-link-hover)]" href="#">
                  Footer link
                </a>
                <a
                  class="text-[var(--footer-link)] transition-colors hover:text-[var(--footer-link-hover)]"
                  href="#"
                >
                  Accent link
                </a>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
