    const needsQuotes = (value) =>
      value === "" ||
      /^\\s|\\s$/.test(value) ||
      /[:#\\n\\r\\t]/.test(value) ||
      /^[-?]|^(true|false|null|yes|no|on|off)$/i.test(value);

    const quoteScalar = (value) => `'${value.replace(/'/g, "''")}'`;

    const formatScalar = (value) => (needsQuotes(value) ? quoteScalar(value) : value);

    const formatFlowArray = (values) => `[${values.map((entry) => formatScalar(entry)).join(", ")}]`;

    const formatCommand = (command) => {
      const trimmed = command.trim();
      if (trimmed.startsWith("[") && trimmed.endsWith("]")) return trimmed;
      return formatScalar(trimmed);
    };

    const appendRawBlock = (lines, raw, indent) => {
      if (!raw || !raw.trim()) return;
      const prefix = " ".repeat(indent);
      raw.replace(/\r/g, "").split("\n").forEach((line) => {
        lines.push(`${prefix}${line}`);
      });
    };

    const buildCloudInitYaml = (state) => {
      const lines = ["#cloud-config"];
      lines.push(`# os: ${state.general.os || "debian-12"}`);
      const addLine = (line) => lines.push(line);
      const addKeyValue = (key, value) => addLine(`${key}: ${formatScalar(value)}`);

      if (state.general.hostname.trim()) addKeyValue("hostname", state.general.hostname.trim());
      if (state.general.fqdn.trim()) addKeyValue("fqdn", state.general.fqdn.trim());
      if (state.general.timezone.trim()) addKeyValue("timezone", state.general.timezone.trim());

      if (state.boot.enabled) {
        addLine(`package_update: ${state.boot.packageUpdate ? "true" : "false"}`);
        addLine(`package_upgrade: ${state.boot.packageUpgrade ? "true" : "false"}`);
      } else {
        if (state.boot.packageUpdate) addLine("package_update: true");
        if (state.boot.packageUpgrade) addLine("package_upgrade: true");
      }

      addLine(`ssh_pwauth: ${state.general.sshPwauth ? "true" : "false"}`);

      if (state.users.disableRoot) addLine("disable_root: true");
      if (state.users.lockPassword) addLine("lock_passwd: true");
      const importIds = state.users.sshImportId
        .split(/\r?\n/)
        .map((entry) => entry.trim())
        .filter(Boolean);
      if (importIds.length) {
        addLine("ssh_import_id:");
        importIds.forEach((entry) => addLine(`  - ${formatScalar(entry)}`));
      }

      const aptSources = state.apt.sources.filter(
        (source) => source.name.trim() && source.source.trim() && source.key.trim()
      );
      if (
        state.apt.enabled ||
        state.apt.raw ||
        state.apt.primaryMirror.trim() ||
        state.apt.httpProxy.trim() ||
        state.apt.httpsProxy.trim() ||
        aptSources.length
      ) {
        addLine("apt:");
        if (state.apt.primaryMirror.trim()) {
          addLine("  primary:");
          addLine(`    - uri: ${formatScalar(state.apt.primaryMirror.trim())}`);
          addLine("      arches: [default]");
        }
        if (state.apt.httpProxy.trim() || state.apt.httpsProxy.trim()) {
          addLine("  proxy:");
          if (state.apt.httpProxy.trim()) addLine(`    http: ${formatScalar(state.apt.httpProxy.trim())}`);
          if (state.apt.httpsProxy.trim()) addLine(`    https: ${formatScalar(state.apt.httpsProxy.trim())}`);
        }
        if (aptSources.length) {
          addLine("  sources:");
          aptSources.forEach((source) => {
            addLine(`    ${formatScalar(source.name.trim())}:`);
            addLine(`      source: ${formatScalar(source.source.trim())}`);
            addLine("      key: |");
            source.key.replace(/\r/g, "").split("\n").forEach((line) => {
              addLine(`        ${line}`);
            });
          });
        }
        appendRawBlock(lines, state.apt.raw, 2);
      }

      if (state.users.enabled || state.users.raw) {
        addLine("users:");
        if (state.users.enabled && state.users.items.length) {
          state.users.items.forEach((user) => {
            const name = user.name.trim();
            if (!name) return;
            addLine(`  - name: ${formatScalar(name)}`);
            const groups = user.groups
              .split(",")
              .map((entry) => entry.trim())
              .filter(Boolean);
            if (groups.length) {
              addLine(`    groups: ${formatFlowArray(groups)}`);
            } else if (user.system) {
              addLine("    groups: []");
            }
            if (user.system) addLine("    system: true");
            if (user.sudo.trim()) {
              addLine(`    sudo: ${formatScalar(user.sudo.trim())}`);
            } else if (user.system) {
              addLine('    sudo: ""');
            }
            if (user.shell.trim()) addLine(`    shell: ${formatScalar(user.shell.trim())}`);
            const keys = user.sshKeys
              .split(/\r?\n/)
              .map((entry) => entry.trim())
              .filter(Boolean);
            if (keys.length) {
              addLine("    ssh_authorized_keys:");
              keys.forEach((key) => addLine(`      - ${formatScalar(key)}`));
            }
          });
        }
        appendRawBlock(lines, state.users.raw, 2);
      }

      if (state.packages.enabled || state.packages.raw) {
        const selected = state.packages.selected.filter(Boolean);
        const custom = state.packages.custom.map((entry) => entry.trim()).filter(Boolean);
        const packages = [...selected, ...custom];
        if (packages.length || state.packages.raw.trim()) {
          addLine("packages:");
          packages.forEach((pkg) => addLine(`  - ${formatScalar(pkg)}`));
          appendRawBlock(lines, state.packages.raw, 2);
        }
      }

      if (state.writeFiles.enabled || state.writeFiles.raw) {
        const entries = state.writeFiles.items.filter((entry) => entry.path.trim());
        if (entries.length || state.writeFiles.raw.trim()) {
          addLine("write_files:");
          entries.forEach((file) => {
            addLine(`  - path: ${formatScalar(file.path.trim())}`);
            if (file.permissions.trim()) addLine(`    permissions: ${formatScalar(file.permissions.trim())}`);
            if (file.owner.trim()) addLine(`    owner: ${formatScalar(file.owner.trim())}`);
            addLine("    content: |");
            const contentLines = file.content ? file.content.split(/\r?\n/) : [""];
            contentLines.forEach((line) => addLine(`      ${line}`));
          });
          appendRawBlock(lines, state.writeFiles.raw, 2);
        }
      }

      if (state.boot.enabled || state.boot.raw) {
        const commands = state.boot.bootcmd.map((entry) => entry.trim()).filter(Boolean);
        if (commands.length || state.boot.raw.trim()) {
          addLine("bootcmd:");
          commands.forEach((command) => addLine(`  - ${formatCommand(command)}`));
          appendRawBlock(lines, state.boot.raw, 2);
        }
      }

      if (state.runcmd.enabled || state.runcmd.raw) {
        const commands = state.runcmd.items.map((entry) => entry.trim()).filter(Boolean);
        if (commands.length || state.runcmd.raw.trim()) {
          addLine("runcmd:");
          commands.forEach((command) => addLine(`  - ${formatCommand(command)}`));
          appendRawBlock(lines, state.runcmd.raw, 2);
        }
      }

      if (state.services.enabled || state.services.raw) {
        if (state.services.units.length || state.services.raw.trim()) {
          addLine("systemd:");
          if (state.services.enabled && state.services.units.length) {
            addLine("  units:");
            state.services.units.forEach((unit) => {
              if (!unit.name.trim()) return;
              addLine(`    - name: ${formatScalar(unit.name.trim())}`);
              addLine(`      enabled: ${unit.enabled ? "true" : "false"}`);
              addLine("      contents: |");
              const contentLines = unit.content ? unit.content.split(/\r?\n/) : [""];
              contentLines.forEach((line) => addLine(`        ${line}`));
            });
          }
          appendRawBlock(lines, state.services.raw, 2);
        }
      }

      if (state.network.enabled || state.network.raw) {
        const ethernets = state.network.ethernets.filter((ethernet) => ethernet.name.trim());
        const vlans = state.network.vlans.filter((vlan) => {
          const name = String(vlan.name ?? "").trim();
          const link = String(vlan.link ?? "").trim();
          return name && String(vlan.id ?? "").trim() && link;
        });
        if (ethernets.length || vlans.length || state.network.raw.trim()) {
          addLine("network:");
          addLine("  version: 2");
          if (state.network.renderer) addLine(`  renderer: ${formatScalar(state.network.renderer)}`);
          if (ethernets.length) {
            addLine("  ethernets:");
            ethernets.forEach((ethernet) => {
              const name = ethernet.name.trim();
              addLine(`    ${formatScalar(name)}:`);
              addLine(`      dhcp4: ${ethernet.dhcp4 ? "true" : "false"}`);
              addLine(`      dhcp6: ${ethernet.dhcp6 ? "true" : "false"}`);
              if (ethernet.optional) addLine("      optional: true");
              if (ethernet.mtu.trim()) addLine(`      mtu: ${formatScalar(ethernet.mtu.trim())}`);
              const addresses = ethernet.addresses
                .split(",")
                .map((entry) => entry.trim())
                .filter(Boolean);
              if (addresses.length) addLine(`      addresses: ${formatFlowArray(addresses)}`);
              if (ethernet.gateway4.trim()) addLine(`      gateway4: ${formatScalar(ethernet.gateway4.trim())}`);
              if (ethernet.gateway6.trim()) addLine(`      gateway6: ${formatScalar(ethernet.gateway6.trim())}`);
              const nameservers = ethernet.nameservers
                .split(",")
                .map((entry) => entry.trim())
                .filter(Boolean);
              if (nameservers.length) {
                addLine("      nameservers:");
                addLine(`        addresses: ${formatFlowArray(nameservers)}`);
              }
              const routes = ethernet.routes
                .split(/\r?\n/)
                .map((entry) => entry.trim())
                .filter(Boolean);
              if (routes.length) {
                addLine("      routes:");
                routes.forEach((route) => {
                  const parts = route.split(/\s+/);
                  if (parts.length >= 2) {
                    addLine(`        - to: ${formatScalar(parts[0])}`);
                    addLine(`          via: ${formatScalar(parts[1])}`);
                    if (parts[2]) addLine(`          metric: ${formatScalar(parts[2])}`);
                  }
                });
              }
            });
          }
          if (vlans.length) {
            addLine("  vlans:");
            vlans.forEach((vlan) => {
              const name = String(vlan.name ?? "").trim();
              const link = String(vlan.link ?? "").trim();
              const mtu = String(vlan.mtu ?? "").trim();
              const gateway4 = String(vlan.gateway4 ?? "").trim();
              const gateway6 = String(vlan.gateway6 ?? "").trim();
              addLine(`    ${formatScalar(name)}:`);
              addLine(`      id: ${formatScalar(String(vlan.id).trim())}`);
              if (link) addLine(`      link: ${formatScalar(link)}`);
              addLine(`      dhcp4: ${vlan.dhcp4 ? "true" : "false"}`);
              addLine(`      dhcp6: ${vlan.dhcp6 ? "true" : "false"}`);
              if (vlan.optional) addLine("      optional: true");
              if (mtu) addLine(`      mtu: ${formatScalar(mtu)}`);
              const addresses = vlan.addresses
                .split(",")
                .map((entry) => entry.trim())
                .filter(Boolean);
              if (addresses.length) addLine(`      addresses: ${formatFlowArray(addresses)}`);
              if (gateway4) addLine(`      gateway4: ${formatScalar(gateway4)}`);
              if (gateway6) addLine(`      gateway6: ${formatScalar(gateway6)}`);
              const nameservers = vlan.nameservers
                .split(",")
                .map((entry) => entry.trim())
                .filter(Boolean);
              if (nameservers.length) {
                addLine("      nameservers:");
                addLine(`        addresses: ${formatFlowArray(nameservers)}`);
              }
              const routes = vlan.routes
                .split(/\r?\n/)
                .map((entry) => entry.trim())
                .filter(Boolean);
              if (routes.length) {
                addLine("      routes:");
                routes.forEach((route) => {
                  const parts = route.split(/\s+/);
                  if (parts.length >= 2) {
                    addLine(`        - to: ${formatScalar(parts[0])}`);
                    addLine(`          via: ${formatScalar(parts[1])}`);
                    if (parts[2]) addLine(`          metric: ${formatScalar(parts[2])}`);
                  }
                });
              }
            });
          }
          appendRawBlock(lines, state.network.raw, 2);
        }
      }

      if (state.general.finalMessage.trim()) {
        addLine("final_message: |");
        state.general.finalMessage.split(/\r?\n/).forEach((line) => addLine(`  ${line}`));
      }

      return lines.join("\n");
    };

