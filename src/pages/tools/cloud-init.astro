    const setCollapse = (key, open) => {
      const element = collapses.get(key);
      if (!element) return;
      const button = document.querySelector(`[data-collapse-toggle="${key}"]`);
      if (open) {
        element.style.setProperty("--collapse-height", `${element.scrollHeight}px`);
        element.dataset.open = "true";
      } else {
        element.style.setProperty("--collapse-height", "0px");
        element.dataset.open = "false";
      }
      if (button) button.setAttribute("aria-expanded", open ? "true" : "false");
    };

    const syncCollapses = () => {
      Object.keys(collapseState).forEach((key) => {
        setCollapse(key, collapseState[key]);
      });
    };

    document.querySelectorAll("[data-collapse]").forEach((element) => {
      collapses.set(element.dataset.collapse, element);
    });

    document.querySelectorAll("[data-collapse-toggle]").forEach((button) => {
      button.addEventListener("click", () => {
        const key = button.dataset.collapseToggle;
        collapseState = { ...collapseState, [key]: !collapseState[key] };
        syncCollapses();
      });
    });

    presetSelect?.addEventListener("change", (event) => {
      const value = event.target.value;
      if (!value || !PRESETS[value]) return;
      state = cloneState(PRESETS[value]);
      collapseState = {
        users: state.users.enabled,
        packages: state.packages.enabled,
        bootcmd: state.boot.enabled,
        runcmd: state.runcmd.enabled,
        write_files: state.writeFiles.enabled,
        services: state.services.enabled,
        network: state.network.enabled,
        apt: state.apt.enabled,
      };
      ensureDefaults();
      renderForm();
      syncCollapses();
    });

    importFetchButton?.addEventListener("click", async () => {
      if (!importUrlInput || !importText || !importError) return;
      const url = importUrlInput.value.trim();
      importError.textContent = "";
      if (!url) {
        importError.textContent = "Enter a URL to fetch.";
        return;
      }
      if (!/^https?:\/\//i.test(url)) {
        importError.textContent = "Only http(s) URLs are supported.";
        return;
      }
      try {
        const response = await fetch(url);
        if (!response.ok) {
          importError.textContent = `Fetch failed: ${response.status}`;
          return;
        }
        const text = await response.text();
        importText.value = text;
      } catch {
        importError.textContent = "Fetch failed. Check the URL and CORS settings.";
      }
    });

    importApplyButton?.addEventListener("click", () => {
      if (!importText || !importError) return;
      importError.textContent = "";
      const text = importText.value.trim();
      if (!text) {
        importError.textContent = "Paste YAML to import.";
        return;
      }
      try {
        state = parseCloudInitYaml(text);
        collapseState = {
          users: state.users.enabled,
          packages: state.packages.enabled,
          bootcmd: state.boot.enabled,
          runcmd: state.runcmd.enabled,
          write_files: state.writeFiles.enabled,
          services: state.services.enabled,
          network: state.network.enabled,
          apt: state.apt.enabled,
        };
        ensureDefaults();
        renderForm();
        syncCollapses();
      } catch {
        importError.textContent = "Import failed. This parser expects simple cloud-init YAML.";
      }
    });

