              <option value="ubuntu-24.04">Ubuntu 24.04 (Noble)</option>
              <option value="ubuntu-22.04">Ubuntu 22.04 (Jammy)</option>
              <option value="debian-13">Debian 13 (Trixie)</option>
              <option value="debian-12">Debian 12 (Bookworm)</option>
            </select>
          </div>
          <div class="space-y-2">
            <label class="text-xs uppercase tracking-wide text-muted" for="cloud-final-message">Final message</label>
            <input
              id="cloud-final-message"
              class="w-full rounded-lg border border-border bg-bg px-3 py-2 text-sm text-text"
              type="text"
              placeholder="Cloud-init complete."
            />
          </div>
        </div>
        <label class="flex items-center gap-2 text-sm text-muted">
          <input id="cloud-ssh-pwauth" type="checkbox" />
          Enable SSH password auth
        </label>
      </section>

      <section class="rounded-2xl border border-border bg-surface/90 p-5" data-section="users">
        <div class="flex flex-wrap items-start justify-between gap-4">
          <div>
            <h2 class="font-heading text-lg font-semibold text-text">Users</h2>
            <p class="text-sm text-muted">Create accounts, groups, and SSH keys.</p>
          </div>
          <div class="flex flex-wrap items-center gap-4">
            <label class="flex items-center gap-2 text-sm text-muted">
              <input id="cloud-users-enabled" type="checkbox" />
              Enabled
            </label>
            <button
              class="cc-tool-button rounded-lg border border-border px-3 py-1 text-xs font-semibold uppercase tracking-wide text-text hover:border-primary"
              type="button"
