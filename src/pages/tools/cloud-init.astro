    const buildTimezoneOptions = () => {
      if (!timezoneInput) return;
      const allTimezones = getTimezones();
      const timezoneSet = new Set(allTimezones);
      timezoneSet.add("UTC");
      timezoneSet.add("Etc/UTC");
      const commonSet = new Set(COMMON_TIMEZONES);
      const common = COMMON_TIMEZONES.filter((tz) => timezoneSet.has(tz));
      const other = [...timezoneSet].filter((tz) => !commonSet.has(tz)).sort();

      timezoneInput.innerHTML = "";
      const placeholder = document.createElement("option");
      placeholder.value = "";
      placeholder.textContent = "Select timezone";
      timezoneInput.appendChild(placeholder);

      common.forEach((tz) => {
        const option = document.createElement("option");
        option.value = tz;
        option.textContent = tz;
        timezoneInput.appendChild(option);
      });

      if (other.length) {
        const divider = document.createElement("option");
        divider.textContent = "────────";
        divider.disabled = true;
        timezoneInput.appendChild(divider);
      }

      other.forEach((tz) => {
        const option = document.createElement("option");
        option.value = tz;
        option.textContent = tz;
        timezoneInput.appendChild(option);
      });
    };

    const cloneState = (state) => {
      if (typeof structuredClone === "function") return structuredClone(state);
      return JSON.parse(JSON.stringify(state));
    };

    const escapeHtml = (value) =>
      String(value ?? "")
        .replace(/&/g, "&amp;")
        .replace(/</g, "&lt;")
        .replace(/>/g, "&gt;")
        .replace(/"/g, "&quot;")
        .replace(/'/g, "&#39;");

    const parseBoolean = (value) => {
      const normalized = value.trim().toLowerCase();
      return normalized === "true" || normalized === "yes" || normalized === "on";
    };

    const parseFlowArray = (value) =>
      value
        .replace(/^\[/, "")
        .replace(/\]$/, "")
        .split(",")
        .map((entry) =>
          entry
            .trim()
            .replace(/^'|'$/g, "")
            .replace(/''/g, "'")
            .replace(/^\"|\"$/g, "")
            .replace(/\\"/g, "\"")
            .replace(/\\\\/g, "\\")
        )
        .filter(Boolean);

    const parseScalar = (value) => {
      const trimmed = value.trim();
      if (trimmed.startsWith("'") && trimmed.endsWith("'")) {
        return trimmed.slice(1, -1).replace(/''/g, "'");
      }
      if (trimmed.startsWith("\"") && trimmed.endsWith("\"")) {
        return trimmed.slice(1, -1).replace(/\\"/g, "\"").replace(/\\\\/g, "\\");
      }
      return trimmed;
    };

    const normalizeOs = (value) => {
      const normalized = value.trim().toLowerCase();
      if (normalized === "ubuntu") return "ubuntu-24.04";
      if (normalized === "debian") return "debian-12";
      return value.trim() || "debian-12";
    };

    const parseCloudInitYaml = (yaml) => {
      const parsed = createEmptyState();
      const lines = yaml.replace(/\r/g, "").split("\n");
      let i = 0;
      const nextLine = () => lines[i];
      const getIndent = (line) => line.match(/^\s*/)[0].length;

      while (i < lines.length) {
        const line = nextLine();
        if (!line || line.trim() === "" || line.trim() === "#cloud-config") {
          i += 1;
          continue;
        }
        if (line.trim().startsWith("# os:")) {
          parsed.general.os = normalizeOs(line.trim().slice(5));
          i += 1;
          continue;
        }
        if (line.trim().startsWith("#")) {
          i += 1;
          continue;
        }
        const indent = getIndent(line);
        if (indent !== 0) {
          i += 1;
          continue;
        }
        const trimmed = line.trim();
        if (trimmed.startsWith("hostname:")) {
          parsed.general.hostname = parseScalar(trimmed.split(":").slice(1).join(":"));
        } else if (trimmed.startsWith("fqdn:")) {
          parsed.general.fqdn = parseScalar(trimmed.split(":").slice(1).join(":"));
        } else if (trimmed.startsWith("timezone:")) {
          parsed.general.timezone = parseScalar(trimmed.split(":").slice(1).join(":"));
        } else if (trimmed.startsWith("ssh_pwauth:")) {
          parsed.general.sshPwauth = parseBoolean(trimmed.split(":").slice(1).join(":"));
        } else if (trimmed.startsWith("disable_root:")) {
          parsed.users.disableRoot = parseBoolean(trimmed.split(":").slice(1).join(":"));
          parsed.users.enabled = true;
        } else if (trimmed.startsWith("lock_passwd:")) {
          parsed.users.lockPassword = parseBoolean(trimmed.split(":").slice(1).join(":"));
          parsed.users.enabled = true;
        } else if (trimmed.startsWith("package_update:")) {
          parsed.boot.packageUpdate = parseBoolean(trimmed.split(":").slice(1).join(":"));
          parsed.boot.enabled = true;
        } else if (trimmed.startsWith("package_upgrade:")) {
          parsed.boot.packageUpgrade = parseBoolean(trimmed.split(":").slice(1).join(":"));
          parsed.boot.enabled = true;
        } else if (trimmed === "ssh_import_id:") {
          i += 1;
          const ids = [];
          while (i < lines.length && getIndent(nextLine()) >= 2) {
            const idLine = nextLine().trim();
            if (idLine.startsWith("- ")) ids.push(parseScalar(idLine.slice(2)));
            i += 1;
          }
          parsed.users.sshImportId = ids.join("\n");
          parsed.users.enabled = true;
          continue;
        } else if (trimmed.startsWith("final_message:")) {
          const linesOut = [];
          i += 1;
          while (i < lines.length) {
            const messageLine = nextLine();
            if (messageLine === undefined) break;
            if (messageLine.trim() === "") {
              linesOut.push("");
              i += 1;
              continue;
            }
            if (getIndent(messageLine) < 2) break;
            linesOut.push(messageLine.slice(2));
            i += 1;
          }
          parsed.general.finalMessage = linesOut.join("\n").trimEnd();
          continue;
        } else if (trimmed.startsWith("packages:")) {
          parsed.packages.enabled = true;
          const optionSet = new Set(PACKAGE_OPTIONS);
          const inlineValue = trimmed.slice("packages:".length).trim();
          if (inlineValue.startsWith("[") && inlineValue.endsWith("]")) {
            inlineValue
              .slice(1, -1)
              .split(",")
              .map((entry) => entry.trim())
              .filter(Boolean)
              .forEach((pkg) => {
                const parsedPkg = parseScalar(pkg);
                if (optionSet.has(parsedPkg)) {
                  parsed.packages.selected.push(parsedPkg);
                } else {
                  parsed.packages.custom.push(parsedPkg);
                }
              });
            i += 1;
          } else if (trimmed === "packages:") {
            i += 1;
            while (i < lines.length && getIndent(nextLine()) >= 2) {
              const pkgLine = nextLine().trim();
              if (pkgLine.startsWith("#")) {
                i += 1;
                continue;
              }
              if (pkgLine.startsWith("- ")) {
                const pkg = parseScalar(pkgLine.slice(2));
                if (optionSet.has(pkg)) {
                  parsed.packages.selected.push(pkg);
                } else {
                  parsed.packages.custom.push(pkg);
                }
              }
              i += 1;
            }
          } else {
            i += 1;
          }
          continue;
        } else if (trimmed === "bootcmd:") {
          parsed.boot.enabled = true;
          i += 1;
          while (i < lines.length && getIndent(nextLine()) >= 2) {
            const cmdLine = nextLine().trim();
            if (cmdLine.startsWith("#")) {
              i += 1;
              continue;
            }
            if (cmdLine.startsWith("- ")) {
              parsed.boot.bootcmd.push(parseScalar(cmdLine.slice(2)));
            }
            i += 1;
          }
          continue;
        } else if (trimmed === "runcmd:") {
          parsed.runcmd.enabled = true;
          i += 1;
          while (i < lines.length && getIndent(nextLine()) >= 2) {
            const cmdLine = nextLine().trim();
            if (cmdLine.startsWith("#")) {
              i += 1;
              continue;
            }
            if (cmdLine.startsWith("- ")) {
              parsed.runcmd.items.push(parseScalar(cmdLine.slice(2)));
            }
            i += 1;
          }
          continue;
        } else if (trimmed === "users:") {
          parsed.users.enabled = true;
          i += 1;
          let currentUser = null;
          while (i < lines.length && getIndent(nextLine()) >= 2) {
            const userLine = nextLine();
            const userTrim = userLine.trim();
            if (userTrim.startsWith("- name:")) {
              if (currentUser) parsed.users.items.push(currentUser);
              currentUser = {
                name: parseScalar(userTrim.split(":").slice(1).join(":")),
                groups: "",
                sudo: "",
                shell: "",
                sshKeys: "",
                system: false,
              };
            } else if (currentUser && userTrim.startsWith("groups:")) {
              const groupValue = userTrim.split(":").slice(1).join(":").trim();
              currentUser.groups = groupValue.startsWith("[")
                ? parseFlowArray(groupValue).join(",")
                : parseScalar(groupValue);
            } else if (currentUser && userTrim.startsWith("sudo:")) {
              currentUser.sudo = parseScalar(userTrim.split(":").slice(1).join(":"));
            } else if (currentUser && userTrim.startsWith("shell:")) {
              currentUser.shell = parseScalar(userTrim.split(":").slice(1).join(":"));
            } else if (currentUser && userTrim.startsWith("system:")) {
              currentUser.system = parseBoolean(userTrim.split(":").slice(1).join(":"));
            } else if (currentUser && userTrim === "ssh_authorized_keys:") {
              i += 1;
              const keys = [];
              while (i < lines.length && getIndent(nextLine()) >= 4) {
                const keyLine = nextLine().trim();
                if (keyLine.startsWith("- ")) keys.push(parseScalar(keyLine.slice(2)));
                i += 1;
              }
              currentUser.sshKeys = keys.join("\n");
              continue;
            }
            i += 1;
          }
          if (currentUser) parsed.users.items.push(currentUser);
          continue;
        } else if (trimmed === "write_files:") {
          parsed.writeFiles.enabled = true;
          i += 1;
          let currentFile = null;
          while (i < lines.length && getIndent(nextLine()) >= 2) {
            const wfLine = nextLine();
            const wfTrim = wfLine.trim();
            if (wfTrim.startsWith("- path:")) {
              if (currentFile) parsed.writeFiles.items.push(currentFile);
              currentFile = {
                path: parseScalar(wfTrim.split(":").slice(1).join(":")),
                content: "",
                permissions: "",
                owner: "",
              };
            } else if (currentFile && wfTrim.startsWith("permissions:")) {
              currentFile.permissions = parseScalar(wfTrim.split(":").slice(1).join(":"));
            } else if (currentFile && wfTrim.startsWith("owner:")) {
              currentFile.owner = parseScalar(wfTrim.split(":").slice(1).join(":"));
            } else if (currentFile && wfTrim === "content: |") {
              i += 1;
              const contentLines = [];
              while (i < lines.length && getIndent(nextLine()) >= 4) {
                const contentLine = nextLine();
                contentLines.push(contentLine.slice(4));
                i += 1;
              }
              currentFile.content = contentLines.join("\n");
              continue;
            }
            i += 1;
          }
          if (currentFile) parsed.writeFiles.items.push(currentFile);
          continue;
        } else if (trimmed === "systemd:") {
          parsed.services.enabled = true;
          i += 1;
          while (i < lines.length && getIndent(nextLine()) >= 2) {
            const systemdLine = nextLine().trim();
            if (systemdLine === "units:") {
              i += 1;
              let currentUnit = null;
              while (i < lines.length && getIndent(nextLine()) >= 4) {
                const unitLine = nextLine();
                const unitTrim = unitLine.trim();
                if (unitTrim.startsWith("- name:")) {
                  if (currentUnit) parsed.services.units.push(currentUnit);
                  currentUnit = {
                    name: parseScalar(unitTrim.split(":").slice(1).join(":")),
                    enabled: true,
                    content: "",
                  };
                } else if (currentUnit && unitTrim.startsWith("enabled:")) {
                  currentUnit.enabled = parseBoolean(unitTrim.split(":").slice(1).join(":"));
                } else if (currentUnit && unitTrim === "contents: |") {
                  i += 1;
                  const contentLines = [];
                  while (i < lines.length && getIndent(nextLine()) >= 8) {
                    const contentLine = nextLine();
                    contentLines.push(contentLine.slice(8));
                    i += 1;
                  }
                  currentUnit.content = contentLines.join("\n");
                  continue;
                }
                i += 1;
              }
              if (currentUnit) parsed.services.units.push(currentUnit);
              continue;
            }
            i += 1;
          }
          continue;
        } else if (trimmed === "network:") {
          parsed.network.enabled = true;
          i += 1;
          while (i < lines.length && getIndent(nextLine()) >= 2) {
            const netLine = nextLine().trim();
            if (netLine.startsWith("renderer:")) {
              parsed.network.renderer = parseScalar(netLine.split(":").slice(1).join(":"));
              i += 1;
              continue;
            }
            if (netLine === "ethernets:") {
              i += 1;
              while (i < lines.length && getIndent(nextLine()) >= 4) {
                const ethLine = nextLine();
                const ethTrim = ethLine.trim();
                if (getIndent(ethLine) === 4 && ethTrim.endsWith(":")) {
                  const name = ethTrim.slice(0, -1);
                  const ethernet = {
                    name: parseScalar(name),
                    dhcp4: false,
                    dhcp6: false,
                    addresses: "",
                    gateway4: "",
                    gateway6: "",
                    nameservers: "",
                    mtu: "",
                    optional: false,
                    routes: "",
                  };
                  i += 1;
                  while (i < lines.length && getIndent(nextLine()) >= 6) {
                    const propLine = nextLine().trim();
                    if (propLine.startsWith("dhcp4:")) ethernet.dhcp4 = parseBoolean(propLine.split(":").slice(1).join(":"));
                    if (propLine.startsWith("dhcp6:")) ethernet.dhcp6 = parseBoolean(propLine.split(":").slice(1).join(":"));
                    if (propLine.startsWith("optional:")) ethernet.optional = parseBoolean(propLine.split(":").slice(1).join(":"));
                    if (propLine.startsWith("mtu:")) ethernet.mtu = parseScalar(propLine.split(":").slice(1).join(":"));
                    if (propLine.startsWith("addresses:")) {
                      const value = propLine.split(":").slice(1).join(":").trim();
                      ethernet.addresses = value.startsWith("[") ? parseFlowArray(value).join(",") : parseScalar(value);
                    }
                    if (propLine.startsWith("gateway4:")) ethernet.gateway4 = parseScalar(propLine.split(":").slice(1).join(":"));
                    if (propLine.startsWith("gateway6:")) ethernet.gateway6 = parseScalar(propLine.split(":").slice(1).join(":"));
                    if (propLine === "nameservers:") {
                      i += 1;
                      while (i < lines.length && getIndent(nextLine()) >= 8) {
                        const nsLine = nextLine().trim();
                        if (nsLine.startsWith("addresses:")) {
                          const value = nsLine.split(":").slice(1).join(":").trim();
                          ethernet.nameservers = value.startsWith("[") ? parseFlowArray(value).join(",") : parseScalar(value);
                        }
                        i += 1;
                      }
                      continue;
                    }
                    if (propLine === "routes:") {
                      i += 1;
                      const routes = [];
                      while (i < lines.length && getIndent(nextLine()) >= 8) {
                        const routeLine = nextLine().trim();
                        if (routeLine.startsWith("- to:")) {
                          const to = parseScalar(routeLine.split(":").slice(1).join(":"));
                          let via = "";
                          let metric = "";
                          i += 1;
                          while (i < lines.length && getIndent(nextLine()) >= 10) {
                            const routeProp = nextLine().trim();
                            if (routeProp.startsWith("via:")) via = parseScalar(routeProp.split(":").slice(1).join(":"));
                            if (routeProp.startsWith("metric:")) metric = parseScalar(routeProp.split(":").slice(1).join(":"));
                            i += 1;
                          }
                          routes.push([to, via, metric].filter(Boolean).join(" "));
                          continue;
                        }
                        i += 1;
                      }
                      ethernet.routes = routes.join("\n");
                      continue;
                    }
                    i += 1;
                  }
                  parsed.network.ethernets.push(ethernet);
                  continue;
                }
                i += 1;
              }
              continue;
            }
            if (netLine === "vlans:") {
              i += 1;
              while (i < lines.length && getIndent(nextLine()) >= 4) {
                const vlanLine = nextLine();
                const vlanTrim = vlanLine.trim();
                if (getIndent(vlanLine) === 4 && vlanTrim.endsWith(":")) {
                  const name = vlanTrim.slice(0, -1);
                  const vlan = {
                    name: parseScalar(name),
                    id: "",
                    link: "",
                    dhcp4: false,
                    dhcp6: false,
                    addresses: "",
                    gateway4: "",
                    gateway6: "",
                    nameservers: "",
                    mtu: "",
                    optional: false,
                    routes: "",
                  };
                  i += 1;
                  while (i < lines.length && getIndent(nextLine()) >= 6) {
                    const propLine = nextLine().trim();
                    if (propLine.startsWith("id:")) vlan.id = parseScalar(propLine.split(":").slice(1).join(":"));
                    if (propLine.startsWith("link:")) vlan.link = parseScalar(propLine.split(":").slice(1).join(":"));
                    if (propLine.startsWith("dhcp4:")) vlan.dhcp4 = parseBoolean(propLine.split(":").slice(1).join(":"));
                    if (propLine.startsWith("dhcp6:")) vlan.dhcp6 = parseBoolean(propLine.split(":").slice(1).join(":"));
                    if (propLine.startsWith("optional:")) vlan.optional = parseBoolean(propLine.split(":").slice(1).join(":"));
                    if (propLine.startsWith("mtu:")) vlan.mtu = parseScalar(propLine.split(":").slice(1).join(":"));
                    if (propLine.startsWith("addresses:")) {
                      const value = propLine.split(":").slice(1).join(":").trim();
                      vlan.addresses = value.startsWith("[") ? parseFlowArray(value).join(",") : parseScalar(value);
                    }
                    if (propLine.startsWith("gateway4:")) vlan.gateway4 = parseScalar(propLine.split(":").slice(1).join(":"));
                    if (propLine.startsWith("gateway6:")) vlan.gateway6 = parseScalar(propLine.split(":").slice(1).join(":"));
                    if (propLine === "nameservers:") {
                      i += 1;
                      while (i < lines.length && getIndent(nextLine()) >= 8) {
                        const nsLine = nextLine().trim();
                        if (nsLine.startsWith("addresses:")) {
                          const value = nsLine.split(":").slice(1).join(":").trim();
                          vlan.nameservers = value.startsWith("[") ? parseFlowArray(value).join(",") : parseScalar(value);
                        }
                        i += 1;
                      }
                      continue;
                    }
                    if (propLine === "routes:") {
                      i += 1;
                      const routes = [];
                      while (i < lines.length && getIndent(nextLine()) >= 8) {
                        const routeLine = nextLine().trim();
                        if (routeLine.startsWith("- to:")) {
                          const to = parseScalar(routeLine.split(":").slice(1).join(":"));
                          let via = "";
                          let metric = "";
                          i += 1;
                          while (i < lines.length && getIndent(nextLine()) >= 10) {
                            const routeProp = nextLine().trim();
                            if (routeProp.startsWith("via:")) via = parseScalar(routeProp.split(":").slice(1).join(":"));
                            if (routeProp.startsWith("metric:")) metric = parseScalar(routeProp.split(":").slice(1).join(":"));
                            i += 1;
                          }
                          routes.push([to, via, metric].filter(Boolean).join(" "));
                          continue;
                        }
                        i += 1;
                      }
                      vlan.routes = routes.join("\n");
                      continue;
                    }
                    i += 1;
                  }
                  parsed.network.vlans.push(vlan);
                  continue;
                }
                i += 1;
              }
              continue;
            }
            i += 1;
          }
          continue;
        } else if (trimmed === "apt:") {
          parsed.apt.enabled = true;
          i += 1;
          while (i < lines.length && getIndent(nextLine()) >= 2) {
            const aptLine = nextLine().trim();
            if (aptLine === "primary:") {
              i += 1;
              while (i < lines.length && getIndent(nextLine()) >= 4) {
                const primaryLine = nextLine().trim();
                if (primaryLine.startsWith("- uri:")) {
                  parsed.apt.primaryMirror = parseScalar(primaryLine.split(":").slice(1).join(":"));
                }
                i += 1;
              }
              continue;
            }
            if (aptLine === "proxy:") {
              i += 1;
              while (i < lines.length && getIndent(nextLine()) >= 4) {
                const proxyLine = nextLine().trim();
                if (proxyLine.startsWith("http:")) {
                  parsed.apt.httpProxy = parseScalar(proxyLine.split(":").slice(1).join(":"));
                }
                if (proxyLine.startsWith("https:")) {
                  parsed.apt.httpsProxy = parseScalar(proxyLine.split(":").slice(1).join(":"));
                }
                i += 1;
              }
              continue;
            }
            if (aptLine === "sources:") {
              i += 1;
              while (i < lines.length && getIndent(nextLine()) >= 4) {
                const sourceLine = nextLine();
                const sourceTrim = sourceLine.trim();
                if (getIndent(sourceLine) === 4 && sourceTrim.endsWith(":")) {
                  const name = sourceTrim.slice(0, -1);
                  const sourceEntry = {
                    name: parseScalar(name),
                    source: "",
                    key: "",
                    keyUrl: "",
                    keyPreset: "",
                  };
                  i += 1;
                  while (i < lines.length && getIndent(nextLine()) >= 6) {
                    const propLine = nextLine().trim();
                    if (propLine.startsWith("source:")) {
                      sourceEntry.source = parseScalar(propLine.split(":").slice(1).join(":"));
                    } else if (propLine === "key: |") {
                      i += 1;
                      const keyLines = [];
                      while (i < lines.length && getIndent(nextLine()) >= 8) {
                        const keyLine = nextLine();
                        keyLines.push(keyLine.slice(8));
                        i += 1;
                      }
                      sourceEntry.key = keyLines.join("\n");
                      continue;
                    }
                    i += 1;
                  }
                  parsed.apt.sources.push(sourceEntry);
                  continue;
                }
                i += 1;
              }
              continue;
            }
            i += 1;
          }
          continue;
        }
        i += 1;
      }

      return parsed;
    };

    let state = createEmptyState();
    let errors = {};
    const aptKeyStatus = new Map();
    const aptKeyPresetById = new Map(APT_KEY_PRESETS.map((preset) => [preset.id, preset]));
    const STORAGE_KEY = "cc-cloud-init-state-v1";
    let saveTimer = 0;

    const mergeState = (base, incoming) => {
      if (!incoming || typeof incoming !== "object") return base;
      const merged = createEmptyState();
      const mergeSection = (key) => {
        merged[key] = { ...base[key], ...incoming[key] };
      };
      mergeSection("general");
      mergeSection("users");
      mergeSection("packages");
      mergeSection("boot");
      mergeSection("runcmd");
      mergeSection("writeFiles");
      mergeSection("services");
      mergeSection("network");
      mergeSection("apt");
      if (Array.isArray(incoming.users?.items)) merged.users.items = incoming.users.items;
      if (Array.isArray(incoming.packages?.custom)) merged.packages.custom = incoming.packages.custom;
      if (Array.isArray(incoming.packages?.selected)) merged.packages.selected = incoming.packages.selected;
      if (Array.isArray(incoming.boot?.bootcmd)) merged.boot.bootcmd = incoming.boot.bootcmd;
      if (Array.isArray(incoming.runcmd?.items)) merged.runcmd.items = incoming.runcmd.items;
      if (Array.isArray(incoming.writeFiles?.items)) merged.writeFiles.items = incoming.writeFiles.items;
      if (Array.isArray(incoming.services?.units)) merged.services.units = incoming.services.units;
      if (Array.isArray(incoming.network?.ethernets)) merged.network.ethernets = incoming.network.ethernets;
      if (Array.isArray(incoming.network?.vlans)) merged.network.vlans = incoming.network.vlans;
      if (Array.isArray(incoming.apt?.sources)) merged.apt.sources = incoming.apt.sources;
      return merged;
    };

    const loadState = () => {
      try {
        const raw = localStorage.getItem(STORAGE_KEY);
        if (!raw) return;
        const parsed = JSON.parse(raw);
        state = mergeState(createEmptyState(), parsed);
      } catch {
        localStorage.removeItem(STORAGE_KEY);
      }
    };

    const scheduleSave = () => {
      clearTimeout(saveTimer);
      saveTimer = setTimeout(() => {
        try {
          localStorage.setItem(STORAGE_KEY, JSON.stringify(state));
        } catch {}
      }, 200);
    };

    const ensureDefaults = () => {
      if (state.users.enabled && state.users.items.length === 0) {
        state.users.items.push({
          name: "",
          groups: "",
          sudo: "",
          shell: "/bin/bash",
          sshKeys: "",
          system: false,
        });
      }
      if (state.boot.enabled && state.boot.bootcmd.length === 0) {
        state.boot.bootcmd.push("");
      }
      if (state.runcmd.enabled && state.runcmd.items.length === 0) {
        state.runcmd.items.push("");
      }
      if (state.writeFiles.enabled && state.writeFiles.items.length === 0) {
        state.writeFiles.items.push({
          path: "",
          content: "",
          permissions: "",
          owner: "",
        });
      }
      if (state.services.enabled && state.services.units.length === 0) {
        state.services.units.push({
          name: "",
          enabled: true,
          content: "",
        });
      }
      if (
        state.network.enabled &&
        state.network.ethernets.length === 0 &&
        state.network.vlans.length === 0 &&
        !state.network.raw.trim()
      ) {
        state.network.ethernets.push({
          name: "",
          dhcp4: true,
          dhcp6: false,
          addresses: "",
          gateway4: "",
          gateway6: "",
          nameservers: "",
          mtu: "",
          optional: false,
          routes: "",
        });
      }
      if (state.packages.enabled && state.packages.custom.length === 0) {
        state.packages.custom.push("");
      }
    };

    const validate = () => {
      const nextErrors = {};
      if (state.users.enabled) {
        if (state.users.items.length === 0 && !state.users.raw.trim()) {
          nextErrors.users = "Add at least one user.";
        }
        state.users.items.forEach((user, index) => {
          if (!user.name.trim()) {
            nextErrors[`users.${index}.name`] = "Username is required.";
          }
        });
      }
      if (state.packages.enabled) {
        const selected = state.packages.selected.filter(Boolean);
        const custom = state.packages.custom.map((entry) => entry.trim()).filter(Boolean);
        if (selected.length + custom.length === 0 && !state.packages.raw.trim()) {
          nextErrors.packages = "Select at least one package.";
        }
      }
      if (state.boot.enabled) {
        const commands = state.boot.bootcmd.map((entry) => entry.trim()).filter(Boolean);
        if (
          commands.length === 0 &&
          !state.boot.raw.trim() &&
          !state.boot.packageUpdate &&
          !state.boot.packageUpgrade
        ) {
          nextErrors.bootcmd = "Add at least one boot command.";
        }
      }
      if (state.runcmd.enabled) {
        const commands = state.runcmd.items.map((entry) => entry.trim()).filter(Boolean);
        if (commands.length === 0 && !state.runcmd.raw.trim()) {
          nextErrors.runcmd = "Add at least one command.";
        }
      }
      if (state.writeFiles.enabled) {
        if (state.writeFiles.items.length === 0 && !state.writeFiles.raw.trim()) {
          nextErrors.writeFiles = "Add at least one file.";
        }
        state.writeFiles.items.forEach((file, index) => {
          if (!file.path.trim()) {
            nextErrors[`writeFiles.${index}.path`] = "Path is required.";
          }
        });
      }
      if (state.services.enabled) {
        if (state.services.units.length === 0 && !state.services.raw.trim()) {
          nextErrors.services = "Add at least one unit.";
        }
        state.services.units.forEach((unit, index) => {
          if (!unit.name.trim()) {
            nextErrors[`services.${index}.name`] = "Unit name is required.";
          }
          if (!unit.content.trim()) {
            nextErrors[`services.${index}.content`] = "Unit contents are required.";
          }
        });
      }
      if (state.network.enabled) {
        if (
          state.network.ethernets.length === 0 &&
          state.network.vlans.length === 0 &&
          !state.network.raw.trim()
        ) {
          nextErrors.network = "Add at least one interface or VLAN.";
        }
        state.network.ethernets.forEach((ethernet, index) => {
          const isPlaceholder =
            !ethernet.name.trim() &&
            !ethernet.addresses.trim() &&
            !ethernet.gateway4.trim() &&
            !ethernet.gateway6.trim() &&
            !ethernet.nameservers.trim() &&
            !ethernet.mtu.trim() &&
            !ethernet.routes.trim() &&
            ethernet.dhcp4 === true &&
            ethernet.dhcp6 === false &&
            ethernet.optional === false;
          if (!ethernet.name.trim() && !isPlaceholder) {
            nextErrors[`network.ethernets.${index}.name`] = "Interface name is required.";
          }
        });
        state.network.vlans.forEach((vlan, index) => {
          const nameValue = String(vlan.name ?? "");
          const idValue = String(vlan.id ?? "");
          const linkValue = String(vlan.link ?? "");
          const addressesValue = String(vlan.addresses ?? "");
          const gateway4Value = String(vlan.gateway4 ?? "");
          const gateway6Value = String(vlan.gateway6 ?? "");
          const nameserversValue = String(vlan.nameservers ?? "");
          const mtuValue = String(vlan.mtu ?? "");
          const routesValue = String(vlan.routes ?? "");
          const isPlaceholder =
            !nameValue.trim() &&
            !idValue.trim() &&
            !linkValue.trim() &&
            !addressesValue.trim() &&
            !gateway4Value.trim() &&
            !gateway6Value.trim() &&
            !nameserversValue.trim() &&
            !mtuValue.trim() &&
            !routesValue.trim() &&
            vlan.dhcp4 === false &&
            vlan.dhcp6 === false &&
            vlan.optional === false;
          if (!nameValue.trim() && !isPlaceholder) {
            nextErrors[`network.vlans.${index}.name`] = "VLAN name is required.";
          }
          if ((!idValue.trim() || !linkValue.trim()) && !isPlaceholder) {
            if (!idValue.trim()) {
              nextErrors[`network.vlans.${index}.id`] = "VLAN ID is required.";
            }
            if (!linkValue.trim()) {
              nextErrors[`network.vlans.${index}.link`] = "Link interface is required.";
            }
          }
        });
      }
      if (state.apt.enabled) {
        state.apt.sources.forEach((source, index) => {
          const hasAny =
            source.name.trim() ||
            source.source.trim() ||
            source.key.trim() ||
            source.keyUrl.trim() ||
            source.keyPreset;
          if (!hasAny) return;
          if (!source.name.trim()) {
            nextErrors[`apt.sources.${index}.name`] = "Source name is required.";
          }
          if (!source.source.trim()) {
            nextErrors[`apt.sources.${index}.source`] = "Source line is required.";
          }
          if (!source.key.trim()) {
            nextErrors[`apt.sources.${index}.key`] = "PGP key is required.";
          }
        });
      }
      errors = nextErrors;
    };

    const updatePreview = () => {
      if (!preview || !updatedLabel) return;
      const yaml = buildCloudInitYaml(state);
      preview.textContent = yaml;
      updatedLabel.textContent = new Date().toLocaleString();
    };

    const updateErrors = () => {
      if (usersError) usersError.textContent = getError(errors, "users");
      if (packagesError) packagesError.textContent = getError(errors, "packages");
      if (bootcmdError) bootcmdError.textContent = getError(errors, "bootcmd");
      if (runcmdError) runcmdError.textContent = getError(errors, "runcmd");
      if (writeFilesError) writeFilesError.textContent = getError(errors, "writeFiles");
      if (servicesError) servicesError.textContent = getError(errors, "services");
      if (networkError) networkError.textContent = getError(errors, "network");
    };

    const updateDerived = () => {
      validate();
      updateErrors();
      updatePreview();
      scheduleSave();
    };

    const renderUsers = () => {
      if (!usersList) return;
      usersList.innerHTML = state.users.items
        .map((user, index) => {
          const nameError = getError(errors, `users.${index}.name`);
          const osValue = state.general.os || "debian-12";
          const baseOs = osValue.split("-")[0];
          const presets = APT_KEY_PRESETS.filter(
            (preset) => preset.os === osValue || preset.os === baseOs
          );
          return `
            <div class="rounded-xl border border-border bg-bg/60 p-4 space-y-3">
              <div class="flex items-center justify-between">
                <p class="text-xs uppercase tracking-wide text-muted">User ${index + 1}</p>
                <button
                  class="cc-tool-button rounded-lg border border-border px-2 py-1 text-xs uppercase tracking-wide text-text hover:border-primary"
                  type="button"
                  data-user-remove="${index}"
                >
                  Remove
                </button>
