const aptKeyPresets = await Promise.all(
  APT_KEY_MATRIX.map(async (preset) => {
    if (!preset.url) return { ...preset, key: "" };
    try {
      const response = await fetch(preset.url);
      if (!response.ok) return { ...preset, key: "" };
      const key = await response.text();
      return { ...preset, key: key.trim() };
    } catch {
      return { ...preset, key: "" };
    }
  })
);
