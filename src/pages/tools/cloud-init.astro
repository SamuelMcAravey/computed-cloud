            state.apt.sources[Number(index)].source = preset.source;
          }
          state.apt.sources[Number(index)].key = preset.key || "";
        }
        aptKeyStatus.delete(Number(index));
        renderAptSources();
        updateDerived();
        syncCollapses();
      }
    });

    aptSourcesList?.addEventListener("click", async (event) => {
      const target = event.target;
      if (target.dataset.aptRemove) {
        state.apt.sources.splice(Number(target.dataset.aptRemove), 1);
        aptKeyStatus.clear();
        renderAptSources();
        updateDerived();
        syncCollapses();
        return;
      }
      if (!target.dataset.aptKeyFetch) return;
      const index = Number(target.dataset.aptKeyFetch);
      const source = state.apt.sources[index];
      if (!source) return;
      const url = source.keyUrl.trim();
      if (!url) {
        aptKeyStatus.set(index, "Add a key URL.");
        renderAptSources();
        return;
      }
      try {
        aptKeyStatus.set(index, "Fetching...");
        renderAptSources();
        const response = await fetch(url);
        if (!response.ok) {
          aptKeyStatus.set(index, `Fetch failed: ${response.status}`);
          renderAptSources();
          return;
        }
        const key = await response.text();
        source.key = key.trim();
        aptKeyStatus.set(index, "Key fetched.");
        renderAptSources();
        updateDerived();
      } catch {
        aptKeyStatus.set(index, "Fetch failed. Check URL/CORS.");
        renderAptSources();
      }
    });

    addAptSourceButton?.addEventListener("click", () => {
      state.apt.sources.push({ name: "", source: "", key: "", keyUrl: "", keyPreset: "" });
      renderAptSources();
      updateDerived();
      syncCollapses();
    });

    document.addEventListener("click", (event) => {
      const target = event.target;
      if (target.id !== "add-apt-source") return;
      state.apt.sources.push({ name: "", source: "", key: "", keyUrl: "", keyPreset: "" });
      renderAptSources();
      updateDerived();
      syncCollapses();
    });

    aptPrimaryInput?.addEventListener("input", (event) => {
      state.apt.primaryMirror = event.target.value;
      updateDerived();
    });

    aptHttpInput?.addEventListener("input", (event) => {
      state.apt.httpProxy = event.target.value;
      updateDerived();
    });

    aptHttpsInput?.addEventListener("input", (event) => {
      state.apt.httpsProxy = event.target.value;
      updateDerived();
    });

    copyButton?.addEventListener("click", async () => {
      if (!preview) return;
      try {
        await navigator.clipboard.writeText(preview.textContent || "");
        copyButton.dataset.copied = "true";
        setTimeout(() => copyButton.removeAttribute("data-copied"), 1200);
      } catch {
        copyButton.dataset.copied = "true";
        setTimeout(() => copyButton.removeAttribute("data-copied"), 1200);
      }
    });

    downloadButton?.addEventListener("click", () => {
      downloadTextFile("cloud-init.yaml", preview?.textContent || "");
    });

    resetButton?.addEventListener("click", () => {
      state = createEmptyState();
      collapseState = {
        users: false,
        packages: false,
        bootcmd: false,
        runcmd: false,
        write_files: false,
        services: false,
        network: false,
        apt: false,
      };
      if (presetSelect) presetSelect.value = "";
      if (importText) importText.value = "";
      if (importUrlInput) importUrlInput.value = "";
      if (importError) importError.textContent = "";
      aptKeyStatus.clear();
      localStorage.removeItem(STORAGE_KEY);
      renderForm();
      syncCollapses();
    });

    loadState();
    buildTimezoneOptions();
    ensureDefaults();
    renderForm();
    syncCollapses();
  </script>

  <style>
    .cc-cloud-preview {
      min-height: 480px;
      border-radius: 1rem;
      border: 1px solid rgb(var(--cc-border));
      background: rgb(var(--cc-bg) / 0.7);
      padding: 1rem;
      font-family: var(--cc-font-mono);
      white-space: pre;
      overflow: auto;
      line-height: 1.6;
    }

    .cc-collapse {
      overflow: hidden;
      max-height: 0;
      opacity: 0;
      transition: max-height 200ms ease, opacity 200ms ease;
    }

    .cc-collapse[data-open="true"] {
      max-height: var(--collapse-height);
      opacity: 1;
    }
  </style>
</BaseLayout>









