            </button>
          </div>
        </div>
        <div class="cc-collapse mt-4" data-collapse="users">
          <div class="mb-4 grid gap-3 sm:grid-cols-2">
            <label class="flex items-center gap-2 text-sm text-muted">
              <input id="cloud-disable-root" type="checkbox" />
              disable_root
            </label>
            <label class="flex items-center gap-2 text-sm text-muted">
              <input id="cloud-lock-passwd" type="checkbox" />
              lock_passwd
            </label>
          </div>
          <div class="space-y-2">
            <label class="text-xs uppercase tracking-wide text-muted" for="cloud-ssh-import">ssh_import_id</label>
            <textarea
              id="cloud-ssh-import"
              class="min-h-[80px] w-full rounded-lg border border-border bg-bg px-3 py-2 text-sm text-text"
              placeholder="gh:username"
            ></textarea>
            <p class="text-xs text-muted">One entry per line.</p>
          </div>
          <div id="users-list" class="space-y-4 max-h-[45vh] overflow-auto cc-scrollbox"></div>
          <p id="users-error" class="text-xs text-rose-600"></p>
          <button
            id="add-user"
            class="cc-tool-button mt-3 rounded-lg border border-border px-3 py-2 text-sm font-medium text-text hover:border-primary"
            type="button"
          >
            Add user
          </button>
          <p class="mt-2 text-xs text-muted">Groups are comma-separated. SSH keys support one per line.</p>
          <div class="mt-3 space-y-2">
            <label class="text-xs uppercase tracking-wide text-muted" for="cloud-users-raw">Extra YAML (under users)</label>
            <textarea
              id="cloud-users-raw"
              class="min-h-[100px] w-full rounded-lg border border-border bg-bg px-3 py-2 text-sm text-text"
              placeholder="- name: extra"
            ></textarea>
            <p class="text-xs text-muted">Paste without indentation.</p>
          </div>
        </div>
      </section>

      <section class="rounded-2xl border border-border bg-surface/90 p-5" data-section="packages">
        <div class="flex flex-wrap items-start justify-between gap-4">
