<BaseLayout title="Cloud-init Generator" description="Generate cloud-init YAML in the browser." data-pagefind-ignore="all">
  <section class="space-y-4">
    <p class="text-xs uppercase tracking-wide text-muted">Tools</p>
    <h1 class="font-heading text-4xl font-semibold text-text">Cloud-init generator</h1>
    <p class="text-lg text-muted">
      Build cloud-init YAML with a live preview. Everything runs locally in your browser.
    </p>
  </section>

  <section class="mt-8 grid gap-6 lg:grid-cols-[minmax(0,1fr)_minmax(0,1fr)]">
    <div class="space-y-6">
      <section class="rounded-2xl border border-border bg-surface/90 p-5 space-y-4">
        <div class="flex flex-wrap items-center justify-between gap-4">
          <div>
            <h2 class="font-heading text-lg font-semibold text-text">Example preset</h2>
            <p class="text-sm text-muted">Start from a baseline and tweak as needed.</p>
          </div>
          <div class="flex flex-wrap items-center gap-3">
            <label class="text-xs uppercase tracking-wide text-muted" for="cloud-preset">Preset</label>
            <select
              id="cloud-preset"
              class="rounded-lg border border-border bg-bg px-3 py-2 text-sm text-text"
            >
              <option value="">Choose preset</option>
              <option value="minimal">Minimal</option>
              <option value="devVm">Dev VM</option>
              <option value="serverHardening">Server hardening</option>
            </select>
          </div>
        </div>
      </section>

      <section class="rounded-2xl border border-border bg-surface/90 p-5 space-y-4">
        <div class="space-y-1">
          <h2 class="font-heading text-lg font-semibold text-text">Import existing</h2>
          <p class="text-sm text-muted">Paste a cloud-init file or fetch one by URL.</p>
        </div>
        <div class="flex flex-wrap items-end gap-3">
          <div class="flex-1 space-y-2">
            <label class="text-xs uppercase tracking-wide text-muted" for="cloud-import-url">Remote URL</label>
            <input
              id="cloud-import-url"
              class="w-full rounded-lg border border-border bg-bg px-3 py-2 text-sm text-text"
              type="url"
              placeholder="https://example.com/cloud-init.yaml"
            />
            <p class="text-xs text-muted">Remote fetch requires CORS access from this site.</p>
          </div>
          <button
            class="cc-tool-button rounded-lg border border-border px-3 py-2 text-sm font-medium text-text hover:border-primary"
            type="button"
            id="cloud-import-fetch"
          >
            Fetch
          </button>
        </div>
        <div class="space-y-2">
          <label class="text-xs uppercase tracking-wide text-muted" for="cloud-import-text">Cloud-init YAML</label>
          <textarea
            id="cloud-import-text"
            class="min-h-[140px] w-full rounded-lg border border-border bg-bg px-3 py-2 text-sm text-text"
            placeholder="#cloud-config"
          ></textarea>
        </div>
        <div class="flex flex-wrap items-center gap-3">
          <button
            class="cc-tool-button rounded-lg border border-border px-3 py-2 text-sm font-medium text-text hover:border-primary"
            type="button"
            id="cloud-import-apply"
          >
            Import pasted
          </button>
          <p class="text-xs text-muted">Best for YAML generated by this tool.</p>
        </div>
        <p id="cloud-import-error" class="text-xs text-rose-600"></p>
      </section>

      <section class="rounded-2xl border border-border bg-surface/90 p-5 space-y-4">
        <div class="space-y-1">
          <h2 class="font-heading text-lg font-semibold text-text">Base settings</h2>
          <p class="text-sm text-muted">Core machine metadata used by most cloud-init flows.</p>
        </div>
        <div class="grid gap-4 sm:grid-cols-2">
          <div class="space-y-2">
            <label class="text-xs uppercase tracking-wide text-muted" for="cloud-hostname">Hostname</label>
            <input
              id="cloud-hostname"
              class="w-full rounded-lg border border-border bg-bg px-3 py-2 text-sm text-text"
              type="text"
              placeholder="example-host"
            />
          </div>
          <div class="space-y-2">
            <label class="text-xs uppercase tracking-wide text-muted" for="cloud-fqdn">FQDN</label>
            <input
              id="cloud-fqdn"
              class="w-full rounded-lg border border-border bg-bg px-3 py-2 text-sm text-text"
              type="text"
              placeholder="example.internal"
            />
          </div>
          <div class="space-y-2">
            <label class="text-xs uppercase tracking-wide text-muted" for="cloud-timezone">Timezone</label>
            <select
              id="cloud-timezone"
              class="w-full rounded-lg border border-border bg-bg px-3 py-2 text-sm text-text"
            ></select>
          </div>
          <div class="space-y-2">
            <label class="text-xs uppercase tracking-wide text-muted" for="cloud-os">OS</label>
            <select
              id="cloud-os"
              class="w-full rounded-lg border border-border bg-bg px-3 py-2 text-sm text-text"
