                    class="w-full rounded-lg border border-border bg-bg px-3 py-2 text-sm text-text"
                    type="text"
                    placeholder="microsoft"
                    value="${escapeHtml(source.name)}"
                    data-apt-index="${index}"
                    data-field="name"
                  />
                  <p class="text-xs text-rose-600">${nameError}</p>
                </div>
                <div class="space-y-2">
                  <label class="text-xs uppercase tracking-wide text-muted" for="cloud-apt-source-${index}">Source line (required)</label>
                  <input
                    id="cloud-apt-source-${index}"
                    class="w-full rounded-lg border border-border bg-bg px-3 py-2 text-sm text-text"
                    type="text"
                    placeholder="deb [arch=amd64] https://repo.example stable main"
                    value="${escapeHtml(source.source)}"
                    data-apt-index="${index}"
                    data-field="source"
                  />
                  <p class="text-xs text-rose-600">${sourceError}</p>
                </div>
              </div>
              <div class="grid gap-3 sm:grid-cols-2">
                <div class="space-y-2">
                  <label class="text-xs uppercase tracking-wide text-muted" for="cloud-apt-preset-${index}">Key preset</label>
                  <select
                    id="cloud-apt-preset-${index}"
                    class="w-full rounded-lg border border-border bg-bg px-3 py-2 text-sm text-text"
                    data-apt-index="${index}"
                    data-field="keyPreset"
                  >
                    <option value="">Choose preset</option>
                    ${presets.map((preset) => `
                      <option value="${preset.id}" ${source.keyPreset === preset.id ? "selected" : ""}>${preset.label}</option>
                    `).join("")}
                  </select>
                </div>
                <div class="space-y-2">
                  <label class="text-xs uppercase tracking-wide text-muted" for="cloud-apt-key-url-${index}">Key URL</label>
                  <input
                    id="cloud-apt-key-url-${index}"
                    class="w-full rounded-lg border border-border bg-bg px-3 py-2 text-sm text-text"
                    type="url"
                    placeholder="https://example.com/key.asc"
                    value="${escapeHtml(source.keyUrl)}"
                    data-apt-index="${index}"
                    data-field="keyUrl"
                  />
                </div>
              </div>
              <div class="space-y-2">
                <label class="text-xs uppercase tracking-wide text-muted" for="cloud-apt-key-${index}">Key (required)</label>
                <textarea
                  id="cloud-apt-key-${index}"
                  class="min-h-[120px] w-full rounded-lg border border-border bg-bg px-3 py-2 text-sm text-text"
                  placeholder="-----BEGIN PGP PUBLIC KEY BLOCK-----"
                  data-apt-index="${index}"
                  data-field="key"
                >${escapeHtml(source.key)}</textarea>
                <p class="text-xs text-rose-600">${keyError}</p>
                <div class="flex flex-wrap items-center gap-2 text-xs text-muted">
                  <button
                    class="cc-tool-button rounded-lg border border-border px-2 py-1 text-xs font-semibold uppercase tracking-wide text-text hover:border-primary"
                    type="button"
                    data-apt-key-fetch="${index}"
                  >
                    Fetch key
                  </button>
                  <span>${escapeHtml(status)}</span>
                </div>
              </div>
            </div>
          `;
        })
        .join("");
