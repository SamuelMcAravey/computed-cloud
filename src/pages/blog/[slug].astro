---
import PostLayout from "@layouts/PostLayout.astro";
import { getCollection } from "astro:content";
import { byNewest, getPostSlug, includeDrafts } from "../../utils/blog";

export async function getStaticPaths() {
  const posts = (await getCollection("blog"))
    .filter((post) => includeDrafts || !post.data.draft)
    .sort(byNewest);

  return posts.map((post, index) => {
    const newer = index > 0 ? posts[index - 1] : undefined;
    const older = index < posts.length - 1 ? posts[index + 1] : undefined;

    return {
      params: { slug: getPostSlug(post) },
      props: {
        post,
        newer:
          newer && ({
            title: newer.data.title,
            slug: getPostSlug(newer),
          } as const),
        older:
          older && ({
            title: older.data.title,
            slug: getPostSlug(older),
          } as const),
      },
    };
  });
}

const { post, newer, older } = Astro.props;
const { Content, headings } = await post.render();
---

<PostLayout
  title={post.data.title}
  description={post.data.description}
  pubDate={post.data.pubDate}
  updatedDate={post.data.updatedDate}
  tags={post.data.tags}
  heroImage={post.data.heroImage}
  headings={headings}
  newer={newer}
  older={older}
>
  <Content />
</PostLayout>
