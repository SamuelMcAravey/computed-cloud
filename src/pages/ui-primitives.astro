---
import BaseLayout from "@layouts/BaseLayout.astro";
import Container from "@components/ui/Container.astro";
import Section from "@components/ui/Section.astro";
import SectionHeading from "@components/ui/SectionHeading.astro";
import Button from "@components/ui/Button.astro";
import ButtonLink from "@components/ui/ButtonLink.astro";
import Card from "@components/ui/Card.astro";
import Badge from "@components/ui/Badge.astro";
import IconBadge from "@components/ui/IconBadge.astro";
import Divider from "@components/ui/Divider.astro";
import SectionDivider from "@components/ui/SectionDivider.astro";
import Prose from "@components/ui/Prose.astro";
import ResponsiveImage from "@components/ui/ResponsiveImage.astro";
import LinkList from "@components/ui/LinkList.astro";

const linkItems = [
  { label: "Overview", href: "/about" },
  { label: "Services", href: "/services" },
  { label: "External Resource", href: "https://example.com", external: true },
  { label: "Empty", href: "" },
];
---

<BaseLayout
  pageTitle="UI Primitives"
  description="A sample page that showcases reusable UI primitives."
>
  <div class="space-y-16">
    <Section>
      <SectionHeading
        eyebrow="Component Library"
        headline="UI Primitives"
        body={[
          "A compact showcase of reusable primitives for layout, typography, and calls to action.",
          "Each section demonstrates alignment, spacing, and variant options.",
        ]}
        align="left"
        size="lg"
      />
      <div class="mt-8 flex flex-wrap items-center gap-3">
        <Badge tone="neutral">Neutral</Badge>
        <Badge tone="primary">Primary</Badge>
        <Badge tone="success">Success</Badge>
        <Badge tone="warning">Warning</Badge>
        <Badge tone="danger">Danger</Badge>
        <IconBadge tone="success">
          <svg
            slot="icon"
            xmlns="http://www.w3.org/2000/svg"
            viewBox="0 0 20 20"
            fill="currentColor"
            class="h-4 w-4"
            aria-hidden="true"
          >
            <path
              fill-rule="evenodd"
              d="M16.704 5.29a1 1 0 0 1 .006 1.414l-7.25 7.3a1 1 0 0 1-1.42 0L3.29 10.2a1 1 0 1 1 1.42-1.4l3.02 3.02 6.54-6.55a1 1 0 0 1 1.414.02Z"
              clip-rule="evenodd"
            />
          </svg>
          Verified
        </IconBadge>
      </div>
      <div class="mt-8 flex flex-wrap gap-4">
        <Button>
          <span slot="startIcon">
            <svg
              xmlns="http://www.w3.org/2000/svg"
              viewBox="0 0 20 20"
              fill="currentColor"
              class="h-4 w-4"
              aria-hidden="true"
            >
              <path d="M10 2a1 1 0 0 1 1 1v6h6a1 1 0 1 1 0 2h-6v6a1 1 0 1 1-2 0v-6H3a1 1 0 1 1 0-2h6V3a1 1 0 0 1 1-1Z" />
            </svg>
          </span>
          Primary Button
        </Button>
        <Button variant="secondary">Secondary Button</Button>
        <Button variant="ghost">Ghost Button</Button>
        <ButtonLink href="/contact">Button Link</ButtonLink>
      </div>
    </Section>

    <SectionDivider label="Surfaces" />

    <Section>
      <SectionHeading
        headline="Cards and Imagery"
        body="Cards support variants, padding, and link behavior. Images enforce alt text and optional framing."
        align="left"
        size="md"
      />
      <div class="mt-8 grid gap-6 md:grid-cols-2">
        <Card>
          <ResponsiveImage
            src="/images/hero.jpg"
            alt="Abstract industrial scene"
            variant="framed"
            rounded="2xl"
          />
          <div class="mt-6 space-y-2">
            <h3 class="text-lg font-semibold text-slate-900">Framed image card</h3>
            <p class="text-sm text-slate-600">
              Use framed images to highlight media while keeping a clean surface.
            </p>
          </div>
        </Card>
        <Card href="/services" ariaLabel="Explore services">
          <div class="space-y-2">
            <h3 class="text-lg font-semibold text-slate-900">Linked card</h3>
            <p class="text-sm text-slate-600">
              Cards can act as links with hover feedback and focus rings.
            </p>
          </div>
          <Divider class="my-6" />
          <div class="flex items-center justify-between text-sm text-slate-600">
            <span>Learn more</span>
            <span aria-hidden="true">→</span>
          </div>
        </Card>
      </div>
    </Section>

    <Section tone="muted">
      <SectionHeading
        headline="Typography and Prose"
        body="Use Prose for rich text blocks, lists, and inline links."
        align="left"
        size="md"
      />
      <div class="mt-8">
        <Prose size="base">
          <h2>Heading level two</h2>
          <p>
            This block demonstrates paragraph styling with a
            <a href="/about">sample link</a> and <strong>emphasized text</strong>.
          </p>
          <h3>Subheading</h3>
          <ul>
            <li>List item one</li>
            <li>List item two</li>
            <li>List item three</li>
          </ul>
        </Prose>
      </div>
    </Section>

    <Section>
      <SectionHeading
        headline="Lists and Dividers"
        body="Link lists support stacked, inline, or bulleted layouts with hover markers."
        align="left"
        size="md"
      />
      <div class="mt-8 grid gap-8 md:grid-cols-2">
        <div class="space-y-4">
          <h3 class="text-sm font-semibold uppercase tracking-wider text-slate-500">
            Stacked links
          </h3>
          <LinkList items={linkItems} showHoverMarker />
          <Divider label="Inline" />
          <LinkList items={linkItems} variant="inline" tone="default" />
        </div>
        <div class="space-y-6">
          <h3 class="text-sm font-semibold uppercase tracking-wider text-slate-500">
            Container widths
          </h3>
          <div class="space-y-4">
            <Container size="narrow" class="rounded-2xl border border-slate-200 bg-slate-50 p-4">
              <p class="text-sm text-slate-600">Narrow container</p>
            </Container>
            <Container size="wide" class="rounded-2xl border border-slate-200 bg-slate-50 p-4">
              <p class="text-sm text-slate-600">Wide container</p>
            </Container>
            <div class="flex items-stretch gap-4">
              <div class="flex-1 rounded-2xl border border-slate-200 p-4 text-sm text-slate-600">
                Left panel
              </div>
              <Divider orientation="vertical" />
              <div class="flex-1 rounded-2xl border border-slate-200 p-4 text-sm text-slate-600">
                Right panel
              </div>
            </div>
          </div>
        </div>
      </div>
    </Section>
  </div>
</BaseLayout>
