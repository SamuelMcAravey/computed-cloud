---
import BaseLayout from '@layouts/BaseLayout.astro';
import TemplatePageRouter from '../templates/TemplatePageRouter.astro';
import { site } from '../data/site';
const { hero, seo } = site.pages.pricing;
---
<BaseLayout  pageTitle={hero.headline}  title={seo?.title}  description={seo?.description ?? hero.subheadline}>
  <TemplatePageRouter route="pricing" />
</BaseLayout>
