---
import { getCollection } from "astro:content";
import BaseLayout from "@layouts/BaseLayout.astro";
import NoteCard from "@components/NoteCard.astro";
import { flattenNotes } from "../utils/notes";

const notes = flattenNotes(await getCollection("notes"));
---

<BaseLayout
  title="Notes"
  description="Shorter notes on systems, integrations, operations, and things worth keeping."
>
  <section class="space-y-6">
    <p class="text-xs uppercase tracking-[0.2em] text-muted">Notes</p>
    <h1 class="font-heading text-4xl font-semibold text-text">Notes</h1>
    <p class="max-w-3xl text-lg leading-8 text-muted">
      Short reference notes on systems, integrations, operations, and things I want
      to remember. Some are current. Some come from older work that is still worth
      writing down.
    </p>
  </section>

  <section class="notes-masonry mt-10 flex flex-col gap-6 lg:flex-row lg:flex-wrap lg:items-start" data-notes-masonry>
    {notes.map((note) => (
      <div class="w-full lg:w-[calc((100%-48px)/2)] lg:shrink-0">
        <NoteCard note={note} compact />
      </div>
    ))}
  </section>

  <script>
    import MagicGrid from "magic-grid";

    const initNotesGrid = () => {
      const grid = document.querySelector("[data-notes-masonry]");
      if (!(grid instanceof HTMLElement)) {
        return;
      }

      const magicGrid = new MagicGrid({
        container: grid,
        static: true,
        gutter: 24,
        maxColumns: 2,
        useMin: true,
        center: false,
      });

      magicGrid.listen();
    };

    if (document.readyState === "complete") {
      initNotesGrid();
    } else {
      window.addEventListener("load", initNotesGrid, { once: true });
    }
  </script>
</BaseLayout>
