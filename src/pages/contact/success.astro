---
import BaseLayout from "@layouts/BaseLayout.astro";
import { site } from "../../data/site";

const success = (site.pages.contact as any).success ?? {
  headline: "Thanks — we received your request.",
  body: "We will reply the same day when possible.",
  cta: { label: "Back to home", href: "/" },
};
---

<BaseLayout pageTitle={success.headline} description={success.body}>
  <section class="container mx-auto px-4 sm:px-6 lg:px-8">
    <div class="max-w-3xl space-y-6">
      <div class="space-y-3">
        <h1 class="text-3xl font-bold text-slate-900 sm:text-4xl">
          {success.headline}
        </h1>
        <p class="text-base text-slate-600">{success.body}</p>
      </div>
      <a
        href={success.cta.href}
        class="inline-flex items-center px-6 py-3 text-sm font-semibold text-white bg-blue-600 rounded-lg shadow hover:bg-blue-700 transition-colors"
      >
        {success.cta.label}
      </a>
    </div>
  </section>
</BaseLayout>
