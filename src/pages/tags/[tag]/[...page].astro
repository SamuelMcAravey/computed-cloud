---
import BaseLayout from "@layouts/BaseLayout.astro";
import Pagination from "@components/Pagination.astro";
import PostCard from "@components/PostCard.astro";
import { getCollection } from "astro:content";
import { POSTS_PER_PAGE } from "../../../consts";
import { byNewest, getPostSlug, includeDrafts, normalizeTag } from "../../../utils/blog";

export async function getStaticPaths({ paginate }) {
  const posts = (await getCollection("blog")).filter(
    (post) => includeDrafts || !post.data.draft
  );

  const tagMap = new Map<string, { label: string; posts: typeof posts }>();

  for (const post of posts) {
    for (const tag of post.data.tags) {
      const key = normalizeTag(tag);
      const entry = tagMap.get(key);
      if (entry) {
        entry.posts.push(post);
      } else {
        tagMap.set(key, { label: tag, posts: [post] });
      }
    }
  }

  const paths = [];
  for (const [tag, entry] of tagMap.entries()) {
    const sorted = entry.posts.sort(byNewest);
    paths.push(
      ...paginate(sorted, {
        pageSize: POSTS_PER_PAGE,
        params: { tag },
        props: { tagLabel: entry.label },
      })
    );
  }

  return paths;
}

const { page, tagLabel } = Astro.props;
---

<BaseLayout
  title={`Tag: ${tagLabel}`}
  description={`Posts tagged with ${tagLabel}.`}
  data-pagefind-ignore="all"
>
  <section class="space-y-4">
    <p class="text-xs uppercase tracking-wide text-muted">Tag</p>
    <h1 class="font-heading text-3xl font-semibold text-text">{tagLabel}</h1>
    <p class="text-muted">Posts filed under {tagLabel}.</p>
  </section>

  <section class="mt-10 space-y-6">
    {page.data.map((post) => (
      <PostCard post={post} slug={getPostSlug(post)} />
    ))}
  </section>

  <Pagination page={page} />
</BaseLayout>
